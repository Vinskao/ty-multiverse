          -ms-interpolation-mode: nearest-neighbor;
        }
      `;
      document.head.appendChild(style);
      // 使用 peopleService 獲取角色列表和詳細信息
      const { peopleService } = await import('../services/api/peopleService');

      // 1. 先獲取角色名稱列表
      console.log('🔄 Levellist 使用 peopleService 獲取角色名稱列表...');
      const characterNames = await peopleService.getAllPeopleNames();
      console.log('✅ Levellist 獲取角色名稱列表成功:', characterNames);

      // 確保是數組格式
      if (!Array.isArray(characterNames)) {
        throw new Error('角色名稱列表格式錯誤');
      }

      // 2. 獲取每個角色的詳細信息並計算總戰力
      const charactersWithPower = await Promise.all(
        characterNames.map(async (name, index) => {
          try {
            // 檢查是否有暫存的戰力數據
            const cachedData = getFromLocalStorage(name);
            if (cachedData) {
              // 使用暫存的戰力數據
              return {
                name: name,
                nameOriginal: cachedData.nameOriginal || name,
                totalPower: cachedData.totalPower,
                physicPower: cachedData.physicPower,
                magicPower: cachedData.magicPower,
                utilityPower: cachedData.utilityPower + (cachedData.hasBonus ? cachedData.weaponBonus : 0),
                originalUtilityPower: cachedData.utilityPower,
                weaponBonus: cachedData.weaponBonus,
                hasBonus: cachedData.hasBonus,
                weaponData: cachedData.weaponData,
                attributes: cachedData.attributes
              };
            }
            
            // 獲取角色詳細信息（使用 peopleService，自動使用正確的 Gateway URL）
            let character: any;
            try {
              // 使用 peopleService 的同步方法獲取角色信息
              character = await peopleService.getPersonByNameAndWait(name);
            } catch (error) {
              console.error(`獲取角色 ${name} 信息失敗:`, error);
              throw new Error(`獲取角色 ${name} 信息失敗: ${error instanceof Error ? error.message : String(error)}`);
            }

            // 基本能力值
            const physicPower = parseInt(String(character?.physicPower || 0), 10);
            const magicPower = parseInt(String(character?.magicPower || 0), 10);
            const utilityPower = parseInt(String(character.utilityPower || 0), 10);
            const originalUtilityPower = utilityPower;

            // 透過 damageWithWeapon API 取得總戰力
            let totalPower = physicPower + magicPower + utilityPower;

            // 添加延遲以避免 429 錯誤
            if (index > 0) {
              await new Promise(resolve => setTimeout(resolve, 100 * index)); // 每個請求間隔 100ms
            }

            try {
              // 使用新的傷害計算服務
              const damageService = (await import('../services/api/damageService')).default.getInstance();
              const damageValue = await damageService.getCharacterDamage(name);
              if (damageValue > 0) {
                totalPower = damageValue;
              }
            } catch (e) {
              console.error(`damageWithWeapon API error for ${name}:`, e);
            }

            // 計算武器加成
            const weaponBonus = totalPower - (physicPower + magicPower + utilityPower);
            const hasBonus = weaponBonus > 0;

            return {
              ...character,
              totalPower,
              physicPower,
              magicPower,
              utilityPower,
              originalUtilityPower,
              weaponBonus,
              hasBonus,
              weaponData: null
            };
          } catch (error) {
            console.error(`Error fetching weapon info for ${name}:`, error);
            // 如果獲取角色信息失敗，返回基本信息
            return {
              name: name,
              nameOriginal: name,
              physicPower: 0,
              magicPower: 0,
              utilityPower: 0,
              totalPower: 0,
              attributes: '未知',
              weaponBonus: 0,
              hasBonus: false,
              weaponData: null
            };
          }
        })
      );

      // 過濾掉戰力為0的角色和沒有圖片的角色
      const validCharacters = await Promise.all(
        charactersWithPower.filter(char => char.totalPower > 0).map(async (character) => {
            const imagePath = `${PEOPLE_IMAGE_URL}/${character.name || 'default'}.png`;
          const hasImage = await checkImageExists(imagePath);
          return hasImage ? character : null;
        })
      );
      
      const filteredCharacters = validCharacters.filter(char => char !== null);
      filteredCharacters.sort((a, b) => b.totalPower - a.totalPower);

      // 創建戰力列表
      createPowerList(charactersWithPower);

      // 動態生成SS及以上等級
      const POWER_LEVELS = [...BASE_POWER_LEVELS];
      const maxPower = filteredCharacters.length > 0 ? filteredCharacters[0].totalPower : 0;
      let currentMin = 3600;
      let levelIndex = 1;
      let multiplier = 1.0;
      
      while (currentMin <= maxPower) {
        multiplier *= 1.2;
        const levelSize = Math.floor(1000 * multiplier);
        const levelMax = currentMin + levelSize - 1;
        const levelName = "Level " + "S".repeat(levelIndex + 1);
        const redValue = Math.max(50, 255 - (levelIndex * 20));
        const color = `rgb(${redValue}, 0, 0)`;
        
        POWER_LEVELS.unshift({
          name: levelName,
          min: currentMin,
          max: levelMax,
          color: color
        });
        
        currentMin = levelMax + 1;
        levelIndex++;
      }

      // 將角色分配到各個等級
      const levelGroups = {};
      POWER_LEVELS.forEach(level => {
        levelGroups[level.name] = [];
      });

      filteredCharacters.forEach(character => {
        for (let i = 0; i < POWER_LEVELS.length; i++) {
          if (character.totalPower >= POWER_LEVELS[i].min && character.totalPower <= POWER_LEVELS[i].max) {
            levelGroups[POWER_LEVELS[i].name].push(character);
            break;
          }
        }
      });

      // 創建 UI
      const mainContainer = document.createElement('div');
      mainContainer.className = 'level-groups';

      // 從低到高顯示等級，跳過沒有角色的等級
      for (const level of POWER_LEVELS.reverse()) {
        const characters = levelGroups[level.name];
        if (characters.length === 0) continue;
        mainContainer.appendChild(await createLevelContainer(level, characters));
      }

      const container = document.getElementById('level-container');
      if (container) {
        container.appendChild(mainContainer);
      }
    } catch (error) {
      console.error('Error loading Levellist:', error);
      
      // 顯示用戶友好的錯誤訊息
      if (typeof (window as any).Swal !== 'undefined') {
        (window as any).Swal.fire({
          title: '載入失敗',
          text: `無法載入角色數據: ${error.message}`,
          icon: 'error',
          confirmButtonText: '重新整理',
          showCancelButton: true,
          cancelButtonText: '取消'
        }).then((result) => {
          if (result.isConfirmed) {
            window.location.reload();
          }
        });
      } else {
        console.error(`載入失敗: ${error.message}`);
      }
    }
  });
</script>
