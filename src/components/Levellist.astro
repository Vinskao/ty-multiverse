  // 匯出表格功能
  function exportToExcel() {
    const exportBtn = document.getElementById('export-btn') as HTMLButtonElement;
    if (!exportBtn) return;
    
    // 禁用按鈕並顯示載入狀態
    exportBtn.disabled = true;
    exportBtn.innerHTML = `
      <span>匯出中...</span>
      <div style="
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
        transition: left 0.5s ease;
      "></div>
    `;
    exportBtn.style.background = 'linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%)';
    exportBtn.style.transform = 'scale(0.95)';
    exportBtn.style.boxShadow = '0 4px 15px rgba(255, 107, 107, 0.5)';
    
    try {
      console.log('📊 開始匯出表格...');
      
      // 檢查 SheetJS 是否已載入
      if (typeof (window as any).XLSX === 'undefined') {
        throw new Error('SheetJS 庫未載入，請重新整理頁面');
      }
      
      // 獲取表格元素
      const table = document.querySelector('#power-list table');
      if (!table) {
        throw new Error('找不到表格元素');
      }
      
      // 獲取表頭
      const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent?.trim() || '');
      
      // 獲取表格數據
      const rows = Array.from(table.querySelectorAll('tbody tr'));
      const data = rows.map(row => {
        const cells = Array.from(row.querySelectorAll('td'));
        return cells.map(cell => {
          // 如果是輸入框，獲取其值
          const input = cell.querySelector('input');
          if (input) {
            return input.value;
          }
          // 否則獲取文字內容
          return cell.textContent?.trim() || '';
        });
      });
      
      // 創建工作簿
      const wb = (window as any).XLSX.utils.book_new();
      
      // 創建主要數據工作表
      const wsData = [headers, ...data];
      const ws = (window as any).XLSX.utils.aoa_to_sheet(wsData);
      
      // 設置列寬
      const colWidths = headers.map(header => ({ wch: Math.max(header.length, 10) }));
      ws['!cols'] = colWidths;
      
      // 添加工作表到工作簿
      (window as any).XLSX.utils.book_append_sheet(wb, ws, '力表數據');
      
      // 創建統計工作表
      const powerRanges = {
        '0-999': 0,
        '1000-1999': 0,
        '2000-2999': 0,
        '3000-3999': 0,
        '4000+': 0
      };
      
      data.forEach(row => {
        const totalPower = parseInt(row[6]) || 0; // 總戰力在第7列
        if (totalPower < 1000) powerRanges['0-999']++;
        else if (totalPower < 2000) powerRanges['1000-1999']++;
        else if (totalPower < 3000) powerRanges['2000-2999']++;
        else if (totalPower < 4000) powerRanges['3000-3999']++;
        else powerRanges['4000+']++;
      });
      
      const statsData = [
        ['戰力範圍', '角色數量'],
        ...Object.entries(powerRanges).map(([range, count]) => [range, count])
      ];
      
      const wsStats = (window as any).XLSX.utils.aoa_to_sheet(statsData);
      wsStats['!cols'] = [{ wch: 15 }, { wch: 10 }];
      (window as any).XLSX.utils.book_append_sheet(wb, wsStats, '統計信息');
      
      // 創建摘要工作表
      const summaryData = [
        ['力表匯出報告'],
        [''],
        ['匯出時間', new Date().toLocaleString('zh-TW')],
        ['總角色數', data.length],
        [''],
        ['戰力統計'],
        ['最高戰力', Math.max(...data.map(row => parseInt(row[6]) || 0))],
        ['最低戰力', Math.min(...data.map(row => parseInt(row[6]) || 0))],
        ['平均戰力', Math.round(data.reduce((sum, row) => sum + (parseInt(row[6]) || 0), 0) / data.length)],
        [''],
        ['軍隊分布'],
        ...Object.entries(
          data.reduce((acc, row) => {
            const armyName = row[1] || '未知'; // 假設軍隊名稱在第2列
            acc[armyName] = (acc[armyName] || 0) + 1;
            return acc;
          }, {} as Record<string, number>)
        ).sort((a, b) => b[1] - a[1])
      ];
      
      const wsSummary = (window as any).XLSX.utils.aoa_to_sheet(summaryData);
      wsSummary['!cols'] = [{ wch: 20 }, { wch: 15 }];
      (window as any).XLSX.utils.book_append_sheet(wb, wsSummary, '摘要報告');
      
      // 生成 xlsx 文件並下載
      const fileName = `力表_${new Date().toISOString().slice(0, 10)}.xlsx`;
      (window as any).XLSX.writeFile(wb, fileName);
      
      console.log('✅ 表格匯出成功');
      showAlert('表格匯出成功！', 'success', 2000);
      
    } catch (error) {
      console.error('❌ 匯出失敗:', error);
      showAlert(`匯出失敗: ${error.message}`, 'error', 3000);
    } finally {
      // 恢復按鈕狀態
      exportBtn.disabled = false;
      exportBtn.innerHTML = `
        <span>匯出表格</span>
        <div style="
          position: absolute;
          top: 0;
          left: -100%;
          width: 100%;
          height: 100%;
          background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
          transition: left 0.5s ease;
        "></div>
      `;
      exportBtn.style.background = 'linear-gradient(135deg, #28a745 0%, #20c997 100%)';
      exportBtn.style.transform = 'translateY(0) scale(1)';
      exportBtn.style.boxShadow = '0 8px 25px rgba(40, 167, 69, 0.4)';
    }
  }

