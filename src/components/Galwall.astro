---
import '../styles/galwall.css';
---
<div class="galwall-action-bar">
  <button id="galwall-refresh-btn" class="galwall-refresh-btn">
    <span class="icon">🔄</span> 刷新牆面
  </button>
</div>
<div id="galwallWrapper">
  <div id="containerFront"></div>
  <div id="containerBack"></div>
</div>

<script>
  import CharacterService from '../services/api/characterService';

  let frontList: string[] = [];
  let backList: string[] = [];
  const baseImagePath = import.meta.env.PUBLIC_PEOPLE_IMAGE_URL + "/";
  const characterService = CharacterService.getInstance();

  // 檢查圖片是否存在
  async function checkImageExists(imagePath) {
    try {
      const response = await fetch(imagePath, { method: 'HEAD' });
      return response.ok;
    } catch (error) {
      return false;
    }
  }

  // 獲取角色列表
  async function fetchCharacterNames() {
    try {
      const characters = await characterService.getCharacters();
      return characters.map(c => c.name);
    } catch (error) {
      console.error('❌ Galwall 獲取角色名稱列表失敗:', error);
      return [];
    }
  }

  // 檢查三種圖片類型
  async function checkImageTypes(characterName) {
    const timestamp = characterService.getMediaTimestamp();
    const normalPath = `${baseImagePath}${characterName}.png?t=${timestamp}`;
    const fightingPath = `${baseImagePath}${characterName}Fighting.png?t=${timestamp}`;
    const ruinedPath = `${baseImagePath}${characterName}Ruined.png?t=${timestamp}`;
    
    // 用帶有 timestamp 的 URL 去 check，確保 HEAD 也是最新的或是命中緩存
    const [normalExists, fightingExists, ruinedExists] = await Promise.all([
      checkImageExists(normalPath),
      checkImageExists(fightingPath),
      checkImageExists(ruinedPath)
    ]);
    
    return {
      name: characterName,
      normalPath: normalExists ? normalPath : null,
      fightingPath: fightingExists ? fightingPath : null,
      ruinedPath: ruinedExists ? ruinedPath : null
    };
  }

  async function initGalwall(isRefresh = false) {
    console.log('🚀 Galwall 組件初始化...');
    const containerFront = document.getElementById("containerFront");
    const containerBack = document.getElementById("containerBack");
    const refreshBtn = document.getElementById("galwall-refresh-btn") as HTMLButtonElement;

    if (!containerFront || !containerBack) return;

    if (isRefresh) {
      if (refreshBtn) {
        refreshBtn.disabled = true;
        refreshBtn.innerHTML = '<span class="icon">⌛</span> 刷新中...';
      }
      containerFront.innerHTML = '<div style="color:white;padding:20px;">更新中...</div>';
      containerBack.innerHTML = '';
      await characterService.refreshCharacters();
    }

    const characterNames = await fetchCharacterNames();
    const imageResults = await Promise.all(characterNames.map(name => checkImageTypes(name)));
    
    const validImages = imageResults.flatMap(result => {
      const paths: string[] = [];
      if (result.normalPath) paths.push(result.normalPath);
      if (result.fightingPath) paths.push(result.fightingPath);
      if (result.ruinedPath) paths.push(result.ruinedPath);
      return paths;
    });

    const totalImages = validImages.length;
    const frontCount = Math.ceil(totalImages / 3);
    
    frontList = validImages.slice(0, frontCount);
    backList = validImages.slice(frontCount);

    function createAdDiv(imageURL, isFront) {
      const adDiv = document.createElement("div");
      adDiv.className = isFront ? "ad-front" : "ad-back";
      const adImage = document.createElement("img");
      adImage.className = "ad-image";
      adImage.src = imageURL;
      adImage.style.height = "300px";
      adImage.style.width = "auto";
      adImage.style.objectFit = "contain";
      adImage.style.background = "transparent";
      
      adImage.onerror = () => adImage.style.display = 'none';
      adDiv.appendChild(adImage);
      return adDiv;
    }

    function loadAds(imageList, container, isFront) {
      container.innerHTML = "";
      imageList.forEach(url => {
        container.appendChild(createAdDiv(url, isFront));
      });
    }

    loadAds(frontList, containerFront, true);
    loadAds(backList, containerBack, false);

    containerFront.style.width = (300 * frontList.length) + "px";
    containerBack.style.width = (300 * backList.length) + "px";

    if (!(containerFront as any)._animationInit) {
      animateContainer(containerFront);
      (containerFront as any)._animationInit = true;
    }
    if (!(containerBack as any)._animationInit) {
      animateContainer(containerBack);
      (containerBack as any)._animationInit = true;
    }

    if (isRefresh && refreshBtn) {
      refreshBtn.disabled = false;
      refreshBtn.innerHTML = '<span class="icon">🔄</span> 刷新牆面';
    }
  }

  function animateContainer(container) {
    const SHUFFLE_INTERVAL = 40000;
    const doShuffle = () => {
      const items = Array.from(container.children) as HTMLElement[];
      if (items.length <= 1) return;
      const firstPositions = new Map<HTMLElement, number>();
      items.forEach(el => firstPositions.set(el, el.getBoundingClientRect().left));
      const shuffled = [...items].sort(() => Math.random() - 0.5);
      shuffled.forEach(el => container.appendChild(el));
      shuffled.forEach(el => {
        const lastX = el.getBoundingClientRect().left;
        const firstX = firstPositions.get(el) || lastX;
        const deltaX = firstX - lastX;
        el.style.transform = `translateX(${deltaX}px)`;
        el.style.transition = 'none';
      });
      requestAnimationFrame(() => {
        shuffled.forEach(el => {
          el.style.transition = 'transform 800ms ease';
          el.style.transform = 'translateX(0)';
          el.addEventListener('transitionend', () => {
            el.style.transition = '';
            el.style.transform = '';
          }, { once: true });
        });
      });
    };
    setInterval(doShuffle, SHUFFLE_INTERVAL);
  }

  document.addEventListener("DOMContentLoaded", async function () {
    initGalwall();
    const refreshBtn = document.getElementById("galwall-refresh-btn");
    if (refreshBtn) {
      refreshBtn.addEventListener('click', () => initGalwall(true));
    }
  });
</script>
</script> 