---
import { Icon } from "./Icon";
import { ThemeToggle } from "./ThemeToggle";
import type { iconPaths } from "./IconPaths";

// 鐛插彇 URL 鍙冩暩
const url = new URL(Astro.request.url);
const username = url.searchParams.get("username");
// #4: token / refresh_token 不再經 URL 傳遞（機密改由 localStorage + 後端強制）

// 檢查登入狀態（username 非機密，僅用於 SSR 顯示判斷）
const isLoggedIn = !!username;

// 鐛插彇鐣跺墠璺緫
const currentPath = Astro.url.pathname;

/** Main menu items */
const textLinks: {
  label: string;
  href: string;
  isActive: boolean;
  i18nKey: string;
  adminOnly?: boolean;
}[] = [
  {
    label: "Home",
    i18nKey: "nav.home",
    href: isLoggedIn
      ? `/tymultiverse/?username=${username}`
      : "/tymultiverse/",
    isActive:
      currentPath === "/tymultiverse/" ||
      currentPath === "/tymultiverse/index.html",
  },
  {
    label: isLoggedIn ? "Logout" : "Login",
    i18nKey: isLoggedIn ? "nav.logout" : "nav.login",
    href: isLoggedIn
      ? "#"
      : `/tymultiverse/login?redirect=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`,
    isActive: currentPath === "/tymultiverse/login",
  },
  {
    label: "Work",
    i18nKey: "nav.work",
    href: isLoggedIn
      ? `/tymultiverse/work/?username=${username}`
      : "/tymultiverse/work/",
    isActive: currentPath.startsWith("/tymultiverse/work"),
  },
  {
    label: "About",
    i18nKey: "nav.about",
    href: isLoggedIn
      ? `/tymultiverse/about/?username=${username}`
      : "/tymultiverse/about/",
    isActive: currentPath.startsWith("/tymultiverse/about"),
  },
  ...(isLoggedIn
    ? [
        {
          label: "Control",
          i18nKey: "nav.control",
          href: `/tymultiverse/control/?username=${username}`,
          isActive: currentPath.startsWith("/tymultiverse/control"),
        },
        {
          label: "Wildland",
          i18nKey: "nav.wildland",
          adminOnly: true,
          href: `/tymultiverse/wildland/?username=${username}`,
          isActive: currentPath.startsWith("/tymultiverse/wildland"),
        },
        {
          label: "Palais",
          i18nKey: "nav.palais",
          adminOnly: true,
          href: `/tymultiverse/palais/?username=${username}`,
          isActive: currentPath.startsWith("/tymultiverse/palais"),
        },
      ]
    : []),
];

const iconLinks: {
  label: string;
  href: string;
  icon: keyof typeof iconPaths;
  isActive: boolean;
}[] = [
  {
    label: "Twitter",
    href: "https://twitter.com/wawiking",
    icon: "twitter-logo",
    isActive: false,
  },
  {
    label: "GitHub",
    href: "https://github.com/Vinskao",
    icon: "github-logo",
    isActive: false,
  },
];
---

<nav>
  <div class="menu-header">
    <a
      href="/tymultiverse"
      class="site-title section-title is-inline"
      onclick="localStorage.removeItem('lastVisitedPath');"
    >
      <Icon
        icon="terminal-window"
        color="var(--accent-regular)"
        size="1.6em"
        gradient
      />
      TY Multiverse
    </a>
    <menu-button>
      <template>
        <button class="menu-button" aria-expanded="false">
          <span class="sr-only">Menu</span>
          <Icon icon="list" />
        </button>
      </template>
    </menu-button>
  </div>
  <noscript>
    <ul class="nav-items">
      {
        textLinks.map(({ label, href, isActive, i18nKey, adminOnly }) => (
          <li class:list={[{ "admin-only": adminOnly }]}>
            <a
              aria-current={isActive ? "page" : "false"}
              class:list={[
                "link",
                {
                  active: isActive,
                },
              ]}
              href={href}
              data-i18n={i18nKey}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </noscript>
  <noscript>
    <div class="menu-footer">
      <div class="socials">
        {
          iconLinks.map(({ href, icon, label }) => (
            <a href={href} class="social">
              <span class="sr-only">{label}</span>
              
              <Icon icon={icon} />
            </a>
          ))
        }
      </div>
      <div class="nav-controls-footer">
        <span class="noscript-note">JavaScript is disabled</span>
      </div>
    </div>
  </noscript>
  <div id="menu-content" hidden>
    <ul class="nav-items">
      {
        textLinks.map(({ label, href, isActive, i18nKey, adminOnly }) => (
          <li class:list={[{ "admin-only": adminOnly }]}>
            <a
              aria-current={isActive ? "page" : "false"}
              class:list={[
                "link",
                {
                  active: isActive,
                },
              ]}
              href={href}
              data-i18n={i18nKey}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="menu-footer">
      <div class="socials">
        {
          iconLinks.map(({ href, icon, label }) => (
            <a href={href} class="social">
              <span class="sr-only">{label}</span>
              <Icon icon={icon} />
            </a>
          ))
        }
      </div>
      <div class="nav-controls-footer">
        <button class="reset-website-btn lang-toggle-btn" data-i18n="home.resetWebsite">Reset Website</button>
        <button id="langToggleBtn" class="lang-toggle-btn" aria-label="Toggle language">EN</button>
        <ThemeToggle client:load />
      </div>
    </div>
  </div>
</nav>

<script>
  import i18nData from "../storages/i18n.json";

  let _langCleanup: (() => void) | null = null;

  /** 瑾炶█鍒囨彌鎸夐垥閭忚集 **/
  function initLangToggle() {
    const buttons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("#langToggleBtn, #langToggleBtn-noscript"),
    );
    if (buttons.length === 0) return;

    const translatePage = (code: string) => {
      // 缈昏甯舵湁 data-i18n 灞€х殑鍏冪礌
      document.querySelectorAll("[data-i18n]").forEach((el) => {
        const key = el.getAttribute("data-i18n");
        if (!key) return;
        
        const keys = key.split(".");
        let translation: any = i18nData;
        
        // 渚濈収 key 璺緫灏嬫壘缈昏锛屼緥濡?"nav.home"
        for (const k of keys) {
          if (translation && translation[k]) {
            translation = translation[k];
          } else {
            translation = null;
            break;
          }
        }
        
        // 鍐嶄緷鐓ц獮瑷€浠ｇ⒓鍙栧緱鏈€绲傛枃瀛?
        if (translation && translation[code]) {
          let text = translation[code];
          const count = el.getAttribute("data-i18n-count");
          if (count !== null) {
            text = text.replace("{count}", count);
          }
          el.textContent = text;
        }
      });
    };

    const updateBtn = (lang: string) => {
      buttons.forEach((button) => {
        button.textContent = lang === "zh" ? "\u4E2D\u6587" : "EN";
      });
    };

    buttons.forEach((btn) => {
      if (btn.dataset.langToggleBound === "true") return;
      btn.dataset.langToggleBound = "true";

      // Always-working click handler - no dependency on AppLang being ready at init time
      btn.addEventListener("click", () => {
        const AppLang = (window as any).AppLang;
        if (AppLang) {
          const next = AppLang.get() === "en" ? "zh" : "en";
          console.log("[LangToggle] click via AppLang -> toggling to:", next);
          AppLang.set(next);
        } else {
          const STORAGE_KEY = "site_language";
          const current = localStorage.getItem(STORAGE_KEY) || "en";
          const next = current === "en" ? "zh" : "en";
          localStorage.setItem(STORAGE_KEY, next);
          updateBtn(next);
          translatePage(next);
          console.warn("[LangToggle] AppLang not ready -> fallback toggled to:", next);
        }
      });
    });

    const setupHandlers = () => {
      const AppLang = (window as any).AppLang;
      if (!AppLang) return false;
      
      const current = AppLang.get();
      updateBtn(current);
      translatePage(current);
      
      if (_langCleanup) { _langCleanup(); _langCleanup = null; }
      _langCleanup = AppLang.onChange(({ code }: { code: string }) => {
        updateBtn(code);
        translatePage(code);
        console.log('[LangToggle] onChange fired, lang:', code);
      });
      
      console.log('[LangToggle] handlers set up, lang:', current);
      return true;
    };

    if (!setupHandlers()) {
      // Fallback init if AppLang is not ready yet
      const current = localStorage.getItem('site_language') || 'en';
      updateBtn(current);
      translatePage(current);
      
      console.warn('[LangToggle] AppLang not ready at init, scheduling retry...');
      setTimeout(() => {
        if (setupHandlers()) {
          console.log('[LangToggle] retry succeeded');
        } else {
          console.error('[LangToggle] AppLang still not available after retry');
        }
      }, 500);
    }
  }

  // 鏀彺 View Transitions
  initLangToggle();
  document.addEventListener("astro:page-load", initLangToggle);
</script>

<script>
  import { storageService } from "../services/core/storageService";

  // 灏?storageService 鎺涜級鍒?window 灏嶈薄涓?
  (window as any).storageService = storageService;

  class MenuButton extends HTMLElement {
    constructor() {
      super();
      this.appendChild(this.querySelector("template")!.content.cloneNode(true));
      const btn = this.querySelector("button")!;
      const menu = document.getElementById("menu-content")!;
      menu.hidden = true;
      menu.classList.add("menu-content");

      const setExpanded = (expand: boolean) => {
        btn.setAttribute("aria-expanded", expand ? "true" : "false");
        menu.hidden = !expand;
      };

      btn.addEventListener("click", () => setExpanded(menu.hidden));
      const handleViewports = (e: MediaQueryList | MediaQueryListEvent) => {
        setExpanded(e.matches);
        btn.hidden = e.matches;
      };
      const mediaQueries = window.matchMedia("(min-width: 50em)");
      handleViewports(mediaQueries);
      mediaQueries.addEventListener("change", handleViewports);
    }
  }

  if (!customElements.get("menu-button")) {
    customElements.define("menu-button", MenuButton);
  }
</script>

<script>
  import { initNav } from "../scripts/NavScript";

  // 鏀彺 View Transitions 鐨勫垵濮嬪寲
  initNav();
</script>

<script>
  // 鍌欑敤鐨勫師鐢?JavaScript 涓婚鍒囨彌鍔熻兘 - 鍍呭湪 React 姘村悎澶辨晽鏅傚暉鐢?
  function initThemeToggleFallback() {
    console.log("[ThemeToggle Fallback] Checking for React handlers...");

    const themeToggleContainer = document.querySelector(".theme-toggle");
    const themeToggleButton = themeToggleContainer?.querySelector("button");

    if (!themeToggleButton) return;
    if (themeToggleButton.dataset.fallbackBound === "true") return;

    // 妾㈡煡鎸夐垥鏄惁宸茬稉鐢?React 铏曠悊
    const hasReactHandlers = Object.keys(themeToggleButton).some(
      (key) => key.startsWith("__react") || key.startsWith("_react"),
    );

    if (hasReactHandlers) {
      console.log(
        "[ThemeToggle Fallback] React detected successfully, skipping fallback.",
      );
      return;
    }

    console.warn(
      "[ThemeToggle Fallback] No React detected, installing native listener.",
    );
    themeToggleButton.dataset.fallbackBound = "true";

    themeToggleButton.addEventListener(
      "click",
      (e) => {
        e.preventDefault();
        e.stopPropagation();
        const html = document.documentElement;
        const currentTheme = html.classList.contains("theme-dark")
          ? "dark"
          : "light";
        const newTheme = currentTheme === "dark" ? "light" : "dark";

        html.classList.remove("theme-light", "theme-dark");
        html.classList.add(`theme-${newTheme}`);
        localStorage.setItem("theme", newTheme);
        themeToggleButton.setAttribute(
          "aria-pressed",
          newTheme === "dark" ? "true" : "false",
        );
        console.log("[ThemeToggle Fallback] Toggled to", newTheme);
      },
      true,
    );
  }

  // 绲?React 涓€榛炴檪闁擄紙1.5s锛夐€茶姘村悎锛屽鏋滈倓涓嶈灏卞暉鍕曞倷妗?
  setTimeout(initThemeToggleFallback, 1500);
  document.addEventListener("astro:page-load", () =>
    setTimeout(initThemeToggleFallback, 1500),
  );
</script>

<script>
  function initResetBtn() {
    document.querySelectorAll('.reset-website-btn').forEach((btn) => {
      // Remove existing listener to avoid duplicates if view transitions are used
      const newBtn = btn.cloneNode(true);
      btn.parentNode?.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', async (e) => {
        const targetBtn = e.target as HTMLButtonElement;
        if (!targetBtn) return;
        
        const originalText = targetBtn.textContent;
        targetBtn.disabled = true;
        targetBtn.textContent = 'Resetting...';
        
        try {
          const { imageCacheService } = await import('../services/imageCacheService');
          const { thumbnailService } = await import('../services/thumbnailService');
          const { peopleService } = await import('../services/api/peopleService');
          const CharacterService = (await import('../services/api/characterService')).default;
          
          // Clear all caches
          await imageCacheService.clearCache();
          await thumbnailService.clearCache();
          CharacterService.getInstance().clearCache();
          CharacterService.getInstance().refreshMediaTimestamp();
          
          // Re-prefetch all images
          const names = await peopleService.getAllPeopleNames();
          const baseUrl = import.meta.env.PUBLIC_PEOPLE_IMAGE_URL;
          await imageCacheService.preloadImages(names, baseUrl);
          
          targetBtn.textContent = 'Done!';
          // Refresh page after a short delay to see changes
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } catch (error) {
          console.error('Reset failed:', error);
          targetBtn.textContent = 'Error!';
          setTimeout(() => {
            targetBtn.disabled = false;
            targetBtn.textContent = originalText;
          }, 2000);
        }
      });
    });
  }

  initResetBtn();
  document.addEventListener("astro:page-load", initResetBtn);
</script>

<style>
  .reset-website-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

