---
// 緩存管理組件
---

<div id="cache-manager" style="
  position: fixed;
  top: 20px;
  right: 20px;
  background: rgba(0, 0, 0, 0.8);
  color: white;
  padding: 15px;
  border-radius: 10px;
  font-size: 12px;
  z-index: 1000;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  min-width: 200px;
">
  <div style="margin-bottom: 10px; font-weight: bold;">📦 緩存狀態</div>
  <div id="cache-status">載入中...</div>
  <button id="clear-cache-btn" class="btn is-warning" style="
    margin-top: 10px;
    font-size: 11px;
  ">清除緩存</button>
  <button id="refresh-cache-btn" class="btn is-primary" style="
    margin-top: 5px;
    font-size: 11px;
    width: 100%;
  ">刷新數據</button>
</div>

<script>
  // 緩存管理功能
  async function updateCacheStatus() {
    try {
      const characterService = (await import('../services/api/characterService')).default.getInstance();
      const status = characterService.getCacheStatus();
      
      const statusElement = document.getElementById('cache-status');
      if (statusElement) {
        if (status.hasCache && status.expiryTime) {
          const remainingTime = Math.max(0, status.expiryTime - Date.now());
          const minutes = Math.floor(remainingTime / 60000);
          const seconds = Math.floor((remainingTime % 60000) / 1000);
          
          statusElement.innerHTML = `
            <div style="color: #2ed573;">✅ 已緩存</div>
            <div style="font-size: 10px; color: #ddd;">
              剩餘時間: ${minutes}:${seconds.toString().padStart(2, '0')}
            </div>
          `;
        } else {
          statusElement.innerHTML = `
            <div style="color: #ff4757;">❌ 無緩存</div>
            <div style="font-size: 10px; color: #ddd;">需要重新載入</div>
          `;
        }
      }
    } catch (error) {
      console.error('更新緩存狀態失敗:', error);
    }
  }

  // 清除緩存
  async function clearCache() {
    try {
      const characterService = (await import('../services/api/characterService')).default.getInstance();
      characterService.clearCache();
      
      // 顯示成功訊息
      const btn = document.getElementById('clear-cache-btn');
      if (btn) {
        const originalText = btn.textContent;
        btn.textContent = '✅ 已清除';
        btn.style.background = '#2ed573';
        
        setTimeout(() => {
          btn.textContent = originalText;
          btn.style.background = '#ff4757';
        }, 2000);
      }
      
      updateCacheStatus();
    } catch (error) {
      console.error('清除緩存失敗:', error);
    }
  }

  // 刷新數據
  async function refreshData() {
    try {
      const btn = document.getElementById('refresh-cache-btn') as HTMLButtonElement;
      if (btn) {
        btn.textContent = '🔄 刷新中...';
        btn.disabled = true;
      }
      
      const characterService = (await import('../services/api/characterService')).default.getInstance();
      await characterService.refreshCharacters();
      
      // 顯示成功訊息
      if (btn) {
        btn.textContent = '✅ 已刷新';
        btn.style.background = '#2ed573';
        
        setTimeout(() => {
          btn.textContent = '刷新數據';
          btn.style.background = '#2ed573';
          btn.disabled = false;
        }, 2000);
      }
      
      updateCacheStatus();
      
      // 重新載入頁面以更新所有組件
      setTimeout(() => {
        window.location.reload();
      }, 1000);
    } catch (error) {
      console.error('刷新數據失敗:', error);
      
      const btn = document.getElementById('refresh-cache-btn') as HTMLButtonElement;
      if (btn) {
        btn.textContent = '❌ 失敗';
        btn.style.background = '#ff4757';

        setTimeout(() => {
          btn.textContent = '刷新數據';
          btn.style.background = '#2ed573';
          btn.disabled = false;
        }, 2000);
      }
    }
  }

  // 初始化
  document.addEventListener('DOMContentLoaded', () => {
    // 更新初始狀態
    updateCacheStatus();
    
    // 每秒更新狀態
    setInterval(updateCacheStatus, 1000);
    
    // 綁定按鈕事件
    const clearBtn = document.getElementById('clear-cache-btn');
    const refreshBtn = document.getElementById('refresh-cache-btn');
    
    if (clearBtn) {
      clearBtn.addEventListener('click', clearCache);
    }
    
    if (refreshBtn) {
      refreshBtn.addEventListener('click', refreshData);
    }
  });
</script>
