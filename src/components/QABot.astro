    // 根據配置更新header controls狀態
    private updateHeaderControlsByConfig(mode: "v1" | "v2") {
      const config = qabotConfig.header_controls[mode];
      if (!config) return;

      // 更新各個控制項的狀態
      Object.entries(config).forEach(([key, controlConfig]: [string, any]) => {
        let element: HTMLElement | null = null;

        // 根據配置獲取元素
        if (controlConfig.element_id) {
          element = document.getElementById(controlConfig.element_id);
        } else if (controlConfig.element_selector) {
          element = document.querySelector(controlConfig.element_selector);
        }

        if (!element) return;

        // 更新元素狀態
        if (controlConfig.enabled) {
          // 啟用狀態
          element.classList.remove("v2-disabled");
          element.removeAttribute("disabled");
          if (element instanceof HTMLButtonElement) {
            element.disabled = false;
          }
        } else {
          // 禁用狀態
          element.classList.add("v2-disabled");
          if (element instanceof HTMLButtonElement) {
            element.disabled = true;
          }
        }

        // 更新title
        if (controlConfig.title) {
          element.title = controlConfig.title;
        }
      });
    }

