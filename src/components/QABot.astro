    // 安全地提取頁面內容
    private extractPageContentSafe(): { text: string; length: number } {
      console.log("開始提取頁面內容...");

      // 使用全局的頁面內容提取函數（如果可用）
      if (typeof (window as any).extractPageContent === "function") {
        try {
          const pageData = (window as any).extractPageContent();
          console.log(`使用全局提取函數，內容長度: ${pageData.length}`);
          console.log(`內容預覽: ${pageData.content.substring(0, 200)}...`);

          // 限制長度避免 token 超限
          const maxLength = 3000;
          const truncated =
            pageData.content.length > maxLength
              ? pageData.content.substring(0, maxLength) + "..."
              : pageData.content;

          console.log(`最終文字長度: ${truncated.length}`);
          return { text: truncated, length: truncated.length };
        } catch (error) {
          console.warn("全局提取函數失敗，使用備用方法:", error);
        }
      }

      // 備用提取方法
      console.log("使用備用內容提取方法...");

      // 嘗試多個內容選擇器，按優先級排序
      const contentSelectors = [
        '[data-page-type="content"]',
        '[data-page-type="main"]',
        '[data-page-type="article"]',
        "main",
        "article",
        ".content",
        ".main-content",
        "#content",
        "#main",
        ".post-content",
        ".entry-content",
      ];

      let contentElement: Element | null = null;

      // 尋找最佳內容元素
      for (const selector of contentSelectors) {
        const element = document.querySelector(selector);
        if (element) {
          const text =
            (element as HTMLElement).innerText || element.textContent || "";
          if (text.trim().length > 100) {
            // 確保有足夠內容
            contentElement = element;
            console.log(`找到內容元素: ${selector}, 長度: ${text.length}`);
            break;
          }
        }
      }

      // 如果沒有找到合適的內容元素，使用 body
      if (!contentElement) {
        contentElement = document.body;
        console.log("使用 document.body 作為內容元素");
      }

      // 創建臨時容器
      const tempDiv = document.createElement("div");
      tempDiv.innerHTML = contentElement.innerHTML;

      // 移除不需要的元素
      const elementsToRemove = [
        "script",
        "style",
        "nav",
        "footer",
        "aside",
        "header",
        '[aria-hidden="true"]',
        '[style*="display: none"]',
        '[style*="display:none"]',
        ".qa-bot-container",
        ".qa-bot-toggle", // 移除聊天機器人本身
        ".sidebar",
        ".side-nav",
        ".navigation",
        ".advertisement",
        ".ads",
        ".banner",
        ".social-share",
        ".share-buttons",
        ".comments",
        ".comment-section",
      ];

      elementsToRemove.forEach((selector) => {
        const elements = tempDiv.querySelectorAll(selector);
        elements.forEach((el) => el.remove());
      });

      // 提取純文字
      let text = tempDiv.innerText || tempDiv.textContent || "";
      text = text.replace(/\s+/g, " ").trim();

      console.log(`提取的原始文字長度: ${text.length}`);
      console.log(`提取的文字預覽: ${text.substring(0, 200)}...`);

      // 如果內容太少，嘗試從 body 提取更多內容
      if (text.length < 200 && contentElement !== document.body) {
        console.log("內容太少，嘗試從 body 提取更多內容");
        const bodyDiv = document.createElement("div");
        bodyDiv.innerHTML = document.body.innerHTML;

        // 移除不需要的元素
        elementsToRemove.forEach((selector) => {
          const elements = bodyDiv.querySelectorAll(selector);
          elements.forEach((el) => el.remove());
        });

        const bodyText = bodyDiv.innerText || bodyDiv.textContent || "";
        const cleanedBodyText = bodyText.replace(/\s+/g, " ").trim();

        if (cleanedBodyText.length > text.length) {
          text = cleanedBodyText;
          console.log(`使用 body 內容，新長度: ${text.length}`);
        }
      }

      // 限制長度避免 token 超限
      const maxLength = 3000;
      const truncated =
        text.length > maxLength ? text.substring(0, maxLength) + "..." : text;

      console.log(`最終文字長度: ${truncated.length}`);

      return { text: truncated, length: truncated.length };
    }

    // 檢測頁面語言
    private detectPageLanguage(): string {
      console.log("開始檢測頁面語言...");

      // 檢查 HTML lang 屬性
      const htmlLang = document.documentElement.lang;
      console.log(`HTML lang 屬性: ${htmlLang}`);

      // 檢查 meta 標籤
      const metaLang = document.querySelector(
        'meta[name="language"]',
      ) as HTMLMetaElement;
      console.log(`Meta language: ${metaLang?.content}`);

      // 優先使用 Unicode 檢測（更準確）
      const text = document.body.innerText || "";
      const chineseCharCount = (text.match(/[\u4e00-\u9fff]/g) || []).length;
      const totalCharCount = text.length;
      const chineseRatio =
        totalCharCount > 0 ? chineseCharCount / totalCharCount : 0;

      console.log(
        `總字符數: ${totalCharCount}, 中文字符數: ${chineseCharCount}, 中文比例: ${(chineseRatio * 100).toFixed(1)}%`,
      );

      // 如果中文比例超過 20%，就認為是中文頁面
      if (chineseRatio > 0.2) {
        console.log("檢測到中文頁面");
        return "chinese";
      }

      // 如果中文比例很低，檢查 HTML lang 屬性
      if (
        htmlLang &&
        (htmlLang.startsWith("zh") || htmlLang.startsWith("en"))
      ) {
        const detectedLang = htmlLang.startsWith("zh") ? "chinese" : "english";
        console.log(`根據 HTML lang 屬性檢測為: ${detectedLang}`);
        return detectedLang;
      }

      // 檢查 meta 標籤
      if (metaLang?.content) {
        const detectedLang = metaLang.content.startsWith("zh")
          ? "chinese"
          : "english";
        console.log(`根據 Meta 標籤檢測為: ${detectedLang}`);
        return detectedLang;
      }

      console.log("預設為英文頁面");
      return "english";
    }

    // 構建頁面分析請求參數
    private buildPageAnalysisPayload({
      text,
      length,
      type,
    }: {
      text: string;
      length: number;
      type: string;
    }) {
      const detectedLanguage = this.detectPageLanguage();

      return {
        text,
        analysis_type: `page_${type}`,
        content_length: length,
        user_id: this.state.userId,
        language: detectedLanguage,
        name: this.state.botName,
        frontend_source: "astro_page_analyzer",
        page_url: window.location.href,
        page_title: document.title,
      };
    }

    // 檢查快取
    private getAnalysisCache(
      type: string,
    ): { answer: string; timestamp: number } | null {
      const cacheKey = `page_analysis_${window.location.href}_${type}`;
      const cached = sessionStorage.getItem(cacheKey);
      if (!cached) return null;

      const data = JSON.parse(cached);
      const now = Date.now();
      const fiveMinutes = 5 * 60 * 1000;

      // 檢查是否在 5 分鐘內
      if (now - data.timestamp < fiveMinutes) {
        return data;
      }

      // 過期則清除
      sessionStorage.removeItem(cacheKey);
      return null;
    }

    // 儲存快取
    private setAnalysisCache(type: string, answer: string) {
      const cacheKey = `page_analysis_${window.location.href}_${type}`;
      const data = { answer, timestamp: Date.now() };
      sessionStorage.setItem(cacheKey, JSON.stringify(data));
    }

    // 渲染分析結果卡片
    private renderAnalysisCard(
      answer: string,
      analysisType: string,
      contentLength: number,
    ) {
      const currentLang = this.state.currentLanguage;
      const templates =
        analystTemplates[currentLang as keyof typeof analystTemplates];
      const labels = templates?.labels || {
        page_summary: "📄 頁面摘要",
        page_key_points: "🔍 重點提取",
        page_technical: "⚙️ 技術分析",
        page_qa: "❓ 問題生成",
      };
      const metadata = templates?.metadata || {
        content_length: "內容長度",
        source: "來源",
        reanalyze: "🔄 重新分析",
        copy_result: "📋 複製結果",
      };

      const typeLabels: Record<string, string> = {
        page_summary: labels.page_summary,
        page_key_points: labels.page_key_points,
        page_technical: labels.page_technical,
        page_qa: labels.page_qa,
      };

      const messageDiv = this.createMessageStructure(
        "bot",
        this.formatAnswer(answer),
      );
      const contentDiv = messageDiv.querySelector(
        ".message-content",
      ) as HTMLDivElement;

      // 添加分析卡片元數據
      const metadataDiv = document.createElement("div");
      metadataDiv.className = "analysis-metadata";
      metadataDiv.innerHTML = `
        <div class="analysis-info">
          <span class="analysis-type">${typeLabels[analysisType] || "頁面分析"}</span>
          <span class="content-length">${metadata.content_length || "內容長度"}: ${contentLength} ${currentLang === "english" ? "chars" : "字"}</span>
          <span class="page-url">${metadata.source || "來源"}: ${document.title}</span>
        </div>
        <div class="analysis-actions">
          <button class="reanalyze-btn" onclick="this.closest('.message').dispatchEvent(new CustomEvent('reanalyze'))">
            ${metadata.reanalyze || "🔄 重新分析"}
          </button>
          <button class="copy-btn" onclick="navigator.clipboard.writeText('${answer.replace(/'/g, "\\'")}')">
            ${metadata.copy_result || "📋 複製結果"}
          </button>
        </div>
      `;

      contentDiv.appendChild(metadataDiv);
      this.elements.chatMessages.appendChild(messageDiv);

      // 監聽重新分析事件
      messageDiv.addEventListener("reanalyze", () => {
        this.analyzePage(true); // 強制重新分析，忽略快取
      });

      this.scrollToBottom();
    }

    // 更新分析按鈕狀態
    private updateAnalysisButtonState() {
      const startBtn = document.querySelector(
        "#startPageAnalysis",
      ) as HTMLButtonElement;
      if (!startBtn) return;

      const currentLang = this.state.currentLanguage;
      const templates =
        analystTemplates[currentLang as keyof typeof analystTemplates];
      const ui = templates?.ui;

      if (this.state.isAnalyzing) {
        startBtn.disabled = true;
        startBtn.innerHTML = `<span class="spinner">⏳</span> ${ui?.analyzing || "分析中..."}`;
      } else {
        startBtn.disabled = false;
        startBtn.innerHTML = ui?.start_button || "📄 分析頁面";
      }
    }

    private async analyzePage(forceRefresh: boolean = false) {
      if (this.state.isAnalyzing) return;

      this.state.isAnalyzing = true;
      this.updateAnalysisButtonState();

      const loadingId = this.addLoadingMessage();

      try {
        // 檢查快取（除非強制重新分析）
        if (!forceRefresh) {
          const cached = this.getAnalysisCache(this.state.analysisType);
          if (cached) {
            this.removeMessage(loadingId);
            this.renderAnalysisCard(
              cached.answer,
              `page_${this.state.analysisType}`,
              0,
            );
            this.state.isAnalyzing = false;
            this.updateAnalysisButtonState();
            this.toggleAnalysisPanel(false);
            return;
          }
        }

        // 生成用戶提示消息
        const currentLang = this.state.currentLanguage;
        const templates =
          analystTemplates[currentLang as keyof typeof analystTemplates];
        const labels = templates?.labels || {
          page_summary: "📄 頁面摘要",
          page_key_points: "🔍 重點提取",
          page_technical: "⚙️ 技術分析",
          page_qa: "❓ 問題生成",
        };

        const typeLabels: Record<string, string> = {
          summary: labels.page_summary,
          key_points: labels.page_key_points,
          technical: labels.page_technical,
          qa: labels.page_qa,
        };

        const userPrompt =
          currentLang === "english"
            ? `Please ${typeLabels[this.state.analysisType] || "analyze the page"}`
            : `請${typeLabels[this.state.analysisType] || "分析頁面"}`;

        this.addMessage(userPrompt, "user");

        // 提取頁面內容
        const { text, length } = this.extractPageContentSafe();

        // 構建請求參數
        const payload = this.buildPageAnalysisPayload({
          text,
          length,
          type: this.state.analysisType,
        });

        // 調用 API
        const result = await this.callQAAPI(payload);
        this.removeMessage(loadingId);

        if (result.success) {
          const answer = result.text || result.answer || result;

          // 儲存快取
          this.setAnalysisCache(this.state.analysisType, answer);

          // 渲染結果
          this.renderAnalysisCard(
            answer,
            `page_${this.state.analysisType}`,
            length,
          );
        } else {
          this.addErrorMessage(result.error || "分析失敗，請稍後再試。");
        }
      } catch (err) {
        this.removeMessage(loadingId);
        this.addErrorMessage(`分析失敗：${(err as Error).message}`);
      } finally {
        this.state.isAnalyzing = false;
        this.updateAnalysisButtonState();
        this.toggleAnalysisPanel(false);
      }
    }
  }

  // 初始化QABot - 支援 View Transitions
  function initQABot() {
    // 確保舊實例不會干擾
    if ((window as any).qabotInstance) {
      if (typeof (window as any).qabotInstance.cleanup === "function") {
        (window as any).qabotInstance.cleanup();
      }
    }
    (window as any).qabotInstance = new QABot();
  }

  document.addEventListener("astro:page-load", initQABot);

  // 初次加載（如果尚未觸發 astro:page-load）
  if (document.readyState === "complete") {
    // initQABot(); // astro:page-load usually fires once even on first load
  }
</script>

