---
// QABot組件
import "../styles/qabot.css";
---

<!-- 已抽出共用 HTML 至 QAPlatform.astro -->
<script>
  // Global language manager
  // eslint-disable-next-line
  const __LANG_LOADED = (() => {
    try {
      if (!(window as any).AppLang) {
        const s = document.createElement("script");
        s.src = "/tymultiverse/scripts/lang.js";
        s.async = false;
        document.head.appendChild(s);
      }
    } catch (_) {}
  })();
  // 將訊息配置直接打包，避免正式環境 404
  // @ts-ignore
  import messages from "../storages/messages.json";
  // @ts-ignore
  import analystTemplates from "../storages/analyst.json";
  // @ts-ignore
  import qabotConfig from "../storages/qabot.json";
  import { thumbnailService } from "../services/thumbnailService";
  class QABot {
    // DOM 元素
    private elements: Record<string, HTMLElement> = {};

    // 狀態管理
    private state = {
      userId: "",
      currentHistoryPage: 0,
      historyItemsPerPage: 5,
      currentLanguage: "chinese",
      isFullscreen: false,
      isThinking: false,
      saucyMessageCount: 0,
      maxSaucyMessages: 3,
      lastSaucyMessage: "",
      hasShownInactivityMessage: false,
      currentTheme: "light",
      earliestTimestamp: null as number | null,
      botName: "Maya",
      availableBots: [] as string[],
      currentBotIndex: 0,
      // 新增：頁面分析相關狀態
      analysisType: "summary",
      isAnalyzing: false,
      hasShownLoginAlert: false,
    };

    // 定時器
    private timers = {
      inactivity: null as NodeJS.Timeout | null,
      randomMessage: null as NodeJS.Timeout | null,
    };

    // 消息配置
    private messages: any = null;

    constructor() {
      this.initializeElements();
      this.initializeState();
      this.initializeTheme();
      this.setupEventListeners();
      this.setupAvatarSelector(); // 新增頭貼選擇器
      this.setupNetworkListener(); // 新增網路狀態監聽
      this.fetchBotNames(); // 從 API 取得可用 bot 名稱
      // 新增：初始化頁面分析面板
      this.setupAnalysisPanel();
      this.loadMessages().then(() => {
        this.loadChatHistory();
        this.startTimers();
      });
    }

    // 初始化主題
    private initializeTheme() {
      // 檢測當前主題
      this.state.currentTheme = this.detectCurrentTheme();

      // 監聽主題變化
      this.setupThemeListener();
    }

    // 檢測當前主題
    private detectCurrentTheme(): string {
      const savedTheme = localStorage.getItem("theme");
      if (savedTheme) {
        return savedTheme;
      }

      // 檢查系統偏好
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        return "dark";
      }

      // 檢查 DOM 中的 theme-dark 類
      if (document.documentElement.classList.contains("theme-dark")) {
        return "dark";
      }

      return "light";
    }

    // 設置主題監聽器
    private setupThemeListener() {
      // 監聽 localStorage 變化
      window.addEventListener("storage", (e) => {
        if (e.key === "theme") {
          this.updateTheme(e.newValue || "light");
        }
      });

      // 監聽 DOM 變化（當其他組件改變主題時）
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (
            mutation.type === "attributes" &&
            mutation.attributeName === "class"
          ) {
            const target = mutation.target as HTMLElement;
            if (target === document.documentElement) {
              const newTheme = target.classList.contains("theme-dark")
                ? "dark"
                : "light";
              if (newTheme !== this.state.currentTheme) {
                this.updateTheme(newTheme);
              }
            }
          }
        });
      });

      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });

      // 監聽系統主題變化
      const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
      mediaQuery.addEventListener("change", (e) => {
        const newTheme = e.matches ? "dark" : "light";
        if (newTheme !== this.state.currentTheme) {
          this.updateTheme(newTheme);
        }
      });
    }

    // 設置網路狀態監聽器
    private setupNetworkListener() {
      let wasOffline = !navigator.onLine;

      // 監聽網路狀態變化
      window.addEventListener("online", () => {
        if (wasOffline) {
          console.log("網路已恢復，重新獲取AI專員列表");
          wasOffline = false;
          this.refreshBotList();
        }
      });

      window.addEventListener("offline", () => {
        wasOffline = true;
        console.log("網路已斷線");
      });
    }

    // 重新整理AI專員列表
    private async refreshBotList() {
      try {
        console.log("開始重新獲取AI專員列表...");

        // 顯示loading狀態
        this.showBotListLoading();

        await this.fetchBotNames();

        // 隱藏loading狀態
        this.hideBotListLoading();

        // 如果當前選擇的AI不在新列表中，自動切換到第一個可用的AI
        if (
          this.state.availableBots.length > 0 &&
          !this.state.availableBots.includes(this.state.botName)
        ) {
          console.log(
            `當前AI ${this.state.botName} 不在新列表中，切換到 ${this.state.availableBots[0]}`,
          );
          this.state.currentBotIndex = 0;
          this.state.botName = this.state.availableBots[0];
          this.updateAvatarAndName();

          // 顯示切換提示
          this.addBotSwitchMessage();

          // 延遲顯示新的歡迎消息
          setTimeout(() => {
            this.addWelcomeMessage();
          }, 1000);
        }

        console.log("AI專員列表更新完成");
      } catch (error) {
        console.error("重新獲取AI專員列表失敗:", error);
        this.hideBotListLoading();
      }
    }

    // 顯示AI專員列表載入中狀態
    private showBotListLoading() {
      // 在頭像選擇器中顯示loading狀態
      if (this.elements.avatarSelector) {
        this.elements.avatarSelector.innerHTML = `
          <div class="avatar-selector-loading">
            <div class="loading-spinner"></div>
            <p>正在重新連線中...</p>
          </div>
        `;
        this.elements.avatarSelector.style.display = "block";
      }
    }

    // 隱藏AI專員列表載入中狀態
    private hideBotListLoading() {
      if (this.elements.avatarSelector) {
        this.elements.avatarSelector.style.display = "none";
      }
    }

    // 更新主題
    private updateTheme(newTheme: string) {
      this.state.currentTheme = newTheme;

      // 這裡可以添加主題相關的邏輯
      // 例如更新按鈕樣式、重新渲染等
    }

    // 初始化 DOM 元素
    private initializeElements() {
      const elementIds = [
        "userInput",
        "sendButton",
        "chatMessages",
        "inputStatus",
        "qaBotToggle",
        "qaBotContainer",
        "closeButton",
        "historyButton",
        "loadMoreButton",
        "loadMoreContainer",
        "imageModal",
        "modalImage",
        "imageModalClose",
        // 新增：頁面分析相關元素
        "pageAnalysisButton",
        "analysisPanel",
      ];

      elementIds.forEach((id) => {
        this.elements[id] = document.getElementById(id) as HTMLElement;
      });

      // 另外取得頭貼元素
      this.elements.headerAvatar = document.querySelector(
        ".header-avatar",
      ) as HTMLElement;
    }

    // 初始化狀態
    private initializeState() {
      this.state.userId = this.getOrCreateUserId();
      // Initialize language from global AppLang
      this.state.currentLanguage = (window as any).AppLang
        ? (window as any).AppLang.getQALang()
        : localStorage.getItem("qabot_language") || "chinese";
      this.updateLanguageButton();
      this.updateInputPlaceholder();

      // Listen to global language changes
      if (
        (window as any).AppLang &&
        typeof (window as any).AppLang.onChange === "function"
      ) {
        (window as any).AppLang.onChange(({ qaLang }) => {
          if (qaLang && qaLang !== this.state.currentLanguage) {
            this.state.currentLanguage = qaLang;
            this.reinitializeChat();
            this.updateLanguageButton();
            this.updateInputPlaceholder();
          }
        });
      }
    }

    // 載入消息配置
    private async loadMessages() {
      // 不再透過 fetch，直接使用打包進來的 JSON
      this.messages = messages;
      // 移除沒有對應句庫的 bot
      this.pruneAvailableBots();
    }

    // 檢查指定角色是否有有效的 welcome 句
    private hasValidMessages(name: string): boolean {
      const zh = this.messages?.chinese?.[name];
      const en = this.messages?.english?.[name];
      return zh?.welcome?.length > 0 || en?.welcome?.length > 0;
    }

    private pruneAvailableBots() {
      if (!Array.isArray(this.state.availableBots)) return;

      const beforeFilter = [...this.state.availableBots];
      this.state.availableBots = this.state.availableBots.filter((n) => {
        const hasMessages = this.hasValidMessages(n);
        const hasThumbnail = thumbnailService.isThumbnailAvailable(n);
        return hasMessages && hasThumbnail;
      });

      // 確保至少 Maya 存在（如果她有句庫且有頭像的話）
      if (
        !this.state.availableBots.includes("Maya") &&
        this.hasValidMessages("Maya") &&
        thumbnailService.isThumbnailAvailable("Maya")
      ) {
        this.state.availableBots.unshift("Maya");
      }

      // 如果當前 bot 沒有句庫或沒有頭像 → 換成清單第一個
      const isCurrentValid = this.hasValidMessages(this.state.botName) && 
                            thumbnailService.isThumbnailAvailable(this.state.botName);
      
      if (!isCurrentValid && this.state.availableBots.length) {
        this.state.botName = this.state.availableBots[0];
        this.state.currentBotIndex = 0;
        this.updateAvatarAndNameAsync();
      }
    }

    // 取得所有可選 bot 名稱
    private async fetchBotNames() {
      try {
        // 使用統一的 peopleService
        const { peopleService } = await import("../services/api/peopleService");
        const names = await peopleService.getAllPeopleNames();

        if (Array.isArray(names)) {
          // 確保 Maya 在列表內
          if (!names.includes("Maya")) names.unshift("Maya");
          this.state.availableBots = names;

          // 開始預處理頭像（壓縮並緩存到瀏覽器）
          const baseUrl = import.meta.env.PUBLIC_PEOPLE_IMAGE_URL;
          thumbnailService.preLoadThumbnails(names, baseUrl).then(() => {
            // 預處理完成後再次過濾，確保無效頭像的人不會出現
            if (this.messages) this.pruneAvailableBots();
          });

          // 初始化後先過濾無句庫的
          if (this.messages) this.pruneAvailableBots();

          this.state.currentBotIndex = names.indexOf("Maya");
          return; // 成功後直接返回
        } else {
          // API 調用失敗，顯示 Sweet Alert 提示用戶先登入
          this.showLoginAlert();
          console.warn("❌ API回應錯誤: 無效的數據格式");
        }
      } catch (err) {
        // 網路錯誤，顯示 Sweet Alert 提示用戶先登入
        this.showLoginAlert();
        console.warn("❌ 網路錯誤:", err);
      }

      // 所有情況都失敗後，確保至少有一個預設的AI可用
      console.warn("使用預設AI");
      if (this.state.availableBots.length === 0) {
        this.state.availableBots = ["Maya"];
        this.state.currentBotIndex = 0;
      }
      this.updateAvatarAndNameAsync();
    }

    // 顯示登入提示
    private showLoginAlert() {
      // 檢查是否已經顯示過提示，避免重複顯示
      if (this.state.hasShownLoginAlert) {
        return;
      }

      this.state.hasShownLoginAlert = true;

      // 使用 SweetAlert2 顯示美觀的提示
      if (typeof (window as any).Swal !== "undefined") {
        (window as any).Swal.fire({
          title: "🔐 需要登入",
          html: `
            <div style="text-align: center; padding: 20px;">
              <div style="font-size: 48px; margin-bottom: 20px;">👋</div>
              <p style="font-size: 16px; color: #666; margin-bottom: 15px;">
                需要登入才能獲取完整的AI專員列表
              </p>
              <p style="font-size: 14px; color: #999;">
                登入後可以選擇更多AI助手進行對話
              </p>
            </div>
          `,
          icon: "info",
          confirmButtonText: "知道了",
          confirmButtonColor: "#3085d6",
          showCancelButton: true,
          cancelButtonText: "稍後再說",
          cancelButtonColor: "#6c757d",
          customClass: {
            popup: "swal-login-popup",
            title: "swal-login-title",
            htmlContainer: "swal-login-content",
          },
          background: "#fff",
          backdrop: "rgba(0,0,0,0.4)",
          allowOutsideClick: true,
          allowEscapeKey: true,
          width: "400px",
        });
      }
    }

    // 依目前 botName 更新 UI
    private updateAvatarAndName() {
      const avatarUrl = this.getAvatarUrl(this.state.botName);
      const defaultAvatarUrl = this.getDefaultAvatarUrl();

      // 更新 header 頭像
      const avatarEl = this.elements.headerAvatar as HTMLImageElement;
      if (avatarEl) {
        avatarEl.src = avatarUrl;
        avatarEl.alt = this.state.botName;
        avatarEl.onerror = () => {
          avatarEl.src = defaultAvatarUrl;
        };
      }

      // 更新 toggle 按鈕頭像
      const toggleImage = this.elements.qaBotToggle?.querySelector(
        ".toggle-image",
      ) as HTMLImageElement;
      if (toggleImage) {
        toggleImage.src = avatarUrl;
        toggleImage.alt = this.state.botName;
        toggleImage.onerror = () => {
          toggleImage.src = defaultAvatarUrl;
        };
      }

      // 更新 toggle 按鈕文字
      const toggleText = this.elements.qaBotToggle?.querySelector(
        ".toggle-text",
      ) as HTMLElement;
      if (toggleText) toggleText.textContent = this.state.botName;

      const headerName = avatarEl?.parentElement?.querySelector(
        ".header-text h3",
      ) as HTMLElement;
      if (headerName) headerName.textContent = this.state.botName;

      // 更新歡迎訊息頭像與名稱
      const welcomeAvatar = document.getElementById("welcomeMsgAvatar") as HTMLImageElement;
      if (welcomeAvatar) {
        welcomeAvatar.src = avatarUrl;
        welcomeAvatar.alt = this.state.botName;
        welcomeAvatar.onerror = () => { welcomeAvatar.src = defaultAvatarUrl; };
      }
      const welcomeName = document.getElementById("welcomeMsgName") as HTMLElement;
      if (welcomeName) welcomeName.textContent = this.state.botName;

      // 更新 loading 訊息頭像與名稱
      const loadingAvatar = document.getElementById("loadingMsgAvatar") as HTMLImageElement;
      if (loadingAvatar) {
        loadingAvatar.src = avatarUrl;
        loadingAvatar.alt = this.state.botName;
        loadingAvatar.onerror = () => { loadingAvatar.src = defaultAvatarUrl; };
      }
      const loadingName = document.getElementById("loadingMsgName") as HTMLElement;
      if (loadingName) loadingName.textContent = this.state.botName;
    }

    // 依目前 botName 更新 UI (非同步版本)
    private async updateAvatarAndNameAsync() {
      const originalUrl = this.getAvatarUrl(this.state.botName);
      const avatarUrl = await thumbnailService.getThumbnail(
        this.state.botName,
        originalUrl,
      );
      const defaultAvatarUrl = this.getDefaultAvatarUrl();

      // 更新 header 頭像
      const avatarEl = this.elements.headerAvatar as HTMLImageElement;
      if (avatarEl) {
        avatarEl.src = avatarUrl;
        avatarEl.alt = this.state.botName;
        avatarEl.onerror = () => {
          avatarEl.src = defaultAvatarUrl;
        };
      }

      // 更新 toggle 按鈕頭像
      const toggleImage = this.elements.qaBotToggle?.querySelector(
        ".toggle-image",
      ) as HTMLImageElement;
      if (toggleImage) {
        toggleImage.src = avatarUrl;
        toggleImage.alt = this.state.botName;
        toggleImage.onerror = () => {
          toggleImage.src = defaultAvatarUrl;
        };
      }

      // 更新 toggle 按鈕文字
      const toggleText = this.elements.qaBotToggle?.querySelector(
        ".toggle-text",
      ) as HTMLElement;
      if (toggleText) toggleText.textContent = this.state.botName;

      const headerName = avatarEl?.parentElement?.querySelector(
        ".header-text h3",
      ) as HTMLElement;
      if (headerName) headerName.textContent = this.state.botName;

      // 更新歡迎訊息頭像與名稱
      const welcomeAvatar = document.getElementById("welcomeMsgAvatar") as HTMLImageElement;
      if (welcomeAvatar) {
        welcomeAvatar.src = avatarUrl;
        welcomeAvatar.alt = this.state.botName;
        welcomeAvatar.onerror = () => { welcomeAvatar.src = defaultAvatarUrl; };
      }
      const welcomeName = document.getElementById("welcomeMsgName") as HTMLElement;
      if (welcomeName) welcomeName.textContent = this.state.botName;

      // 更新 loading 訊息頭像與名稱
      const loadingAvatar = document.getElementById("loadingMsgAvatar") as HTMLImageElement;
      if (loadingAvatar) {
        loadingAvatar.src = avatarUrl;
        loadingAvatar.alt = this.state.botName;
        loadingAvatar.onerror = () => { loadingAvatar.src = defaultAvatarUrl; };
      }
      const loadingName = document.getElementById("loadingMsgName") as HTMLElement;
      if (loadingName) loadingName.textContent = this.state.botName;
    }

    // 取得預設頭貼 URL
    private getDefaultAvatarUrl(): string {
      // 使用環境變數取得 PNG 圖片 URL
      return `${import.meta.env.PUBLIC_PEOPLE_IMAGE_URL}/default.png`;
    }

    // 建立頭貼選擇 UI 與事件
    private setupAvatarSelector() {
      const avatarEl = this.elements.headerAvatar as HTMLImageElement;
      if (!avatarEl) return;

      // 創建浮動頭像選擇面板
      const avatarSelector = document.createElement("div");
      avatarSelector.className = "avatar-selector";
      avatarSelector.style.display = "none";
      document.body.appendChild(avatarSelector);

      // 點擊頭像顯示選擇面板
      avatarEl.addEventListener("click", (e) => {
        e.stopPropagation();

        // 檢查是否在V2模式下
        if ((window as any).qabotMode === "v2") {
          const config = qabotConfig.header_controls.v2.avatar;
          if (config && !config.enabled && config.restriction_message) {
            this.showV2RestrictionMessage(config.restriction_message);
          }
          return;
        }

        this.showAvatarSelector(avatarSelector);
      });

      // 新增：header-text hover + click 切換到 V2
      const headerText = document.querySelector(
        ".chat-header .header-text",
      ) as HTMLElement;
      if (headerText) {
        headerText.style.cursor = "pointer";
        headerText.title = "切換到 Maya v2";
        headerText.addEventListener("mouseenter", () => {
          headerText.style.opacity = "0.85";
          headerText.style.textDecoration = "underline";
        });
        headerText.addEventListener("mouseleave", () => {
          headerText.style.opacity = "";
          headerText.style.textDecoration = "";
        });
        headerText.addEventListener("click", () => {
          const current = (window as any).qabotMode;
          const next = current === "v2" ? "v1" : "v2";
          (window as any).qabotMode = next;
          window.dispatchEvent(
            new CustomEvent("qabot:switch", { detail: { mode: next } }),
          );
        });
      }

      // 監聽全域模式切換，使用配置文件管理header controls狀態
      window.addEventListener("qabot:switch", (e: any) => {
        const mode = e?.detail?.mode;
        if (mode === "v1" || mode === "v2") {
          this.updateHeaderControlsByConfig(mode);
        }
      });

      // 點擊其他地方隱藏選擇面板
      document.addEventListener("click", (e) => {
        if (
          !avatarSelector.contains(e.target as Node) &&
          !avatarEl.contains(e.target as Node)
        ) {
          avatarSelector.style.display = "none";
        }
      });

      // 存到 elements 方便以後取用
      this.elements.avatarSelector = avatarSelector;
    }

    // 設置分析面板事件監聽器
    private setupAnalysisPanelEvents() {
      const panel = this.elements.analysisPanel as HTMLElement;
      if (!panel) {
        console.warn("分析面板元素不存在");
        return;
      }

      // 綁定分析類型按鈕事件
      const typeButtons = panel.querySelectorAll(".pa-type-btn");

      typeButtons.forEach((btn, index) => {
        btn.addEventListener("click", (e) => {
          const type =
            (e.currentTarget as HTMLElement).getAttribute("data-type") ||
            "summary";
          this.selectAnalysisType(type);
        });
      });

      // 綁定開始分析按鈕事件
      const startBtn = panel.querySelector(
        "#startPageAnalysis",
      ) as HTMLButtonElement;
      if (startBtn) {
        startBtn.addEventListener("click", () => {
          this.analyzePage();
        });
      } else {
        console.warn("未找到開始分析按鈕");
      }
    }

    // 顯示頭像選擇面板
    private showAvatarSelector(selector: HTMLElement) {
      // 清空現有內容
      selector.innerHTML = "";

      // 創建標題
      const title = document.createElement("h4");
      title.textContent = "在線專員";
      title.className = "avatar-selector-title";
      selector.appendChild(title);

      // 創建頭像網格
      const avatarGrid = document.createElement("div");
      avatarGrid.className = "avatar-grid";

      const defaultAvatarUrl = this.getDefaultAvatarUrl();

      // 過濾掉 default 角色和可能的無效角色
      const validBots = this.state.availableBots.filter(
        (botName) =>
          botName.toLowerCase() !== "default" &&
          botName.toLowerCase() !== "unknown" &&
          botName.trim() !== "" &&
          thumbnailService.isThumbnailAvailable(botName),
      );

      validBots.forEach((botName, index) => {
        const avatarItem = document.createElement("div");
        avatarItem.className = "avatar-item";
        if (botName === this.state.botName) {
          avatarItem.classList.add("active");
        }

        const avatarImg = document.createElement("img");
        const originalUrl = this.getAvatarUrl(botName);
        avatarImg.alt = botName;
        avatarImg.className = "avatar-selector-img";

        // 使用 thumbnail service
        thumbnailService
          .getThumbnail(botName, originalUrl)
          .then((thumbUrl) => {
            avatarImg.src = thumbUrl;
          })
          .catch(() => {
            avatarImg.src = originalUrl;
          });

        // 如果圖片載入失敗，隱藏整個選項
        avatarImg.onerror = () => {
          avatarItem.style.display = "none";
        };

        const avatarName = document.createElement("span");
        avatarName.textContent = botName;
        avatarName.className = "avatar-name";

        avatarItem.appendChild(avatarImg);
        avatarItem.appendChild(avatarName);

        // 點擊切換AI - 使用原始索引
        avatarItem.addEventListener("click", () => {
          const originalIndex = this.state.availableBots.indexOf(botName);
          this.selectBot(originalIndex);
          selector.style.display = "none";
        });

        avatarGrid.appendChild(avatarItem);
      });

      selector.appendChild(avatarGrid);

      // 顯示面板
      selector.style.display = "block";
    }

    // 選擇指定的bot
    private selectBot(index: number) {
      if (index >= 0 && index < this.state.availableBots.length) {
        this.state.currentBotIndex = index;
        this.state.botName = this.state.availableBots[index];
        this.updateAvatarAndNameAsync();

        // 立即清除對話歷史，避免頭像和對話不匹配
        this.elements.chatMessages.innerHTML = "";
        // 隱藏載入更多歷史按鈕
        if (this.elements.loadMoreContainer) {
          this.elements.loadMoreContainer.style.display = "none";
        }

        // 重置狀態
        this.state.lastSaucyMessage = "";
        this.state.hasShownInactivityMessage = false;
        this.state.isThinking = false;
        this.state.saucyMessageCount = 0;
        this.state.earliestTimestamp = null;

        // 顯示AI切換提示
        this.addBotSwitchMessage();

        // 延遲顯示新的歡迎消息，讓用戶看到切換提示
        setTimeout(() => {
          this.addWelcomeMessage();
        }, 1000);

        this.resetInactivityTimer();
        this.scrollToBottom();
      }
    }

    // 取得頭貼 URL
    private getAvatarUrl(name: string): string {
      // 使用位址 `${import.meta.env.PUBLIC_PEOPLE_IMAGE_URL}/${encodeURIComponent(name)}.png`
      return `${import.meta.env.PUBLIC_PEOPLE_IMAGE_URL}/${encodeURIComponent(name)}.png`;
    }

    // 設置事件監聽器
    private setupEventListeners() {
      // 基本控制事件
      this.elements.qaBotToggle.addEventListener("click", () =>
        this.toggleChat(),
      );
      // 監聽從外部切換 v1/v2
      window.addEventListener("qabot:switch", (e: any) => {
        const mode = e?.detail?.mode;
        const container = this.elements.qaBotContainer;
        const headerNameEl = container?.querySelector(
          ".header-text h3",
        ) as HTMLElement | null;
        const inputEl = this.elements.userInput as HTMLInputElement;
        if (mode === "v2") {
          // 確保 v1 視窗可見
          if (container && !container.classList.contains("show")) {
            container.classList.add("show");
          }
          // 顯示 Maya v2 名稱
          if (headerNameEl) headerNameEl.textContent = "Maya v2";
          // 調整輸入框提示
          if (inputEl) inputEl.placeholder = "問 Maya v2...";
        } else if (mode === "v1") {
          // 還原成目前 bot 名稱
          if (headerNameEl) headerNameEl.textContent = this.state.botName;
          // 還原輸入框提示
          this.updateInputPlaceholder();
          // 顯示 v1 面板
          if (container && !container.classList.contains("show")) {
            container.classList.add("show");
          }
        }
      });
      this.elements.closeButton.addEventListener("click", () =>
        this.hideChat(),
      );
      this.elements.historyButton.addEventListener("click", () =>
        this.loadChatHistory(),
      );
      this.elements.loadMoreButton.addEventListener("click", () =>
        this.loadMoreHistory(),
      );
      // 新增：頁面分析按鈕事件
      this.elements.pageAnalysisButton.addEventListener("click", () => {
        // 檢查是否在V2模式下
        if ((window as any).qabotMode === "v2") {
          const config = qabotConfig.header_controls.v2.page_analysis;
          if (config && !config.enabled && config.restriction_message) {
            this.showV2RestrictionMessage(config.restriction_message);
          }
          return;
        }
        this.toggleAnalysisPanel();
      });

      // 新增：頁面分析面板事件（延遲綁定，確保面板已創建）
      setTimeout(() => {
        this.setupAnalysisPanelEvents();
      }, 100);

      // 功能按鈕事件
      (
        document.getElementById("fullscreenButton") as HTMLButtonElement
      ).addEventListener("click", () => this.toggleFullscreen());
      (
        document.getElementById("languageButton") as HTMLButtonElement
      ).addEventListener("click", () => {
        // 檢查是否在V2模式下
        if ((window as any).qabotMode === "v2") {
          const config = qabotConfig.header_controls.v2.language;
          if (config && !config.enabled && config.restriction_message) {
            this.showV2RestrictionMessage(config.restriction_message);
          }
          return;
        }
        this.toggleLanguage();
      });

      // 輸入相關事件
      this.elements.userInput.addEventListener("input", () => {
        this.updateSendButton();
        this.resetInactivityTimer();
      });

      this.elements.userInput.addEventListener("keypress", (e) => {
        if (e.key === "Enter" && !e.shiftKey) {
          e.preventDefault();
          if ((window as any).qabotMode === "v2") return; // 交由 v2 處理
          this.sendMessage();
        }
        this.resetInactivityTimer();
      });

      this.elements.sendButton.addEventListener("click", () => {
        if ((window as any).qabotMode === "v2") return; // 交由 v2 處理
        this.sendMessage();
        this.resetInactivityTimer();
      });

      // 主題建議事件
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target?.classList.contains("suggestion-btn")) {
          const topic = target.getAttribute("data-topic");
          if (topic) {
            this.handleTopicSuggestion(topic);
          }
        }
      });

      // 圖片模態框事件
      this.elements.imageModalClose.addEventListener("click", (e) => {
        e.stopPropagation();
        this.hideImageModal();
      });

      this.elements.imageModal.addEventListener("click", (e) => {
        if (e.target === this.elements.imageModal) this.hideImageModal();
      });

      // 圖片點擊事件
      this.elements.chatMessages.addEventListener("click", (e) => {
        const img = (e.target as HTMLElement).closest(
          ".answer-image",
        ) as HTMLImageElement;
        if (img) {
          const imageSrc = img.getAttribute("data-src") || img.src;
          this.showImageModal(imageSrc);
        }
      });

      // ESC 鍵關閉模態框
      document.addEventListener("keydown", (e) => {
        if (
          e.key === "Escape" &&
          this.elements.imageModal.classList.contains("show")
        ) {
          this.hideImageModal();
        }
      });

      // 監聽全域模式切換事件
      window.addEventListener("qabot:switch", (e: any) => {
        const mode = e?.detail?.mode;
        const headerText = document.querySelector(
          ".header-text",
        ) as HTMLElement;
        const input = document.getElementById("userInput") as HTMLInputElement;

        if (mode === "v2") {
          // 切換到 v2 模式
          if (headerText) {
            headerText.setAttribute("data-tooltip", "切換至 v1 模式");
          }
          if (input) {
            input.placeholder = "問我任何問題... (v2)";
          }
        } else if (mode === "v1") {
          // 切換到 v1 模式
          if (headerText) {
            headerText.setAttribute("data-tooltip", "切換至 v2 模式");
          }
          if (input) {
            input.placeholder = "問我任何問題...";
          }
        }
      });

      // 初始化 tooltip
      const headerText = document.querySelector(".header-text") as HTMLElement;
      if (headerText) {
        headerText.setAttribute("data-tooltip", "切換至 v2 模式");
      }
    }

    // 創建消息結構的通用方法
    private createMessageStructure(
      type: "bot" | "user" | "loading" = "bot",
      content?: any,
    ) {
      const messageDiv = document.createElement("div");
      messageDiv.className = `message ${type}-message`;

      if (type === "bot" || type === "loading") {
        // 添加頭像
        const avatarDiv = document.createElement("div");
        avatarDiv.className = "message-avatar";
        const avatarImg = document.createElement("img");
        const originalUrl = this.getAvatarUrl(this.state.botName);
        avatarImg.alt = this.state.botName;
        avatarImg.className = "bot-avatar";

        // 使用 thumbnail service
        thumbnailService
          .getThumbnail(this.state.botName, originalUrl)
          .then((thumbUrl) => {
            avatarImg.src = thumbUrl;
          })
          .catch(() => {
            avatarImg.src = originalUrl;
          });

        avatarImg.onerror = () => {
          avatarImg.src = this.getDefaultAvatarUrl();
        };
        avatarDiv.appendChild(avatarImg);
        messageDiv.appendChild(avatarDiv);

        // 添加內容包裝器
        const contentWrapper = document.createElement("div");
        contentWrapper.className = "message-content-wrapper";

        // 添加消息頭部
        const headerDiv = document.createElement("div");
        headerDiv.className = "message-header";
        const aiName = document.createElement("span");
        aiName.className = "ai-name";
        aiName.textContent = this.state.botName;
        headerDiv.appendChild(aiName);
        contentWrapper.appendChild(headerDiv);

        const contentDiv = document.createElement("div");
        contentDiv.className = "message-content";

        if (type === "loading") {
          contentDiv.innerHTML = `
            <div class="loading">
              <div class="spinner"></div>
              <span>正在思考中...</span>
            </div>
          `;
        } else if (content) {
          // 確保 content 是字符串類型
          if (typeof content !== "string") {
            content = String(content || "");
          }
          contentDiv.innerHTML = content;
        }

        contentWrapper.appendChild(contentDiv);
        messageDiv.appendChild(contentWrapper);
      } else if (type === "user" && content) {
        // 用戶消息
        const headerDiv = document.createElement("div");
        headerDiv.className = "message-header";
        const userId = document.createElement("span");
        userId.className = "user-id";
        userId.textContent = `ID: ${this.state.userId.substring(0, 8)}...`;
        headerDiv.appendChild(userId);
        messageDiv.appendChild(headerDiv);

        const contentDiv = document.createElement("div");
        contentDiv.className = "message-content";
        // 確保 content 是字符串類型
        if (typeof content !== "string") {
          content = String(content || "");
        }
        contentDiv.innerHTML = `<p>${this.escapeHtml(content)}</p>`;
        messageDiv.appendChild(contentDiv);
      }

      return messageDiv;
    }

    // 添加消息到聊天區域
    private addMessage(content: any, type: "bot" | "user" | "loading" = "bot") {
      // 確保 content 是字符串類型
      if (typeof content !== "string") {
        console.warn("addMessage: content is not a string:", content);
        content = String(content || "");
      }

      const messageDiv = this.createMessageStructure(type, content);
      this.elements.chatMessages.appendChild(messageDiv);
      this.scrollToBottom();
      return messageDiv;
    }

    // 添加載入消息
    private addLoadingMessage() {
      this.state.isThinking = true;
      const loadingDiv = this.createMessageStructure("loading");
      this.elements.chatMessages.appendChild(loadingDiv);
      this.scrollToBottom();
      return loadingDiv;
    }

    // 添加歡迎消息
    private addWelcomeMessage() {
      // 先顯示 loading 效果
      const loadingDiv = this.createMessageStructure("loading");
      this.elements.chatMessages.appendChild(loadingDiv);
      this.scrollToBottom();

      // 延遲 1.5 秒後顯示實際的歡迎消息
      setTimeout(() => {
        this.removeMessage(loadingDiv);

        const langData = this.messages?.[this.state.currentLanguage];
        const currentMessages =
          langData?.[this.state.botName] || langData?.["Maya"];
        const randomWelcome =
          currentMessages.welcome[
            Math.floor(Math.random() * currentMessages.welcome.length)
          ];

        const messageDiv = this.createMessageStructure(
          "bot",
          `<p>${randomWelcome}</p>`,
        );

        // 添加主題建議
        const contentDiv = messageDiv.querySelector(
          ".message-content",
        ) as HTMLDivElement;
        const topicSuggestions = document.createElement("div");
        topicSuggestions.className = "topic-suggestions";

        const suggestionsTitle = document.createElement("h4");
        suggestionsTitle.textContent =
          this.state.currentLanguage === "chinese"
            ? "💡 建議主題："
            : "💡 Suggested Topics:";
        topicSuggestions.appendChild(suggestionsTitle);

        const suggestionButtons = document.createElement("div");
        suggestionButtons.className = "suggestion-buttons";

        const topics =
          this.state.currentLanguage === "chinese"
            ? [
                { key: "Java", text: "☕ Java 開發" },
                { key: "OOP及DI框架", text: "🏗️ OOP及DI框架" },
                { key: "部署實踐", text: "🚀 部署實踐" },
                { key: "redis 及 mq 的差異", text: "🗄️ Redis 與 MQ 的差異" },
                {
                  key: "了解妳",
                  text:
                    this.state.botName === "Wavo" ? "想多了解你" : "想多了解妳",
                },
              ]
            : [
                { key: "Java", text: "☕ Java Development" },
                { key: "OOP及DI框架", text: "🏗️ OOP & DI Frameworks" },
                { key: "部署實踐", text: "🚀 Deployment Practices" },
                {
                  key: "redis 及 mq 的差異",
                  text: "🗄️ Redis & MQ Differences",
                },
                { key: "了解妳", text: "Learn More About Maya" },
              ];

        topics.forEach((topic) => {
          const button = document.createElement("button");
          button.className = "suggestion-btn";
          button.setAttribute("data-topic", topic.key);
          button.textContent = topic.text;
          suggestionButtons.appendChild(button);
        });

        topicSuggestions.appendChild(suggestionButtons);
        contentDiv.appendChild(topicSuggestions);

        this.elements.chatMessages.appendChild(messageDiv);
        this.scrollToBottom();
      }, 1500);
    }

    // 添加AI切換提示消息
    private addBotSwitchMessage() {
      const switchMessage =
        this.state.currentLanguage === "chinese"
          ? `🔄 已切換到 ${this.state.botName}`
          : `🔄 Switched to ${this.state.botName}`;

      const messageDiv = this.createMessageStructure(
        "bot",
        `<p class="bot-switch-message">${switchMessage}</p>`,
      );
      this.elements.chatMessages.appendChild(messageDiv);
      this.scrollToBottom();

      // 3秒後自動移除切換提示
      setTimeout(() => {
        if (messageDiv.parentNode) {
          messageDiv.parentNode.removeChild(messageDiv);
        }
      }, 3000);
    }

    // 處理主題建議
    private handleTopicSuggestion(topic: string) {
      if (!this.messages) {
        console.error("消息配置未載入");
        return;
      }

      const langData = this.messages?.[this.state.currentLanguage];
      const topicsData = langData?.topics;
      if (!topicsData) {
        console.error("當前語言消息或topics不存在");
        return;
      }
      const suggestion = (topicsData as any)[topic];

      if (suggestion) {
        (this.elements.userInput as HTMLInputElement).value = suggestion;
        this.updateSendButton();
        (this.elements.userInput as HTMLInputElement).focus();
      } else {
        // 嘗試使用備用文本
        const fallbackText = `請告訴我關於 ${topic} 的知識`;
        (this.elements.userInput as HTMLInputElement).value = fallbackText;
        this.updateSendButton();
        (this.elements.userInput as HTMLInputElement).focus();
      }
    }

    // 格式化答案
    private formatAnswer(answer: string): string {
      let formattedAnswer = answer;

      // 處理特殊格式
      formattedAnswer = formattedAnswer.replace(
        /「([^」]+)」/g,
        "<strong>「$1」</strong>",
      );
      formattedAnswer = formattedAnswer.replace(
        /(吉国\s*[小千秋][百秋])(?![^<]*\.png)/g,
        "<strong>$1</strong>",
      );
      formattedAnswer = formattedAnswer.replace(
        /(森築\s*空音)(?![^<]*\.png)/g,
        "<strong>$1</strong>",
      );
      formattedAnswer = formattedAnswer.replace(
        /(Sayuri|Chiaki|Sorane)(?![^<]*\.png)/g,
        "<strong>$1</strong>",
      );

      // 處理圖片連結
      formattedAnswer = formattedAnswer.replace(
        /圖片連結：\s*\n((?:- [^\n]+\n?)+)/gi,
        (match, imageList) => {
          const imageUrls =
            imageList.match(/https?:\/\/[^\n]+\.(?:png|jpg|jpeg|gif|webp)/gi) ||
            [];
          return `<div class="image-container-wrapper">${imageUrls
            .map(
              (url) =>
                `<div class="image-container"><img src="${url}" alt="圖片" class="answer-image" data-src="${url}" onerror="this.style.display='none'" loading="lazy" width="260" style="max-width:260px;height:auto;" /></div>`,
            )
            .join("")}</div>`;
        },
      );

      formattedAnswer = formattedAnswer.replace(
        /圖片連結：\s*(https?:\/\/[^\n]+\.(?:png|jpg|jpeg|gif|webp))/gi,
        '<div class="image-container"><img src="$1" alt="圖片" class="answer-image" data-src="$1" onerror="this.style.display=\'none\'" loading="lazy" width="260" style="max-width:260px;height:auto;" /></div>',
      );

      // 將純圖片連結也轉成 <img>，隱藏原始網址
      formattedAnswer = formattedAnswer.replace(
        /(?<!src=")https?:\/\/[^\s<]+\.(?:png|jpg|jpeg|gif|webp)(?=[\s]|$)/gi,
        (url) => {
          return `<div class="image-container"><img src="${url}" alt="圖片" class="answer-image" data-src="${url}" onerror="this.style.display='none'" loading="lazy" width="260" style="max-width:260px;height:auto;" /></div>`;
        },
      );

      // 處理換行
      formattedAnswer = formattedAnswer
        .replace(/\n\n/g, "</p><p>")
        .replace(/\n/g, "<br>");
      return `<p>${formattedAnswer}</p>`;
    }

    // 添加機器人回應
    private addBotResponse(answer: any, sources: any[]) {
      this.state.isThinking = false;

      // 處理 answer 可能是對象的情況
      let answerText = "";
      if (typeof answer === "object" && answer !== null) {
        // 如果是對象，嘗試提取 text 字段
        if (answer.text) {
          answerText = answer.text;
        } else if (answer.answer) {
          answerText = answer.answer;
        } else if (answer.response) {
          answerText = answer.response;
        } else {
          // 如果沒有找到預期的字段，將整個對象轉換為字符串
          answerText = JSON.stringify(answer);
        }
      } else if (typeof answer === "string") {
        answerText = answer;
      } else {
        answerText = String(answer || "");
      }

      const messageDiv = this.createMessageStructure(
        "bot",
        this.formatAnswer(answerText),
      );
      const contentDiv = messageDiv.querySelector(
        ".message-content",
      ) as HTMLDivElement;

      // 添加來源列表（僅在存在有效來源時）
      if (sources && Array.isArray(sources) && sources.length > 0) {
        const sourcesDiv = document.createElement("div");
        sourcesDiv.className = "sources-list";

        let hasValidSource = false;

        sources.forEach((source) => {
          // 取得檔案路徑（可能欄位名稱不同）
          const filePath = (source &&
            (source.file_path || source.path || source.file)) as
            | string
            | undefined;
          if (!filePath) return; // 無效來源直接跳過

          // 第一次取得有效來源時，插入標題
          if (!hasValidSource) {
            const sourcesTitle = document.createElement("h4");
            sourcesTitle.textContent = "📚 參考文檔：";
            sourcesDiv.appendChild(sourcesTitle);
            hasValidSource = true;
          }

          const sourceItem = document.createElement("div");
          sourceItem.className = "source-item";

          const link = document.createElement("a");
          link.href = `/tymultiverse/work/${filePath.replace(".md", "")}`;
          link.target = "_blank";
          link.className = "source-link";
          link.innerHTML = `📄 ${this.escapeHtml(filePath)}`;

          // 顯示相似度（若有）
          if (source && typeof source.similarity === "number") {
            const similaritySpan = document.createElement("span");
            similaritySpan.className = "similarity";
            similaritySpan.textContent = `相關度: ${(source.similarity * 100).toFixed(1)}%`;
            sourceItem.appendChild(similaritySpan);
          }

          sourceItem.appendChild(link);
          sourcesDiv.appendChild(sourceItem);
        });

        // 只有在確定有至少一個有效來源時才加入內容
        if (hasValidSource) {
          contentDiv.appendChild(sourcesDiv);
        }
      }

      this.elements.chatMessages.appendChild(messageDiv);
      this.scrollToBottom();

      // AI回答完成後，重新開始催促計時
      this.resetInactivityTimer();
    }

    // 添加錯誤消息
    private addErrorMessage(message: string) {
      this.state.isThinking = false;
      const messageDiv = this.createMessageStructure(
        "bot",
        `<p class="error-message">❌ ${this.escapeHtml(message)}</p>`,
      );
      this.elements.chatMessages.appendChild(messageDiv);
      this.scrollToBottom();
    }

    // 發送消息
    private async sendMessage() {
      const userText = (
        this.elements.userInput as HTMLInputElement
      ).value.trim();
      if (!userText) return;

      (this.elements.userInput as HTMLInputElement).value = "";
      this.updateSendButton();
      this.elements.inputStatus.textContent = "";

      this.addMessage(userText, "user");
      const loadingId = this.addLoadingMessage();

      try {
        const response = await this.callQAAPI(userText);
        this.removeMessage(loadingId);

        // console.log('API響應:', response);

        if (response.success) {
          // 根據API響應結構，使用 response.text 或 response.answer
          const answer = response.text || response.answer || response;
          const sources = response.data || response.sources || [];
          // console.log('提取的答案:', answer);
          // console.log('提取的來源:', sources);
          this.addBotResponse(answer, sources);
        } else {
          this.addErrorMessage("抱歉，無法獲取答案，請稍後再試。");
        }
      } catch (error) {
        console.error("API調用錯誤:", error);
        this.removeMessage(loadingId);
        this.addErrorMessage("網絡錯誤，請檢查連接後重試。");
      }
    }

    // 調用 QA API
    private async callQAAPI(payload: string | object) {
      const apiBaseUrl = import.meta.env.DEV
        ? ""
        : import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:8000";
      const apiPathPrefix = "/maya-sawa";

      // 如果是字符串，構建基本 payload
      const finalPayload =
        typeof payload === "string"
          ? {
              text: payload,
              user_id: this.state.userId,
              language: this.state.currentLanguage,
              name: this.state.botName,
            }
          : payload;

      // 調試日誌：確認送出的請求內容
      console.log("callQAAPI payload =>", finalPayload);

      const token = localStorage.getItem("token");
      const headers: Record<string, string> = {
        "Content-Type": "application/json",
      };

      if (token) {
        headers["Authorization"] = `Bearer ${token}`;
      }

      const response = await fetch(`${apiBaseUrl}${apiPathPrefix}/qa/query`, {
        method: "POST",
        headers,
        body: JSON.stringify(finalPayload),
        credentials: "include",
      });

      if (!response.ok)
        throw new Error(`HTTP error! status: ${response.status}`);

      const result = await response.json();

      // 調試日誌：查看 API 回傳
      // console.log('callQAAPI response =>', result);

      return result;
    }

    // 載入聊天歷史
    private async loadChatHistory() {
      try {
        const apiBaseUrl = import.meta.env.DEV
          ? ""
          : import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:8000";
        const apiPathPrefix = "/maya-sawa";

        const token = localStorage.getItem("token");
        const headers: Record<string, string> = {
          "Content-Type": "application/json",
        };

        if (token) {
          headers["Authorization"] = `Bearer ${token}`;
        }

        const response = await fetch(
          `${apiBaseUrl}${apiPathPrefix}/qa/chat-history/${this.state.userId}`,
          {
            headers,
            credentials: "include",
          },
        );
        if (!response.ok)
          throw new Error(`HTTP error! status: ${response.status}`);

        const result = await response.json();

        // 清除現有對話
        this.elements.chatMessages.innerHTML = "";

        // 顯示歡迎消息
        this.addWelcomeMessage();

        if (result.success && result.history && result.history.length > 0) {
          // 依照時間升序排列，確保顯示順序正確
          const sortedHistory = [...result.history].sort((a, b) => {
            const aTime = new Date(
              a.created_at || a.timestamp || a.time || 0,
            ).getTime();
            const bTime = new Date(
              b.created_at || b.timestamp || b.time || 0,
            ).getTime();
            return aTime - bTime;
          });

          // 只顯示最近10分鐘內的對話（與Redis TTL保持一致）
          const tenMinutesAgo = Date.now() - 10 * 60 * 1000;
          const recentHistory = sortedHistory.filter((item) => {
            const itemTime = new Date(
              item.created_at || item.timestamp || item.time || 0,
            ).getTime();
            return itemTime > tenMinutesAgo;
          });

          if (recentHistory.length > 0) {
            const total = recentHistory.length;
            this.state.currentHistoryPage = 0; // 0 = latest page
            const startIdx = Math.max(
              0,
              total - this.state.historyItemsPerPage,
            );
            const historyToShow = recentHistory.slice(startIdx, total);

            historyToShow.forEach((item) => {
              this.addHistoryMessage(
                item.user_message,
                item.ai_answer,
                item.reference_data || [],
              );
            });

            // 記錄目前最早的訊息時間
            if (historyToShow.length > 0) {
              const firstItem = historyToShow[0];
              this.state.earliestTimestamp = new Date(
                firstItem.created_at ||
                  firstItem.timestamp ||
                  firstItem.time ||
                  0,
              ).getTime();
            } else {
              this.state.earliestTimestamp = null;
            }
          }
        }
      } catch (error) {
        console.error("載入聊天歷史失敗:", error);
        this.addErrorMessage("❌ 載入聊天歷史失敗，請稍後再試");
      }
    }

    // 載入更多歷史記錄
    private async loadMoreHistory() {
      try {
        const apiBaseUrl = import.meta.env.DEV
          ? ""
          : import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:8000";
        const apiPathPrefix = "/maya-sawa";

        const token = localStorage.getItem("token");
        const headers: Record<string, string> = {
          "Content-Type": "application/json",
        };

        if (token) {
          headers["Authorization"] = `Bearer ${token}`;
        }

        const response = await fetch(
          `${apiBaseUrl}${apiPathPrefix}/qa/chat-history/${this.state.userId}`,
          {
            headers,
            credentials: "include",
          },
        );
        if (!response.ok)
          throw new Error(`HTTP error! status: ${response.status}`);

        const result = await response.json();

        if (result.success && result.history) {
          const sortedHistory = [...result.history].sort((a, b) => {
            const aTime = new Date(
              a.created_at || a.timestamp || a.time || 0,
            ).getTime();
            const bTime = new Date(
              b.created_at || b.timestamp || b.time || 0,
            ).getTime();
            return aTime - bTime;
          });
          const total = sortedHistory.length;
          // 只取早於目前 earliestTimestamp 的紀錄
          const olderHistory =
            this.state.earliestTimestamp !== null
              ? sortedHistory.filter((item) => {
                  const ts = new Date(
                    item.created_at || item.timestamp || item.time || 0,
                  ).getTime();
                  return ts < (this.state.earliestTimestamp as number);
                })
              : sortedHistory;

          if (olderHistory.length === 0) {
            this.elements.loadMoreContainer.style.display = "none";
            return;
          }

          const startIndex = Math.max(
            0,
            olderHistory.length - this.state.historyItemsPerPage,
          );
          const endIndex = olderHistory.length;
          const historyToShow = olderHistory.slice(startIndex, endIndex);

          // 調整插入順序，確保時間順
          historyToShow.forEach((item) => {
            this.addHistoryMessage(
              item.user_message,
              item.ai_answer,
              item.reference_data || [],
              true,
            );
          });

          // 更新 earliestTimestamp
          const firstOld = historyToShow[0];
          this.state.earliestTimestamp = new Date(
            firstOld.created_at || firstOld.timestamp || firstOld.time || 0,
          ).getTime();

          // 當再也沒有更舊紀錄時，隱藏按鈕並清空標記
          if (startIndex === 0) {
            this.elements.loadMoreContainer.style.display = "none";
            this.state.earliestTimestamp = null;
          } else {
            this.state.currentHistoryPage++;
          }
        }
      } catch (error) {
        console.error("載入更多歷史記錄失敗:", error);
        this.addErrorMessage("❌ 載入更多記錄失敗，請稍後再試");
      }
    }

    // 添加歷史消息
    private addHistoryMessage(
      userMessage: any,
      aiAnswer: any,
      sources: any[],
      insertAtTop: boolean = false,
    ) {
      // 確保參數是字符串類型
      if (typeof userMessage !== "string") {
        userMessage = String(userMessage || "");
      }
      if (typeof aiAnswer !== "string") {
        aiAnswer = String(aiAnswer || "");
      }

      if (insertAtTop) {
        const userDiv = this.createMessageStructure("user", userMessage);
        const botDiv = this.createMessageStructure(
          "bot",
          this.formatAnswer(aiAnswer),
        );
        this.elements.chatMessages.insertBefore(
          botDiv,
          this.elements.chatMessages.firstChild,
        );
        this.elements.chatMessages.insertBefore(
          userDiv,
          this.elements.chatMessages.firstChild,
        );
      } else {
        this.addMessage(userMessage, "user");
        this.addBotResponse(aiAnswer, sources);
      }
    }

    // 顯示催促消息
    private showSaucyMessage() {
      if (this.state.saucyMessageCount >= this.state.maxSaucyMessages) {
        console.log("已達到最大催促次數，停止催促");
        return;
      }

      this.state.saucyMessageCount++;
      console.log(`顯示第${this.state.saucyMessageCount}次催促消息`);

      const langData = this.messages?.[this.state.currentLanguage];
      const currentMessages =
        langData?.[this.state.botName] || langData?.["Maya"];

      // 避免重複顯示相同的消息
      let availableMessages = currentMessages.saucy.filter(
        (msg: string) => msg !== this.state.lastSaucyMessage,
      );
      if (availableMessages.length === 0) {
        // 如果所有消息都用過了，重置並使用所有消息
        availableMessages = currentMessages.saucy;
        this.state.lastSaucyMessage = "";
      }

      const randomMessage =
        availableMessages[Math.floor(Math.random() * availableMessages.length)];
      this.state.lastSaucyMessage = randomMessage;

      const messageDiv = this.createMessageStructure("loading");
      this.elements.chatMessages.appendChild(messageDiv);
      this.scrollToBottom();

      setTimeout(() => {
        const contentDiv = messageDiv.querySelector(
          ".message-content",
        ) as HTMLDivElement;
        contentDiv.innerHTML = `<p>${randomMessage}</p>`;
        this.scrollToBottom();
      }, 1500);
    }

    // 啟動定時器
    private startTimers() {
      // 啟動不活躍計時器（使用遞增間隔）
      this.startInactivityTimer();
    }

    // 重置不活躍計時器
    private resetInactivityTimer() {
      console.log("重置催促計時器");
      if (this.timers.inactivity) clearTimeout(this.timers.inactivity);
      this.state.hasShownInactivityMessage = false;
      this.state.saucyMessageCount = 0;

      // 重新啟動定時器，使用遞增間隔
      this.startInactivityTimer();
    }

    // 啟動不活躍計時器（使用遞增間隔）
    private startInactivityTimer() {
      const intervals = [10, 30, 60]; // 10分鐘, 30分鐘, 60分鐘
      const currentInterval =
        intervals[this.state.saucyMessageCount] ||
        intervals[intervals.length - 1];

      this.timers.inactivity = setTimeout(
        () => {
          if (
            !this.state.isThinking &&
            this.state.saucyMessageCount < this.state.maxSaucyMessages
          ) {
            console.log(`觸發第${this.state.saucyMessageCount + 1}次催促`);
            this.showSaucyMessage();

            // 如果還沒達到最大次數，設置下一次定時器
            if (this.state.saucyMessageCount < this.state.maxSaucyMessages) {
              this.startInactivityTimer();
            }
          }
        },
        currentInterval * 60 * 1000,
      );
    }

