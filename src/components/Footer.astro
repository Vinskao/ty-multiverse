---
import { Icon } from './Icon';
import { execSync } from 'node:child_process';
const currentYear = new Date().getFullYear();
let revision = 'unknown';

try {
	revision = execSync('git rev-parse --short HEAD', {
		cwd: new URL('../..', import.meta.url),
		encoding: 'utf-8',
	}).trim();
} catch (error) {
	console.warn('Failed to resolve git revision for footer:', error);
}
---

<footer>
	<div class="group">
		<p>
			Designed by TY
		</p>
		<p>&copy; {currentYear} TY Multiverse</p>
	</div>
	<div class="social-links">
		<a href="https://twitter.com/wawiking">
			<Icon icon="twitter-logo" />
			<span>Twitter</span>
		</a>
		<a href="https://github.com/Vinskao">
			<Icon icon="github-logo" />
			<span>GitHub</span>
		</a>
	</div>
	<div class="version">revision {revision}</div>
</footer>
