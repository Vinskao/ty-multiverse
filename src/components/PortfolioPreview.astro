---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
const level = data.level || 'basic';
const isAdvance = level === 'advance';
const category = data.category;

// 將 kebab-case 轉換為 Title Case
const formatTitle = (title: string) => {
	return title
		.split('-')
		.map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
		.join(' ');
};

const displayTitle = formatTitle(data.title);

// 分类映射配置
const categoryConfig = {
	'Java': { icon: '☕', color: '#ed8b00', bg: 'linear-gradient(135deg, #ed8b00 0%, #ff6b35 100%)' },
	'Spring Boot': { icon: '🌱', color: '#6db33f', bg: 'linear-gradient(135deg, #6db33f 0%, #4ade80 100%)' },
	'Kubernetes': { icon: '⛵', color: '#326ce5', bg: 'linear-gradient(135deg, #326ce5 0%, #3b82f6 100%)' },
	'Docker': { icon: '🐳', color: '#2496ed', bg: 'linear-gradient(135deg, #2496ed 0%, #06b6d4 100%)' },
	'Database': { icon: '🗄️', color: '#6366f1', bg: 'linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)' },
	'Algorithm': { icon: '🧠', color: '#ec4899', bg: 'linear-gradient(135deg, #ec4899 0%, #f97316 100%)' },
	'Concurrency': { icon: '⚡', color: '#f59e0b', bg: 'linear-gradient(135deg, #f59e0b 0%, #f97316 100%)' },
	'Angular': { icon: '🅰️', color: '#dd0031', bg: 'linear-gradient(135deg, #dd0031 0%, #c2410c 100%)' },
	'AI': { icon: '🤖', color: '#8b5cf6', bg: 'linear-gradient(135deg, #8b5cf6 0%, #a855f7 100%)' },
	'Git': { icon: '📋', color: '#f05032', bg: 'linear-gradient(135deg, #f05032 0%, #ea580c 100%)' },
	'API': { icon: '🔗', color: '#06b6d4', bg: 'linear-gradient(135deg, #06b6d4 0%, #0891b2 100%)' },
	'Design Pattern': { icon: '🏗️', color: '#7c3aed', bg: 'linear-gradient(135deg, #7c3aed 0%, #8b5cf6 100%)' },
	'DevOps': { icon: '🔧', color: '#64748b', bg: 'linear-gradient(135deg, #64748b 0%, #475569 100%)' },
	'Python': { icon: '🐍', color: '#3776ab', bg: 'linear-gradient(135deg, #3776ab 0%, #2563eb 100%)' },
	'JavaScript': { icon: '🟨', color: '#f7df1e', bg: 'linear-gradient(135deg, #f7df1e 0%, #eab308 100%)' },
	'Certification': { icon: '🏆', color: '#fbbf24', bg: 'linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%)' },
	'Other': { icon: '📄', color: '#6b7280', bg: 'linear-gradient(135deg, #6b7280 0%, #4b5563 100%)' }
};

const categoryInfo = category ? categoryConfig[category] || { icon: '📚', color: '#6b7280', bg: 'linear-gradient(135deg, #6b7280 0%, #4b5563 100%)' } : null;
---

<a class="portfolio-preview card" href={`/tymultiverse/work/${id}`}>
	<div class="header-container">
		{categoryInfo && (
			<span
				class="category-badge"
				style={`background: ${categoryInfo.bg}; color: white;`}
			>
				{categoryInfo.icon} {category}
			</span>
		)}
		<span class="title">{displayTitle}</span>
	</div>
	<span class={`level-badge ${isAdvance ? 'advance' : 'basic'}`} data-i18n={isAdvance ? "work.advance" : "work.basic"}>
		{isAdvance ? '🚀 Advance' : '📘 Basic'}
	</span>
	<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
</a>
