---
import {} from "astro";
---

<!-- v2 控制列：插入共用 qa-bot-container 中（header 下方即可） -->
<div class="control-row" id="qaV2Controls" style="display:none">
  <label>
    Model
    <select id="v2Model"></select>
  </label>
  <label style="display:flex;align-items:center;gap:6px;">
    <input type="checkbox" id="v2UseKb" checked /> TY 知識庫
  </label>
</div>

<script>
  import { getApiBaseUrl } from "../scripts/qabotShared";
  import { api } from "../utils/api";
  import { QABotBase } from "../utils/qabotBase";

  class QABotV2 extends QABotBase {
    private inputEl: HTMLInputElement;
    private sendBtn: HTMLButtonElement;
    private modelSel: HTMLSelectElement;
    private kbEl: HTMLInputElement;
    private apiBase: string;

    constructor() {
      super("chatMessages"); // Initialize base class with messages container ID

      // 將控制列移到 header 底下（若尚未在正確位置）
      const container = document.getElementById(
        "qaBotContainer",
      ) as HTMLElement;
      const header = container?.querySelector(
        ".chat-header",
      ) as HTMLElement | null;
      const controls = document.getElementById("qaV2Controls") as HTMLElement;
      if (
        container &&
        header &&
        controls &&
        controls.parentElement !== container
      ) {
        container.insertBefore(controls, container.children[1]);
      }

      this.inputEl = document.getElementById("userInput") as HTMLInputElement;
      this.sendBtn = document.getElementById("sendButton") as HTMLButtonElement;
      this.modelSel = document.getElementById("v2Model") as HTMLSelectElement;
      this.kbEl = document.getElementById("v2UseKb") as HTMLInputElement;
      this.apiBase = getApiBaseUrl();

      this.initialize();
    }

    public initialize(): void {
      this.bindEvents();
      this.loadModels();
    }

    public bindEvents() {
      this.sendBtn.addEventListener("click", () => this.ask());
      this.inputEl.addEventListener("keypress", (e) => {
        if (e.key === "Enter" && !e.shiftKey) {
          e.preventDefault();
          if ((window as any).qabotMode === "v2") this.ask();
        }
      });
    }

    public show() {
      (document.getElementById("qaV2Controls") as HTMLElement).style.display =
        "flex";
    }
    public hide() {
      (document.getElementById("qaV2Controls") as HTMLElement).style.display =
        "none";
    }

    private async loadModels() {
      const cacheKey = "qabot_v2_models_cache_v1";
      const cacheTtlMs = 5 * 60 * 1000;

      const applyModels = (models: any[]) => {
        const activeModels = models.filter((m: any) => m.is_active === true);

        this.modelSel.innerHTML = "";
        activeModels.forEach((m: any) => {
          const opt = document.createElement("option");
          opt.value = m.model_id || m.name;
          opt.textContent = m.name;
          this.modelSel.appendChild(opt);
        });

        if (!this.modelSel.value && activeModels.length > 0) {
          this.modelSel.value = activeModels[0].model_id || activeModels[0].name;
        }
      };

      try {
        const raw = sessionStorage.getItem(cacheKey);
        if (raw) {
          const cached = JSON.parse(raw);
          const models = cached?.data?.models || (Array.isArray(cached?.data) ? cached.data : []);
          if (Array.isArray(models) && Date.now() - Number(cached.timestamp || 0) < cacheTtlMs) {
            applyModels(models);
            return;
          }
        }
      } catch (_) {}

      try {
        const data = await api.getAvailableModels();

        console.log("Models API response:", data);

        const models = data?.models || (Array.isArray(data) ? data : []);

        try {
          sessionStorage.setItem(
            cacheKey,
            JSON.stringify({
              timestamp: Date.now(),
              data,
            }),
          );
        } catch (_) {}

        console.log("Active models:", models.filter((m: any) => m.is_active === true));
        applyModels(models);
      } catch (e) {
        console.error("Failed to load models:", e);
        this.modelSel.innerHTML = '<option value="">?????????</option>';
      }
    }

    private async ask() {
      const q = this.inputEl.value.trim();
      if (!q) return;
      this.inputEl.value = "";

      // 顯示用戶消息
      this.appendMessage(
        `<div class="message user-message"><div class="message-content"><p>${this.escapeHtml(q)}</p></div></div>`,
      );

      // 顯示等待UI
      this.showLoadingMessage();

      try {
        const payload = {
          question: q,
          model_name: this.modelSel.value,
          sync: true, // 強制使用同步處理，避開後端隊列問題
          use_knowledge_base: !!this.kbEl.checked,
        };

        const data = await api.askWithModel(payload);
        console.log("🤖 Ask API Response:", data);

        // 嘗試獲取任務ID (支援多種命名格式)
        const taskId = data.task_id || data.request_id || data.requestId;

        // 檢查是否有 taskId
        if (taskId) {
          console.log("Starting polling for task:", taskId);
          // 開始輪詢任務狀態
          this.startPollingForTask(taskId, q);
        } else if (data.ai_response || data.answer || data.text) {
          // 如果直接返回了結果（同步模式或快速響應）
          this.hideLoadingMessage();
          this.displayAIResponse(data);
        } else {
          console.error(
            "Unexpected response format - missing task_id or content:",
            data,
          );
          throw new Error("未收到任務ID或有效回應 (Check console for details)");
        }
      } catch (e) {
        // 隱藏等待UI
        this.hideLoadingMessage();
        this.showErrorMessage((e as Error).message);
      }
    }

    private startPollingForTask(taskId: string, originalQuestion: string) {
      super.startPollingTask(taskId, async () => {
        const data = await api.getTaskStatus(taskId);

        // 調試信息
        console.log("Task status response:", data);

        switch (data.status) {
          case "SUCCESS":
            // 任務完成
            console.log("Task completed successfully:", data);
            this.hideLoadingMessage();
            this.displayAIResponse(data);
            this.stopPollingTask(taskId);
            break;

          case "FAILURE":
            // 任務失敗
            console.log("Task failed:", data);
            this.hideLoadingMessage();
            const errorMsg = data.error || "任務處理失敗";
            this.showErrorMessage(errorMsg);
            this.stopPollingTask(taskId);
            break;

          case "PENDING":
          case "STARTED":
            // 任務仍在處理中，繼續輪詢
            console.log("Task still processing:", data.status);
            this.updateLoadingMessage(
              data.status === "STARTED" ? "處理中..." : "等待中...",
            );
            // Continue polling (handled by base class)
            break;

          default:
            // 未知狀態
            console.log("Unknown task status:", data.status);
            this.hideLoadingMessage();
            this.showErrorMessage(`未知任務狀態: ${data.status}`);
            this.stopPollingTask(taskId);
        }
      });
    }

    private displayAIResponse(data: any) {
      try {
        // 建立主要的AI回應容器
        const aiResponse = data.ai_response || data.text || data.answer || "";
        const modelInfo = data.ai_model || {};
        const knowledgeUsed = data.knowledge_used || false;
        const citations = data.knowledge_citations || [];

        // 分割AI回應以提取主要內容和知識庫內容
        const responseText = this.formatAIResponse(aiResponse);

        // 建立完整的回應HTML
        let responseHTML = `
          <div class=\"message bot-message\">
            <div class=\"message-content-wrapper\">
              <div class=\"message-header\">
                <span class="ai-name">${this.escapeHtml(modelInfo.name || "AI")}</span>
                ${knowledgeUsed ? '<span class=\"knowledge-badge\">🧠 知識庫</span>' : ""}
              </div>
              <div class=\"message-content\">
                ${responseText}
              </div>
              ${citations.length > 0 ? this.buildCitationsHTML(citations) : ""}
            </div>
          </div>
        `;

        this.appendMessage(responseHTML);
      } catch (e) {
        console.error("Error displaying AI response:", e);
        this.showErrorMessage("回應格式錯誤");
      }
    }

    private formatAIResponse(response: string): string {
      if (!response) return "<p>無回應內容</p>";

      // 分割主要回應和知識庫內容
      const parts = response.split(/相關知識庫內容：|知識庫內容：/);
      const mainContent = parts[0].trim();

      // 格式化主要內容
      const formattedContent = mainContent
        .replace(/\n\n/g, "</p><p>")
        .replace(/\n/g, "<br>")
        .replace(/### (.+?)(\n|$)/g, "<h4>$1</h4>")
        .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
        .replace(/- (.+?)(\n|$)/g, "<li>$1</li>");

      // 包裝在段落標籤中
      const wrappedContent = formattedContent.includes("<li>")
        ? formattedContent.replace(/(<li>.*<\/li>)/g, "<ul>$1</ul>")
        : `<p>${formattedContent}</p>`;

      return wrappedContent;
    }

    private buildCitationsHTML(citations: any[]): string {
      if (!citations || citations.length === 0) return "";

      const citationsList = citations
        .map((citation, index) => {
          const source = citation.source || "";
          const filePath = citation.file_path || "";
          const sourceUrl = citation.source_url || "";
          const title = citation.title || filePath || source;
          const content = citation.content || "";

          // 建立連結，如果有 source_url 就使用，否則建立相對連結
          const linkUrl = sourceUrl || `/work/${filePath}`;
          const linkText = filePath || source;

          return `
          <div class=\"citation-item\">
            <span class=\"citation-number\">${index + 1}</span>
            <div class=\"citation-content\">
              <div class=\"citation-source\">
                <span class="citation-id">${this.escapeHtml(source)}</span>
                ${linkUrl ? `<a href="${linkUrl}" target="_blank" class="citation-link">📄 ${this.escapeHtml(linkText)}</a>` : ""}
              </div>
              ${content ? `<div class="citation-text">${this.escapeHtml(content)}</div>` : ""}
              ${citation.relevance_score ? `<div class=\"citation-score\">相關度: ${(citation.relevance_score * 100).toFixed(1)}%</div>` : ""}
            </div>
          </div>
        `;
        })
        .join("");

      return `
        <div class=\"knowledge-citations\">
          <div class=\"citations-header\">
            <span class=\"citations-icon\">📚</span>
            <span class=\"citations-title\">參考資料</span>
          </div>
          <div class=\"citations-list\">
            ${citationsList}
          </div>
        </div>
      `;
    }

    // 清理方法，用於停止所有輪詢
    public cleanup() {
      super.cleanup();
    }
  }

  function initQABotV2() {
    const existingInstance = (window as any).qabotV2Instance;
    const controls = document.getElementById("qaV2Controls");
    const modelSelect = document.getElementById("v2Model");
    const sameDom =
      !!existingInstance &&
      existingInstance.modelSel === modelSelect &&
      controls !== null;

    if (sameDom) {
      return;
    }

    if (existingInstance && typeof existingInstance.cleanup === "function") {
      existingInstance.cleanup();
    }
    (window as any).qabotV2Instance = new QABotV2();

    if (!(window as any).__qabotV2SwitchBound) {
      (window as any).__qabotV2SwitchBound = true;
      window.addEventListener("qabot:switch", (e: any) => {
        const instance = (window as any).qabotV2Instance as QABotV2;
        if (!instance) return;
        if (e?.detail?.mode === "v2") {
          instance.show();
        } else {
          instance.hide();
        }
      });
    }
  }

  document.addEventListener("astro:page-load", initQABotV2);
</script>
