---
// Learn about using Astro layouts:
// https://docs.astro.build/en/core-concepts/layouts/

// CSS Imports via ?url — Astro v5 SSR does not collect CSS from sub-components,
// so all component CSS must be explicitly linked here in the root layout.
import globalCssUrl from '../styles/global.css?url';
import themeToggleCssUrl from '../styles/theme-toggle.css?url';
import navCssUrl from '../styles/nav.css?url';
import qabotCssUrl from '../styles/qabot.css?url';
import qaplatformCssUrl from '../styles/qaplatform.css?url';
import qabotv2CssUrl from '../styles/qabotv2.css?url';

// Component Imports
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import QAPlatform from '../components/QAPlatform.astro';
import QABot from '../components/QABot.astro';
import QABotV2 from '../components/QABotV2.astro';
import { ClientRouter } from 'astro:transitions';



interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;




---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
		<title>TY Multiverse</title>
		<script is:inline src="/tymultiverse/scripts/lang.js"></script>
		<script is:inline>
			// 🎨 主題初始化 - 在任何渲染之前執行，避免主題閃爍 (FOUC)
			(function() {
				// 1. 從 localStorage 或系統偏好取得主題
				const savedTheme = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = savedTheme || (prefersDark ? 'dark' : 'light');
				
				// 2. 立即設置正確的主題類別，確保頁面渲染時就是正確的主題
				const html = document.documentElement;
				html.classList.remove('theme-light', 'theme-dark');
				html.classList.add(`theme-${theme}`);
				
				// 3. 儲存主題設定（確保首次訪問時也能記住偏好）
				if (!savedTheme) {
					localStorage.setItem('theme', theme);
				}
			})();

			// --- 最後訪問頁面記憶 & 還原 ---
			// 暫時完全禁用重定向邏輯，防止無限循環
			(function() {
				try {
					const STORAGE_KEY = 'lastVisitedPath';
					const currentPath = window.location.pathname + window.location.search;

					const isLoginPage = currentPath.startsWith('/login');
					const isHomePage = currentPath === '/' || currentPath === '/tymultiverse' || currentPath === '/tymultiverse/' || currentPath.startsWith('/tymultiverse/index');

					// 2) 非登入頁面且不含認證參數時，記錄乾淨路徑
					if (!isLoginPage && !isHomePage) {
						// 移除帶有認證資訊的查詢參數版本，用於儲存
						const urlObj = new URL(window.location.href);
						urlObj.searchParams.delete('username');
						urlObj.searchParams.delete('token');
						urlObj.searchParams.delete('refresh_token');
						urlObj.searchParams.delete('refreshToken');
						urlObj.searchParams.delete('email');
						urlObj.searchParams.delete('name');
						urlObj.searchParams.delete('firstName');
						urlObj.searchParams.delete('lastName');
						const cleanPath = urlObj.pathname + urlObj.search;
						localStorage.setItem(STORAGE_KEY, cleanPath);
					}
				} catch(e) {
					console.warn('lastVisitedPath 儲存失敗', e);
				}
			})();
		</script>
		<link rel="stylesheet" href={globalCssUrl} />
		<link rel="stylesheet" href={themeToggleCssUrl} />
		<link rel="stylesheet" href={navCssUrl} />
		<link rel="stylesheet" href={qabotCssUrl} />
		<link rel="stylesheet" href={qaplatformCssUrl} />
		<link rel="stylesheet" href={qabotv2CssUrl} />
		<slot name="head" />
		<MainHead title={title} description={description} />
		<ClientRouter />
	</head>
	<body>
		<div class="stack backgrounds">
			<Nav />
			<!-- 頁面主要內容容器 - 用於 AI 分析 -->
			<main class="page-content" data-page-type="content">
				<slot />
			</main>
			<Footer />
		</div>
		
		<!-- QA Platform (shared UI) + scripts for v1/v2 -->
		<QAPlatform />
		<QABot />
		<QABotV2 />
		


		<script>
			// Add "loaded" class once the document has completely loaded.
			// 支援 View Transitions 的客戶端導航
			function addLoadedClass() {
				document.documentElement.classList.add('loaded');
			}
			addEventListener('load', addLoadedClass);
			// View Transitions 導航後也觸發
			document.addEventListener('astro:page-load', addLoadedClass);
			// 如果頁面已經載入完成，立即添加
			if (document.readyState === 'complete') {
				addLoadedClass();
			}
			
			// 頁面內容提取輔助函數
			(window as any).extractPageContent = function() {
				const contentSelectors = [
					'[data-page-type="content"]',
					'[data-page-type="main"]',
					'[data-page-type="article"]',
					'main',
					'article',
					'.content',
					'.main-content',
					'#content',
					'#main'
				];
				
				let bestContent: string | null = null;
				let maxLength = 0;
				
				// 尋找最佳內容元素
				contentSelectors.forEach(selector => {
					const elements = document.querySelectorAll(selector);
					elements.forEach(element => {
						const text = (element as HTMLElement).innerText || element.textContent || '';
						const cleanText = text.replace(/\s+/g, ' ').trim();
						if (cleanText.length > maxLength) {
							maxLength = cleanText.length;
							bestContent = cleanText;
						}
					});
				});
				
				const finalContent = bestContent || document.body.innerText || '';
				return {
					content: finalContent,
					length: finalContent.length,
					title: document.title,
					url: window.location.href,
					timestamp: new Date().toISOString()
				};
			};

			// 🚀 View Transitions 修復：在 DOM Swap 後立即恢復主題類別
			// 這確保了 React 水合 (Hydration) 時能讀取到正確的 classList
			document.addEventListener('astro:after-swap', () => {
				const savedTheme = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = savedTheme || (prefersDark ? 'dark' : 'light');
				document.documentElement.classList.remove('theme-light', 'theme-dark');
				document.documentElement.classList.add(`theme-${theme}`);
				if (!savedTheme) localStorage.setItem('theme', theme);
				console.log('[Theme] astro:after-swap applied theme:', theme);
			});
		</script>

		<style>
			:root {
				--_placeholder-bg: linear-gradient(transparent, transparent);
				--bg-image-main: url('/tymultiverse/assets/backgrounds/bg-main-light-800w.jpg');
				--bg-image-main-curves: url('/tymultiverse/assets/backgrounds/bg-main-light.svg');
				--bg-image-subtle-1: var(--_placeholder-bg);
				--bg-image-subtle-2: var(--_placeholder-bg);
				--bg-image-footer: var(--_placeholder-bg);
				--bg-svg-blend-mode: overlay;
				--bg-blend-mode: darken;
				--bg-image-aspect-ratio: 2.25;
				--bg-scale: 1.68;
				--bg-aspect-ratio: calc(var(--bg-image-aspect-ratio) / var(--bg-scale));
				--bg-gradient-size: calc(var(--bg-scale) * 100%);
			}

			:root.theme-dark {
				--bg-image-main: url('/tymultiverse/assets/backgrounds/bg-main-dark-800w.jpg');
				--bg-image-main-curves: url('/tymultiverse/assets/backgrounds/bg-main-dark.svg');
				--bg-svg-blend-mode: darken;
				--bg-blend-mode: lighten;
			}

			/* These backgrounds are displayed below the fold, so we lazy load them
			   once the `.loaded` class has been set.  */
			:root.loaded {
				--bg-image-subtle-1: url('/tymultiverse/assets/backgrounds/bg-subtle-1-light-800w.jpg');
				--bg-image-subtle-2: url('/tymultiverse/assets/backgrounds/bg-subtle-2-light-800w.jpg');
				--bg-image-footer: url('/tymultiverse/assets/backgrounds/bg-footer-light-800w.jpg');
			}
			:root.loaded.theme-dark {
				--bg-image-subtle-1: url('/tymultiverse/assets/backgrounds/bg-subtle-1-dark-800w.jpg');
				--bg-image-subtle-2: url('/tymultiverse/assets/backgrounds/bg-subtle-2-dark-800w.jpg');
				--bg-image-footer: url('/tymultiverse/assets/backgrounds/bg-footer-dark-800w.jpg');
			}

			@media (min-width: 50em) {
				:root {
					--bg-scale: 1;
					--bg-image-main: url('/tymultiverse/assets/backgrounds/bg-main-light-1440w.jpg');
				}
				:root.theme-dark {
					--bg-image-main: url('/tymultiverse/assets/backgrounds/bg-main-dark-1440w.jpg');
				}

				:root.loaded {
					--bg-image-subtle-1: url('/tymultiverse/assets/backgrounds/bg-subtle-1-light-1440w.jpg');
					--bg-image-subtle-2: url('/tymultiverse/assets/backgrounds/bg-subtle-2-light-1440w.jpg');
					--bg-image-footer: url('/tymultiverse/assets/backgrounds/bg-footer-light-1440w.jpg');
				}
				:root.loaded.theme-dark {
					--bg-image-subtle-1: url('/tymultiverse/assets/backgrounds/bg-subtle-1-dark-1440w.jpg');
					--bg-image-subtle-2: url('/tymultiverse/assets/backgrounds/bg-subtle-2-dark-1440w.jpg');
					--bg-image-footer: url('/tymultiverse/assets/backgrounds/bg-footer-dark-1440w.jpg');
				}
			}

			.backgrounds {
				min-height: 100%;
				isolation: isolate;
				background:
					/*noise*/
					url('/tymultiverse/assets/backgrounds/noise.png') top center/220px repeat,
					/*footer*/ var(--bg-image-footer) bottom center/var(--bg-gradient-size) no-repeat,
					/*header1*/ var(--bg-image-main-curves) top center/var(--bg-gradient-size) no-repeat,
					/*header2*/ var(--bg-image-main) top center/var(--bg-gradient-size) no-repeat,
					/*base*/ var(--gray-999);
				background-blend-mode: /*noise*/
					overlay,
					/*footer*/ var(--bg-blend-mode),
					/*header1*/ var(--bg-svg-blend-mode),
					/*header2*/ normal,
					/*base*/ normal;
			}
			@media (forced-colors: active) {
				/* Deactivate custom backgrounds for high contrast users. */
				.backgrounds {
					background: none;
					background-blend-mode: none;
					--bg-gradient-size: none;
				}
			}
		</style>
	</body>
	
</html>
