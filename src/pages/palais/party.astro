---
declare global {
    interface Window {
        TY_MULTIVERSE_CONFIG?: {
            tymbUrl: string;
            peopleImageUrl: string;
        };
    }
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";

const url = new URL(Astro.request.url);
const username = url.searchParams.get("username");
const token = url.searchParams.get("token");

const isLoggedIn = !!username && !!token;

if (!isLoggedIn) {
    return Astro.redirect(
        `/tymultiverse/login?redirect=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`,
    );
}

const tymbUrl = import.meta.env.PUBLIC_TYMB_URL;
const peopleImageUrl =
    import.meta.env.PUBLIC_PEOPLE_IMAGE_URL ||
    "http://peoplesystem.tatdvsonorth.com";
---

<BaseLayout title="Party | TY Multiverse" description="Create your choir party">
    <div class="stack gap-20">
        <main class="wrapper stack gap-8">
            <Hero title="Party" tagline="Arrange your choir." align="start" />

            <div class="party-scroll-wrapper">
                <div class="party-container">
                    <!-- Visualizer -->
                    <div class="stage-wrapper">
                        <div id="choir-stage" class="choir-stage">
                            <!-- Dynamic Content -->
                        </div>
                    </div>

                    <!-- Controls -->
                    <div class="controls-header">
                        <div
                            id="loading-spinner"
                            style="display:none; color: var(--accent-regular);"
                        >
                            Loading characters...
                        </div>
                        <div
                            class="header-actions"
                            style="display: flex; gap: 1rem; align-items: center; width: 100%;"
                        >
                            <div class="row-selector-container">
                                <label for="active-row-select" style="font-size: 0.9rem; color: var(--gray-300);">Select Row:</label>
                                <select id="active-row-select" style="padding: 0.5rem; background: #333; color: white; border: 1px solid #555; border-radius: 4px;">
                                    <option value="5">Front Row (Row 5)</option>
                                    <option value="4">Row 4</option>
                                    <option value="3">Row 3</option>
                                    <option value="2">Row 2</option>
                                    <option value="1">Back Row (Row 1)</option>
                                </select>
                            </div>
                            <div id="selection-status" class="selection-status" style="flex-grow: 1;">
                            </div>
                            <button
                                id="download-btn"
                                style="padding: 0.5rem 1rem; cursor: pointer; margin-right: 0.5rem;"
                                >Download (No BG)</button>
                            <button
                                id="download-gif-btn"
                                style="padding: 0.5rem 1rem; cursor: pointer; background: #673ab7; color: white; border: none;"
                                >Download GIF</button>
                        </div>
                    </div>

                    <div id="party-controls" class="controls-section">
                        <!-- Dynamic Checkboxes -->
                    </div>
                </div>
            </div>
        </main>
    </div>
</BaseLayout>

<script
    async
    src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"
></script>
<link rel="stylesheet" href="/src/styles/party.css" />
<script define:vars={{ tymbUrl, peopleImageUrl }}>
    window.TY_MULTIVERSE_CONFIG = {
        tymbUrl: tymbUrl,
        peopleImageUrl: peopleImageUrl,
    };
</script>

<script>
    import "../../scripts/party.ts";
</script>
