---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Levellist from "../../components/Levellist.astro";
import palaisCssUrl from "../../styles/palais.css?url";
import levellistCssUrl from "../../styles/levellist.css?url";

const url = new URL(Astro.request.url);
const username = url.searchParams.get('username');

const isLoggedIn = !!username; // #4: 不再依賴 URL token（機密改由 localStorage + 後端強制）
if (!isLoggedIn) {
  return Astro.redirect(`/tymultiverse/login?redirect=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}
---
<BaseLayout title="Palais Levels | Wavo Yuropha" description="Level list within Palais">
  <Fragment slot="head">
    <link rel="stylesheet" href={palaisCssUrl} />
    <link rel="stylesheet" href={levellistCssUrl} />
  </Fragment>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero title="Palais" tagline="Level List" align="start" />
      <div class="system-container">
        <Levellist />
      </div>
    </main>
  </div>
</BaseLayout>

<script async src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script async defer src="https://cdnjs.cloudflare.com/ajax/libs/d3/4.2.2/d3.min.js"></script> 
<script>
  import "../../scripts/palaisMediaZoom";
</script>
