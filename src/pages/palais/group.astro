---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import palaisCssUrl from "../../styles/palais.css?url";
import peopleGalleryCssUrl from "../../styles/people-gallery.css?url";

const url = new URL(Astro.request.url);
const username = url.searchParams.get('username');

const isLoggedIn = !!username; // #4: 不再依賴 URL token（機密改由 localStorage + 後端強制）
if (!isLoggedIn) {
  return Astro.redirect(`/tymultiverse/login?redirect=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}
---
<BaseLayout title="Palais 模組2 | Wavo Yuropha" description="Group module within Palais">
  <Fragment slot="head">
    <link rel="stylesheet" href={palaisCssUrl} />
    <link rel="stylesheet" href={peopleGalleryCssUrl} />
  </Fragment>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero title="Palais" tagline="Group Module" align="start" />
      <div class="system-container">
        <div class="action-bar">
          <button id="refresh-data" class="refresh-btn">
            <span class="icon">🔄</span> 刷新數據與圖片
          </button>
          <button id="download-all-png" class="download-btn">
            <span class="icon">📦</span> 下載所有角色圖片 (ZIP)
          </button>
          <button id="download-all-padded" class="download-btn">
            <span class="icon">🖼️</span> 下載所有角色圖片（含邊框）(ZIP)
          </button>
        </div>
        <div id="group-container" data-palais-media-zoom></div>
      </div>
    </main>
  </div>
</BaseLayout>

<div id="pg-lightbox">
  <button id="pg-lightbox-close">&times;</button>
  <div style="display:flex;flex-direction:column;align-items:center;">
    <img id="pg-lightbox-img" src="" alt="" />
    <div id="pg-lightbox-name"></div>
  </div>
</div>

<div id="palais-cart">
  <div class="cart-header">
    <span>🧺 菜籃</span>
    <span class="cart-count" id="cart-count">0</span>
  </div>
  <div id="cart-items"></div>
</div>

<script is:inline async src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script is:inline async defer src="https://cdnjs.cloudflare.com/ajax/libs/d3/4.2.2/d3.min.js"></script>

<style>
  #group-container {
    --palais-media-scale: 1;
    margin: 2% 5% 5% 5%;
    padding: 0;
    max-width: 100%;
  }

  .action-bar {
    display: flex;
    justify-content: flex-end;
    padding: 15px 5%;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    margin: 20px 5% 0 5%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    gap: 15px;
  }

  .refresh-btn,
  .download-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .refresh-btn {
    background: linear-gradient(135deg, #6c757d, #495057);
    box-shadow: 0 4px 15px rgba(108, 117, 125, 0.3);
  }

  .download-btn {
    background: linear-gradient(135deg, #46A3FF, #007FFF);
    box-shadow: 0 4px 15px rgba(70, 163, 255, 0.3);
  }

  .refresh-btn:hover,
  .download-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.1);
  }

  .refresh-btn:hover {
    box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
  }

  .download-btn:hover {
    box-shadow: 0 6px 20px rgba(70, 163, 255, 0.4);
  }

  .refresh-btn:active,
  .download-btn:active {
    transform: translateY(0);
  }

  .refresh-btn:disabled,
  .download-btn:disabled {
    background: #666;
    cursor: wait;
    transform: none;
    box-shadow: none;
  }

  .refresh-btn .icon,
  .download-btn .icon {
    font-size: 18px;
  }

  .army-container {
    margin: 20px 0;
    padding: 15px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .army-title {
    font-size: 10px; /* 從 24px 縮到約 1/5，但仍可讀 */
    font-weight: bold;
    color: #fff;
    text-shadow: 0 0 4px rgba(255, 255, 255, 0.5);
  }

  /* --- 浮動菜籃 --- */
  #palais-cart {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 9999;
    width: 200px;
    max-height: 60vh;
    display: flex;
    flex-direction: column;
    background: rgba(20, 20, 30, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    overflow: hidden;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  #palais-cart.drag-over {
    border-color: #46A3FF;
    box-shadow: 0 0 0 2px #46A3FF, 0 8px 30px rgba(0, 0, 0, 0.5);
  }

  #palais-cart .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    cursor: default;
    user-select: none;
  }

  #palais-cart .cart-count {
    font-size: 12px;
    background: #007FFF;
    border-radius: 10px;
    padding: 1px 8px;
  }

  #cart-items {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px;
    overflow-y: auto;
    min-height: 60px;
    align-content: flex-start;
  }

  #cart-items:empty::after {
    content: '把人拖曳到這裡';
    color: rgba(255, 255, 255, 0.4);
    font-size: 12px;
    margin: auto;
  }

  /* 菜籃內的角色卡：取消重疊版面、縮小 */
  #cart-items > div {
    position: relative !important;
    display: inline-block !important;
    width: 56px !important;
    margin: 0 !important;
    left: auto !important;
    bottom: auto !important;
  }

  #cart-items > div > img {
    height: 72px !important;
    width: auto !important;
  }

  /* 菜籃內隱藏卡片底部的詳細資訊，避免擠爆 */
  #cart-items > div > div {
    display: none !important;
  }

  .pg-draggable {
    cursor: grab;
  }

  #group-container .box-container > div {
    width: calc(200px * var(--palais-media-scale)) !important;
    margin-left: calc(-100px * var(--palais-media-scale)) !important;
  }

  #group-container .box-container > div > img {
    height: calc(300px * var(--palais-media-scale)) !important;
  }
</style>

<script>
  import "../../scripts/palaisMediaZoom";

  if (!import.meta.env.PUBLIC_TYMB_URL) {
    throw new Error('PUBLIC_TYMB_URL 環境變量未設置');
  }
  if (!import.meta.env.PUBLIC_PEOPLE_IMAGE_URL) {
    throw new Error('PUBLIC_PEOPLE_IMAGE_URL 環境變量未設置');
  }

  const PEOPLE_IMAGE_URL = import.meta.env.PUBLIC_PEOPLE_IMAGE_URL;

  // --- 浮動菜籃（drag & drop，localStorage 記住）---

  let draggedCard: HTMLElement | null = null;
  const CART_KEY = 'palais-cart-v1';

  function getCartSet(): Set<string> {
    try { return new Set(JSON.parse(localStorage.getItem(CART_KEY) || '[]')); }
    catch { return new Set(); }
  }
  function saveCartSet(set: Set<string>) {
    localStorage.setItem(CART_KEY, JSON.stringify([...set]));
  }
  function updateCartCount() {
    const count = document.getElementById('cart-count');
    const items = document.getElementById('cart-items');
    if (count && items) count.textContent = String(items.children.length);
  }
  function moveCardToCart(card: HTMLElement) {
    const items = document.getElementById('cart-items');
    if (!items || !card) return;
    items.appendChild(card);
    const set = getCartSet();
    if (card.dataset.name) set.add(card.dataset.name);
    saveCartSet(set);
    updateCartCount();
  }
  function moveCardToArmy(card: HTMLElement, armyContainer: HTMLElement) {
    const grid = armyContainer.querySelector('.box-container');
    if (!grid || !card) return;
    grid.appendChild(card);
    const set = getCartSet();
    if (card.dataset.name) set.delete(card.dataset.name);
    saveCartSet(set);
    updateCartCount();
  }
  // 重整 / 刷新後：把記住的人從各隊伍移回菜籃
  function applyCartState() {
    const set = getCartSet();
    const items = document.getElementById('cart-items');
    if (!items) return;
    set.forEach((name) => {
      const card = document.querySelector<HTMLElement>(
        `.army-container .box-container > div[data-name="${(window as any).CSS.escape(name)}"]`
      );
      if (card) items.appendChild(card);
    });
    updateCartCount();
  }
  function initCart() {
    const cart = document.getElementById('palais-cart');
    if (!cart) return;
    cart.addEventListener('dragover', (e) => { e.preventDefault(); cart.classList.add('drag-over'); });
    cart.addEventListener('dragleave', () => { cart.classList.remove('drag-over'); });
    cart.addEventListener('drop', (e) => {
      e.preventDefault();
      cart.classList.remove('drag-over');
      if (draggedCard) moveCardToCart(draggedCard);
    });
  }

  // --- Lightbox ---

  function openLightbox(src: string, name: string) {
    (document.getElementById('pg-lightbox-img') as HTMLImageElement).src = src;
    document.getElementById('pg-lightbox-name')!.textContent = name;
    document.getElementById('pg-lightbox')!.classList.add('show');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    document.getElementById('pg-lightbox')!.classList.remove('show');
    document.body.style.overflow = '';
  }

  document.getElementById('pg-lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('pg-lightbox')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('pg-lightbox')) closeLightbox();
  });

  // --- Character card ---

  function createCharacterCard(character: any, timestamp: string) {
    const characterContainer = document.createElement('div');
    characterContainer.style.cssText = 'display:none;width:200px;text-align:center;margin-left:-100px;position:relative;z-index:1;vertical-align:bottom;cursor:pointer;';

    // 拖曳支援：標記身分，讓卡片可被拖進菜籃 / 拖回隊伍
    characterContainer.draggable = true;
    characterContainer.classList.add('pg-draggable');
    characterContainer.dataset.name = character.name || '';
    characterContainer.dataset.army = character.armyName || '';
    characterContainer.addEventListener('dragstart', (e) => {
      draggedCard = characterContainer;
      e.dataTransfer?.setData('text/plain', character.name || '');
      if (e.dataTransfer) e.dataTransfer.effectAllowed = 'move';
    });

    const img = document.createElement('img');
    img.style.cssText = 'width:auto;height:300px;display:block;margin:0 auto;padding:0;border:none;z-index:2;object-fit:contain;';
    img.alt = character.nameOriginal;

    const originalUrl = `${PEOPLE_IMAGE_URL}/${encodeURIComponent(character.name || 'default')}.png?t=${timestamp}`;

    img.onload = () => { characterContainer.style.display = 'inline-block'; };
    img.onerror = () => { characterContainer.remove(); };
    img.src = originalUrl;

    characterContainer.addEventListener('click', () => openLightbox(originalUrl, character.nameOriginal));
    characterContainer.addEventListener('mouseover', () => { img.style.zIndex = '3'; });
    characterContainer.addEventListener('mouseout', () => { img.style.zIndex = '2'; });

    const infoContainer = document.createElement('div');
    infoContainer.style.cssText = 'color:#fff;text-shadow:0 0 2px rgba(0,0,0,0.5);width:200px;position:absolute;bottom:-40px;left:0;overflow:hidden;font-size:12px;z-index:4;background-color:transparent;padding:5px;border-radius:5px;';

    const nameText = document.createElement('p');
    nameText.textContent = character.nameOriginal;
    nameText.style.cssText = 'margin:0;font-weight:bold;font-size:clamp(8px,1.2vw,10px);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';

    const attributesText = document.createElement('p');
    attributesText.textContent = `Attributes: ${character.attributes}`;
    attributesText.style.cssText = 'margin:0;font-size:clamp(6px,0.8vw,8px);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';

    const sizeText = document.createElement('p');
    sizeText.textContent = `${character.heightCm}cm / ${character.weightKg}kg`;
    sizeText.style.cssText = 'margin:0;font-size:clamp(6px,0.8vw,8px);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';

    infoContainer.appendChild(nameText);
    infoContainer.appendChild(attributesText);
    infoContainer.appendChild(sizeText);
    characterContainer.appendChild(img);
    characterContainer.appendChild(infoContainer);
    return characterContainer;
  }

  // --- Army container ---

  function createArmyContainer(army: string, characters: any[], timestamp: string) {
    const armyContainer = document.createElement('div');
    armyContainer.className = 'army-container';
    armyContainer.style.marginTop = '50px';

    // 放置目標：把菜籃裡的人拖回這個隊伍
    armyContainer.addEventListener('dragover', (e) => { e.preventDefault(); });
    armyContainer.addEventListener('drop', (e) => {
      e.preventDefault();
      if (draggedCard) moveCardToArmy(draggedCard, armyContainer);
    });

    const armyTitle = document.createElement('h2');
    armyTitle.className = 'army-title';
    armyTitle.textContent = army;
    armyTitle.style.marginBottom = '15px';

    const charactersGrid = document.createElement('div');
    charactersGrid.className = 'box-container';
    charactersGrid.style.margin = '0 auto';

    // 根據第一張卡片寬度設定左側 padding，避免最左邊的圖被容器邊緣切到
    if (characters.length > 0) {
      const firstCard = createCharacterCard(characters[0], timestamp);
      const cardWidth = parseInt(firstCard.style.width) || 200;
      charactersGrid.style.paddingLeft = (cardWidth / 2) + 'px';
      charactersGrid.appendChild(firstCard);
      characters.slice(1).forEach(character => {
        charactersGrid.appendChild(createCharacterCard(character, timestamp));
      });
    }

    armyContainer.appendChild(armyTitle);
    armyContainer.appendChild(charactersGrid);
    return armyContainer;
  }

  let currentFilteredData: any[] = [];
  let characterService: any = null;

  async function loadData(isRefresh = false) {
    try {
      const container = document.getElementById('group-container');
      if (!container) return;

      if (isRefresh) {
        const refreshBtn = document.getElementById('refresh-data');
        if (refreshBtn) refreshBtn.setAttribute('disabled', 'true');
      }

      container.innerHTML = '<div style="text-align:center;padding:50px;color:white;font-size:20px;">載入數據中...</div>';

      characterService = (await import('../../services/api/characterService')).default.getInstance();

      let data;
      if (isRefresh) {
        data = await characterService.refreshCharacters();
      } else {
        data = await characterService.getCharacters();
      }

      currentFilteredData = data.filter((char: any) => {
        const name = (char.name || '').toLowerCase();
        const army = (char.armyName || '').toLowerCase();
        if (name.includes('test') || name.includes('person') || army.includes('test') || army.includes('person')) return false;
        if (!char.armyName || army === 'unknown army') return false;
        return true;
      });

      const armyGroups: Record<string, any[]> = {};
      currentFilteredData.forEach((character: any) => {
        const army = character.armyName;
        if (!armyGroups[army]) armyGroups[army] = [];
        armyGroups[army].push(character);
      });

      const timestamp = characterService.getMediaTimestamp();
      const mainContainer = document.createElement('div');
      mainContainer.className = 'army-groups';

      Object.entries(armyGroups).forEach(([army, characters]) => {
        mainContainer.appendChild(createArmyContainer(army, characters as any[], timestamp));
      });

      container.innerHTML = '';
      container.appendChild(mainContainer);

      // 還原菜籃：把記住的人移回浮動菜籃
      applyCartState();

      if (isRefresh) {
        const refreshBtn = document.getElementById('refresh-data');
        if (refreshBtn) refreshBtn.removeAttribute('disabled');
      }
    } catch (error) {
      console.error('❌ Group 載入失敗:', error);
      const container = document.getElementById('group-container');
      if (container) {
        container.innerHTML = '';

        const errorContainer = document.createElement('div');
        errorContainer.style.cssText = `
          padding: 20px;
          margin: 20px 0;
          background: linear-gradient(135deg, rgba(255, 87, 87, 0.1), rgba(255, 87, 87, 0.05));
          border: 2px solid rgba(255, 87, 87, 0.3);
          border-radius: 12px;
          color: #ff5757;
          font-family: 'Courier New', monospace;
          font-size: 14px;
          white-space: pre-wrap;
          text-shadow: 0 0 5px rgba(255, 87, 87, 0.3);
        `;

        const errorTitle = document.createElement('div');
        errorTitle.style.cssText = 'font-weight:bold;font-size:16px;margin-bottom:10px;color:#ff3333;';
        errorTitle.textContent = '🚨 載入失敗 - Group 模組';

        const errorMessage = document.createElement('div');
        const errMsg = error instanceof Error ? error.message : String(error);
        errorMessage.textContent = `錯誤詳情:\n${errMsg}\n\n請檢查:\n• 後端服務是否正常運行\n• 隊列系統是否已啟動\n• API 端點是否正確`;

        errorContainer.appendChild(errorTitle);
        errorContainer.appendChild(errorMessage);
        container.appendChild(errorContainer);
      }
      const errMsg = error instanceof Error ? error.message : String(error);
      alert(`Group 模組載入失敗:\n${errMsg}`);

      const refreshBtn = document.getElementById('refresh-data');
      if (refreshBtn) refreshBtn.removeAttribute('disabled');
    }
  }

  function addPaddingToImage(url: string): Promise<Blob | null> {
    return new Promise((resolve) => {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => {
        const padX = Math.round(img.width * 0.1);
        const padY = Math.round(img.height * 0.2);
        const canvas = document.createElement('canvas');
        canvas.width = img.width + padX * 2;
        canvas.height = img.height + padY * 2;
        const ctx = canvas.getContext('2d');
        if (!ctx) { resolve(null); return; }
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(img, padX, padY);
        canvas.toBlob(blob => resolve(blob), 'image/png');
      };
      img.onerror = () => resolve(null);
      img.src = url;
    });
  }

  document.addEventListener("DOMContentLoaded", async function () {
    initCart();
    loadData();

    const refreshBtn = document.getElementById('refresh-data');
    if (refreshBtn) {
      refreshBtn.addEventListener('click', () => loadData(true));
    }

    const downloadBtn = document.getElementById('download-all-png');
    if (downloadBtn) {
      downloadBtn.addEventListener('click', async () => {
        try {
          downloadBtn.setAttribute('disabled', 'true');
          const originalText = downloadBtn.innerHTML;
          downloadBtn.textContent = '準備中...';

          if (typeof (window as any).JSZip === 'undefined') {
            const script = document.createElement('script');
            script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
            await new Promise((resolve, reject) => {
              script.onload = resolve;
              script.onerror = reject;
              document.head.appendChild(script);
            });
          }

          const JSZip = (window as any).JSZip;
          const zip = new JSZip();
          const imgFolder = zip.folder("characters");

          let completed = 0;
          const total = currentFilteredData.length;
          downloadBtn.textContent = `下載中 (0/${total})...`;

          await Promise.all(currentFilteredData.map(async (char) => {
            const imgName = char.name || 'default';
            const imgUrl = `${PEOPLE_IMAGE_URL}/${encodeURIComponent(imgName)}.png?t=${characterService.getMediaTimestamp()}`;
            try {
              const response = await fetch(imgUrl);
              if (response.ok) {
                const blob = await response.blob();
                imgFolder.file(`${imgName}.png`, blob);
              }
              completed++;
              downloadBtn.textContent = `下載中 (${completed}/${total})...`;
            } catch (err) {
              console.warn(`無法下載圖片: ${imgUrl}`, err);
              completed++;
            }
          }));

          downloadBtn.textContent = '壓縮中...';
          const content = await zip.generateAsync({ type: "blob" });

          const link = document.createElement('a');
          link.href = URL.createObjectURL(content);
          link.download = `palais_characters_${new Date().toISOString().split('T')[0]}.zip`;
          link.click();

          downloadBtn.textContent = '下載成功！';
          setTimeout(() => {
            downloadBtn.removeAttribute('disabled');
            downloadBtn.innerHTML = originalText;
          }, 3000);
        } catch (error) {
          console.error('下載失敗:', error);
          alert('下載失敗: ' + (error as any).message);
          downloadBtn.removeAttribute('disabled');
          downloadBtn.textContent = '下載失敗，請重試';
        }
      });
    }

    const downloadPaddedBtn = document.getElementById('download-all-padded');
    if (downloadPaddedBtn) {
      downloadPaddedBtn.addEventListener('click', async () => {
        try {
          downloadPaddedBtn.setAttribute('disabled', 'true');
          const originalText = downloadPaddedBtn.innerHTML;
          downloadPaddedBtn.textContent = '準備中...';

          if (typeof (window as any).JSZip === 'undefined') {
            const script = document.createElement('script');
            script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
            await new Promise((resolve, reject) => {
              script.onload = resolve;
              script.onerror = reject;
              document.head.appendChild(script);
            });
          }

          const JSZip = (window as any).JSZip;
          const zip = new JSZip();
          const imgFolder = zip.folder("characters_padded");

          let completed = 0;
          const total = currentFilteredData.length;
          downloadPaddedBtn.textContent = `處理中 (0/${total})...`;

          await Promise.all(currentFilteredData.map(async (char) => {
            const imgName = char.name || 'default';
            const imgUrl = `${PEOPLE_IMAGE_URL}/${encodeURIComponent(imgName)}.png?t=${characterService.getMediaTimestamp()}`;
            try {
              const blob = await addPaddingToImage(imgUrl);
              if (blob) imgFolder.file(`${imgName}.png`, blob);
            } catch (err) {
              console.warn(`無法處理圖片: ${imgUrl}`, err);
            }
            completed++;
            downloadPaddedBtn.textContent = `處理中 (${completed}/${total})...`;
          }));

          downloadPaddedBtn.textContent = '壓縮中...';
          const content = await zip.generateAsync({ type: "blob" });

          const link = document.createElement('a');
          link.href = URL.createObjectURL(content);
          link.download = `palais_characters_padded_${new Date().toISOString().split('T')[0]}.zip`;
          link.click();

          downloadPaddedBtn.textContent = '下載成功！';
          setTimeout(() => {
            downloadPaddedBtn.removeAttribute('disabled');
            downloadPaddedBtn.innerHTML = originalText;
          }, 3000);
        } catch (error) {
          console.error('下載失敗:', error);
          alert('下載失敗: ' + (error as any).message);
          downloadPaddedBtn.removeAttribute('disabled');
          downloadPaddedBtn.textContent = '下載失敗，請重試';
        }
      });
    }
  });
</script>
