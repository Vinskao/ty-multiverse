---
declare global {
  interface Window {
    TY_MULTIVERSE_CONFIG?: {
      tymbUrl: string;
      peopleImageUrl: string;
    };
  }
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import danceCssUrl from "../../styles/dance.css?url";

const url = new URL(Astro.request.url);
const username = url.searchParams.get('username');

const isLoggedIn = !!username; // #4: 不再依賴 URL token（機密改由 localStorage + 後端強制）

if (!isLoggedIn) {
  return Astro.redirect(`/tymultiverse/login?redirect=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}

const tymbUrl = import.meta.env.PUBLIC_TYMB_URL;
const peopleImageUrl = import.meta.env.PUBLIC_PEOPLE_IMAGE_URL || 'http://peoplesystem.tatdvsonorth.com';
---

<BaseLayout title="Dance | TY Multiverse" description="Dance video collection">
  <Fragment slot="head">
    <link rel="stylesheet" href={danceCssUrl} />
  </Fragment>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Dance"
        tagline="Enjoy the dance performances."
        align="start"
      />

      <div id="loading-status" class="loading-status">
        <div class="loading-spinner"></div>
        <span>正在載入角色和影片資料...</span>
      </div>
      
      <!-- 控制按鈕 -->
      <div class="cache-control-container">
        <button id="download-all-btn" class="download-all-btn" type="button">
          下載所有影片
        </button>
        <button id="cache-clear-btn" class="cache-clear-btn" type="button">
          清除緩存
        </button>
      </div>
      
      <div id="videos-grid" class="videos-grid" data-palais-media-zoom>
        <!-- 影片內容將動態載入 -->
      </div>
    </main>
  </div>
</BaseLayout>

<script async src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script async defer src="https://cdnjs.cloudflare.com/ajax/libs/d3/4.2.2/d3.min.js"></script>
<script define:vars={{ tymbUrl, peopleImageUrl }}>
  window.TY_MULTIVERSE_CONFIG = {
    tymbUrl: tymbUrl,
    peopleImageUrl: peopleImageUrl
  };
</script>

<script>
  import '../../scripts/dance.ts';
  import '../../scripts/palaisMediaZoom';
</script>
