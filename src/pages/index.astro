---
import { getCollection } from 'astro:content';
import algorithmsData from '../storages/algorithmsUsed.json';
import skillsData from '../storages/skills.json';

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Component Imports
import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import { Icon } from '../components/Icon';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import SkillsBubbleChart from '../components/SkillsBubbleChart';
import AiTokenUsageDashboard from '../components/AiTokenUsageDashboard';

// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';
import indexCssUrl from '../styles/index.css?url';

// 準備 Bubble Chart 資料 - 從 skillsData 計算每個類別的總分
const shadeScores: { [key: string]: number } = {
	shade1: 5,
	shade2: 4,
	shade3: 3,
	shade4: 2,
	shade5: 1,
};

interface BubbleData {
	id: string;
	name: string;
	value: number;
	category: string;
}

const bubbleChartData: BubbleData[] = skillsData.categories.map((category: any) => {
	// Flatten skills from subcategories if they exist, otherwise use direct skills
	const allSkills = category.subcategories 
		? category.subcategories.flatMap((sub: any) => sub.skills)
		: category.skills || [];
	
	// Calculate total score for the category
	const totalScore = allSkills.reduce((sum: number, skill: any) => {
		return sum + (shadeScores[skill.level] || 0);
	}, 0);

	return {
		id: category.name,
		name: category.name,
		value: totalScore,
		category: category.name,
	};
});
// Content Fetching: List four most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// 修改服務器啟動時間的處理
let serverStartTime = new Date().toISOString();
try {
    // 使用環境變量或默認值
    serverStartTime = import.meta.env.SERVER_START_TIME || serverStartTime;
} catch (error) {
    console.error('Error getting server start time:', error);
}

// 檢查是否需要顯示登入提示
const showLoginAlert = Astro.url.searchParams.get('showLoginAlert') === 'true';

const algorithmsUsed = algorithmsData.algorithms;
const skillsCategories = skillsData.categories;

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---
<BaseLayout>
	<Fragment slot="head">
		<link rel="stylesheet" href={indexCssUrl} />
	</Fragment>
	<!-- Messenger Chat Plugin Code -->
	<div id="fb-root"></div>

	<!-- Your Chat Plugin code -->
	<div id="fb-customer-chat" class="fb-customerchat">
	</div>
	{showLoginAlert && 
		<script is:inline>
			document.addEventListener('DOMContentLoaded', function() {
				const lang = (window.AppLang ? window.AppLang.get() : (localStorage.getItem('site_language') || 'en'));
				const title = lang === 'zh' ? '請先登入' : 'Please Login First';
				window.Swal.fire({
					title: title,
					icon: 'info',
					timer: 1000,
					showConfirmButton: false
				});
			});
		</script>
	}
	<div class="stack gap-20 lg:gap-48">

		<div class="wrapper stack gap-20 lg:gap-50">

			<header class="hero stack hero-layout">
				<div class="hero-main">
					<div class="hero-header">
						<h1 data-i18n="home.heroTitle">TY's Outerspace</h1>
						<p data-i18n="home.heroTagline">Java Backend Engineer | Enterprise Systems | Security Integration | AI/RAG Applications</p>
						<div class="visitor-counter-box">
						<p class="visit-counter"><span data-i18n="home.visitorCounterPrefix">Sequence #</span><span id="visit-count">...</span><span data-i18n="home.visitorCounterSuffix">: Identity Synchronized</span></p>
						</div>
					</div>

					<section id="market-overview" class="market-overview">
						<div class="market-overview-header">
							<div>
								<h4 class="section-title" data-i18n="home.marketOverviewTitle">Market Overview</h4>
							</div>
							<p class="market-overview-note" data-i18n="home.marketOverviewNote">Refreshed every 10 minutes</p>
						</div>
						<div class="market-overview-grid">
							<section id="txf-quote-section" class="market-quote-section" aria-live="polite">
								<div class="market-quote-heading">
									<div>
										<h5 class="section-title" data-i18n="home.marketTitle">TAIEX Futures</h5>
									</div>
									<span id="txf-market-status" class="market-status">Loading</span>
								</div>
								<div class="market-quote-card">
									<div>
										<p id="txf-contract" class="market-contract">TXF</p>
										<p id="txf-updated" class="market-updated" data-i18n="home.loading">Loading...</p>
									</div>
									<div class="market-price-block">
										<strong id="txf-price">--</strong>
										<span id="txf-change">--</span>
									</div>
									<dl class="market-metrics">
										<div><dt>Open</dt><dd id="txf-open">--</dd></div>
										<div><dt>High</dt><dd id="txf-high">--</dd></div>
										<div><dt>Low</dt><dd id="txf-low">--</dd></div>
										<div><dt>Volume</dt><dd id="txf-volume">--</dd></div>
									</dl>
									<p id="market-usage-access-message" class="market-updated" hidden></p>
								</div>
							</section>

							<section id="qff-quote-section" class="market-quote-section" aria-live="polite">
								<div class="market-quote-heading">
									<div>
										<h5 class="section-title">Mini TSMC Futures</h5>
									</div>
									<span id="qff-market-status" class="market-status">Loading</span>
								</div>
								<div class="market-quote-card market-quote-card--tsmc">
									<div>
										<p id="qff-contract" class="market-contract">QFFR1</p>
										<p id="qff-updated" class="market-updated">Loading...</p>
									</div>
									<div class="market-price-block">
										<strong id="qff-price">--</strong>
										<span id="qff-change">--</span>
									</div>
									<dl class="market-metrics">
										<div><dt>Open</dt><dd id="qff-open">--</dd></div>
										<div><dt>High</dt><dd id="qff-high">--</dd></div>
										<div><dt>Low</dt><dd id="qff-low">--</dd></div>
										<div><dt>Volume</dt><dd id="qff-volume">--</dd></div>
									</dl>
								</div>
							</section>

							<section id="market-usage-section" class="market-usage-section" aria-live="polite">
								<div class="market-quote-heading">
									<div>
										<h5 class="section-title" data-i18n="home.marketUsageTitle">Usage</h5>
									</div>
									<span id="market-usage-status" class="market-status">Loading</span>
								</div>
								<div class="market-usage-card">
									<div class="market-usage-hero">
										<strong id="market-usage-used">--</strong>
										<span id="market-usage-limit">--</span>
									</div>
									<div class="market-usage-progress">
										<div id="market-usage-progress-bar"></div>
									</div>
									<dl class="market-metrics">
										<div><dt data-i18n="home.marketUsageRemaining">Remaining</dt><dd id="market-usage-remaining">--</dd></div>
										<div><dt data-i18n="home.marketUsageConnections">Connections</dt><dd id="market-usage-connections">--</dd></div>
										<div><dt data-i18n="home.marketUsageUpdated">Updated</dt><dd id="market-usage-updated">--</dd></div>
									</dl>
								</div>
							</section>

							<section id="portfolio-section" class="market-usage-section portfolio-section" aria-live="polite">
								<div class="market-quote-heading">
									<div>
										<h5 class="section-title">Account Portfolio</h5>
									</div>
									<span id="portfolio-status" class="market-status">Loading</span>
								</div>
								<div class="market-usage-card portfolio-card">
									<div class="portfolio-summary">
										<div class="portfolio-summary-item">
											<span>Cash balance</span>
											<strong id="portfolio-cash" tabindex="0">--</strong>
											<div id="portfolio-cash-tooltip" class="portfolio-summary-tooltip" role="status"></div>
										</div>
										<div class="portfolio-summary-item">
											<span>Estimated total assets</span>
											<strong id="portfolio-total" tabindex="0">--</strong>
											<div id="portfolio-total-tooltip" class="portfolio-summary-tooltip" role="status"></div>
										</div>
										<div class="portfolio-summary-item">
											<span>Total unrealized P/L</span>
											<strong id="portfolio-pnl" tabindex="0">--</strong>
											<div id="portfolio-pnl-tooltip" class="portfolio-summary-tooltip" role="status"></div>
										</div>
										<div class="portfolio-summary-item">
											<span>Leverage</span>
											<strong id="portfolio-leverage" tabindex="0">--</strong>
											<div id="portfolio-leverage-tooltip" class="portfolio-summary-tooltip" role="status"></div>
										</div>
									</div>

									<!-- Donut charts: Securities (left) / Futures (right), Combined below -->
									<div class="portfolio-donuts">
										<div class="portfolio-donuts-row">
											<div class="portfolio-donut-section">
												<span class="portfolio-donut-label">Securities</span>
												<div id="portfolio-allocation-chart" class="portfolio-donut portfolio-donut--sm" aria-label="Stock allocation">
													<svg id="portfolio-donut-svg" viewBox="0 0 120 120" role="img" aria-label="Stock allocation chart"></svg>
													<div class="portfolio-donut-center">
														<strong id="portfolio-position-count">--</strong>
																			</div>
													<div id="portfolio-tooltip" class="portfolio-tooltip" role="status"></div>
												</div>
											</div>
											<div class="portfolio-donut-section">
												<span class="portfolio-donut-label">Futures</span>
												<div id="portfolio-futures-chart" class="portfolio-donut portfolio-donut--sm" aria-label="Futures allocation">
													<svg id="portfolio-futures-donut-svg" viewBox="0 0 120 120" role="img" aria-label="Futures allocation chart"></svg>
													<div class="portfolio-donut-center">
														<strong id="portfolio-futures-count">--</strong>
																			</div>
													<div id="portfolio-futures-tooltip" class="portfolio-tooltip" role="status"></div>
												</div>
											</div>
										</div>
										<div class="portfolio-donut-section">
											<span class="portfolio-donut-label">Combined</span>
											<div id="portfolio-combined-chart" class="portfolio-donut portfolio-donut--sm" aria-label="Combined allocation">
												<svg id="portfolio-combined-donut-svg" viewBox="0 0 120 120" role="img" aria-label="Combined allocation chart"></svg>
												<div class="portfolio-donut-center">
													<strong id="portfolio-combined-count">--</strong>
													</div>
												<div id="portfolio-combined-tooltip" class="portfolio-tooltip" role="status"></div>
											</div>
										</div>
									</div>
									<p class="portfolio-chart-hint">Hover, focus, or tap a slice for position details.</p>

	
									<p id="portfolio-updated" class="market-updated">--</p>
									<p id="portfolio-access-message" class="market-updated" hidden></p>
								</div>
							</section>
						</div>
					</section>

					<div class="hero-content">
						<!-- D3 Bubble Chart showing skill categories and scores -->
						<SkillsBubbleChart client:load data={bubbleChartData} categoriesData={skillsCategories} />
					</div>

					<div class="leetcode-graph">
						<h5 class="section-title" data-i18n="home.leetcodeTitle">LeetCode Stats</h5>
						<div id="leetcode-stats" class="leetcode-container">
							<div class="leetcode-card">
								<h6 data-i18n="home.leetcodeLabels.solved">Total Solved</h6>
								<p id="total-solved" data-i18n="home.loading">Loading...</p>
								<div class="progress-bar">
									<div id="total-progress"></div>
								</div>
							</div>
							<div class="leetcode-card">
								<h6 data-i18n="home.leetcodeLabels.easy">Easy</h6>
								<p id="easy-solved" data-i18n="home.loading">Loading...</p>
								<div class="progress-bar">
									<div id="easy-progress"></div>
								</div>
							</div>
							<div class="leetcode-card">
								<h6 data-i18n="home.leetcodeLabels.medium">Medium</h6>
								<p id="medium-solved" data-i18n="home.loading">Loading...</p>
								<div class="progress-bar">
									<div id="medium-progress"></div>
								</div>
							</div>
							<div class="leetcode-card">
								<h6 data-i18n="home.leetcodeLabels.hard">Hard</h6>
								<p id="hard-solved" data-i18n="home.loading">Loading...</p>
								<div class="progress-bar">
									<div id="hard-progress"></div>
								</div>
							</div>
						</div>
					</div>

					<div class="algorithms-section">
						<h5 class="section-title" data-i18n="home.patternsTitle">Patterns Learned</h5>
						<div class="algorithms-list">
							{algorithmsUsed.map((algo) => (
								<span class="algo-pill" data-explanation={algo.explanation}>{algo.name}</span>
							))}
						</div>
					</div>
				</div>

				<div class="hero-side">

					<div class="video-container">
						<div class="roles">
							<Pill class="gold"><Icon icon="code" size="1.33em" /> Backend</Pill>
							<Pill class="gold"><Icon icon="pencil-line" size="1.33em" /> DevOps</Pill>
							<Pill><Icon icon="code" size="1.33em" /> Frontend</Pill>
							<Pill><Icon icon="microphone-stage" size="1.33em" /> PM</Pill>
						</div>
						<div class="ai-usage-home-section">
							<AiTokenUsageDashboard client:load />
						</div>
						<div class="github-graph">
							<h5 class="section-title" data-i18n="home.githubTitle">Github Contributions</h5>
							<div>
								<img src="https://ghchart.rshah.org/VinsKao" alt="VinsKao's Github chart" />
							</div>
						</div>

						<div class="portrait-container">
		
						</div>

					</div>
				</div>

				
			</header>

			<!-- Skills Categories moved from hero-content -->
			<div class="hero-content categories-section">
				<div class="categories">
					{skillsCategories.map((category) => {
						return (
							<div class="category">
								<h5 class="section-title">{category.name}</h5>
								{(category as any).subcategories ? (
									(category as any).subcategories.map((sub: any) => (
										<div class="subcategory-group">
											<span class="subcategory-label">{sub.name}</span>
											<div class="pills-container">
												{sub.skills.map((skill: any) => (
													<span class={`skill-pill ${category.pillClass} ${skill.level} ${skill.specialClass || ''}`}>
														{skill.name}
													</span>
												))}
											</div>
										</div>
									))
								) : (
									<div class="pills-container">
										{((category as any).skills || []).map((skill: any) => (
											<span class={`skill-pill ${category.pillClass} ${skill.level} ${skill.specialClass || ''}`}>
												{skill.name}
											</span>
										))}
									</div>
								)}
							</div>
						);
					})}
				</div>
			</div>

			<Skills />

		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h5 class="section-title" data-i18n="home.collectionsTitle">Collections</h5>
					<p data-i18n="home.recentNotes">Recent Notes</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/tymultiverse/work/">
						<span data-i18n="home.viewAll">View All</span>
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<!-- <h5>Mentions</h5>
					<p>
						To be Continued...
					</p> -->
				</header>

				<!-- <div class="gallery">
					<Grid variant="small">
						{
							['Who', 'Am', 'I'].map((brand) => (
								<li class="mention-card">
									<p>{brand}</p>
								</li>
							))
						}
					</Grid>
				</div> -->
			</section>
		</main>

		<ContactCTA />
	</div>
	<script src="../scripts/index.ts"></script>
</BaseLayout>
