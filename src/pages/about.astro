---
import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
import ResumePreview from "../components/ResumePreview.astro";
import Briefing from "../components/Briefing.astro";
import aboutCssUrl from "../styles/about.css?url";
import briefingCssUrl from "../styles/briefing.css?url";
import { getMermaidConfig } from "../scripts/mermaid-theme";

// Import the JSON data
import aboutData from "../storages/about.json";
import skillsData from "../storages/skills.json";

type LangKey = "en" | "zh";
type LangText = { en: string[]; zh: string[] };
interface ExperienceItem {
  title: string;
  company: string;
  period: string;
  projectExperience?: LangText;
  responsibilities?: LangText;
}

const lang = (Astro.url.searchParams.get("lang") ?? "en") as LangKey;
const experienceData = aboutData.experience as unknown as ExperienceItem[];

// Calculate experience years
const softwareTitles = ["Software Engineer", "Open Source Backend Engineer", "Freelancer"];
const projectManagementTitles = ["Fintech PM, MA Program"];

function parsePeriodDate(s: string): Date {
  if (s.trim().toLowerCase() === "present") return new Date();
  const parts = s.trim().split("/");
  return new Date(Number(parts[0]), Number(parts[1]) - 1, 1);
}

function monthsBetween(start: Date, end: Date): number {
  return Math.max(0, (end.getFullYear() - start.getFullYear()) * 12 + end.getMonth() - start.getMonth());
}

let swMonths = 0;
let pmMonths = 0;
let totalMonths = 0;
for (const job of experienceData) {
  const [startStr, endStr] = job.period.split("~");
  const months = monthsBetween(parsePeriodDate(startStr), parsePeriodDate(endStr));
  totalMonths += months;
  if (softwareTitles.includes(job.title)) swMonths += months;
  if (projectManagementTitles.includes(job.title)) pmMonths += months;
}
const swYears = (swMonths / 12).toFixed(1);
const pmYears = (pmMonths / 12).toFixed(1);
const totalYears = (totalMonths / 12).toFixed(1);
const gitCommitCommand = `"REPO: $(git remote get-url origin)"; git log -n 50 --stat --date=iso-strict --pretty=format:"===COMMIT===%nHASH: %H%nDATE: %cI%nMSG: %s%n%b%n---FILES---"`;

// Function to highlight dates in project descriptions
function highlightDates(text: string): string {
  const dateRegex = /(\d{4}\/\d{1,2}(?:\s*~\s*(?:\d{4}\/\d{1,2}|Present))?)/g;
  return text.replace(dateRegex, '<span class="date-highlight">$1</span>');
}

// Normalize string for de-duplication
function normalizeForDedup(s: string): string {
  return s
    .trim()
    .toLowerCase()
    .replace(/[\s\u3000]+/g, " ")
    .replace(/[、，,；;：:。.!！？?（）()\[\]{}\-–—\u00A0]+/g, "");
}

function parseProject(
  project: string,
  lang: LangKey,
): {
  head: string;
  bullets: string[];
  dataModuleName?: string;
  dataModuleDetails: string[];
} {
  const isZh = lang === "zh";
  const respMarker = isZh ? "；主要負責：" : " — Responsibilities:";
  const dmMarker = isZh ? "；資料模組：" : " — Data Module:";

  const respIdx = project.indexOf(respMarker);
  if (respIdx === -1) {
    return { head: project, bullets: [], dataModuleDetails: [] };
  }

  const head = project.substring(0, respIdx).trim();
  const rest = project.substring(respIdx + respMarker.length).trim();

  let dataModule: string | undefined;
  let respPart = rest;
  const dmIdx = rest.indexOf(dmMarker);
  if (dmIdx !== -1) {
    respPart = rest.substring(0, dmIdx).trim();
    dataModule = rest.substring(dmIdx + dmMarker.length).trim();
  }

  const rawBullets = (isZh ? respPart.split(/；+/) : respPart.split(/\s*,\s*/))
    .map((s) => s.trim())
    .filter((s) => s.length > 0);
  const seen = new Set<string>();
  const bullets = rawBullets.filter((s) => {
    const key = normalizeForDedup(s);
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });

  let dataModuleName: string | undefined;
  let dataModuleDetails: string[] = [];
  if (dataModule) {
    // Extract name and details inside parentheses (both half/full width)
    const openIdx =
      dataModule.indexOf("(") !== -1
        ? dataModule.indexOf("(")
        : dataModule.indexOf("（");
    const closeIdx =
      dataModule.lastIndexOf(")") !== -1
        ? dataModule.lastIndexOf(")")
        : dataModule.lastIndexOf("）");
    if (openIdx !== -1 && closeIdx !== -1 && closeIdx > openIdx) {
      dataModuleName = dataModule.substring(0, openIdx).trim();
      const inner = dataModule.substring(openIdx + 1, closeIdx).trim();
      const dmRaw = (isZh ? inner.split(/；+/) : inner.split(/\s*,\s*/))
        .map((s) => s.trim())
        .filter((s) => s.length > 0);
      const dmSeen = new Set<string>();
      dataModuleDetails = dmRaw.filter((s) => {
        const key = normalizeForDedup(s);
        if (dmSeen.has(key)) return false;
        dmSeen.add(key);
        return true;
      });
    } else {
      dataModuleName = dataModule.trim();
    }
  }

  return { head, bullets, dataModuleName, dataModuleDetails };
}

function formatForResume(job: ExperienceItem, l: LangKey): string {
  if (!job.projectExperience?.[l]?.length) return "";
  const isZh = l === "zh";
  const lines: string[] = [
    `${job.title}  |  ${job.company}  |  ${job.period}`,
    "",
  ];
  for (const project of job.projectExperience[l]) {
    const p = parseProject(project, l);
    lines.push(`• ${p.head}`);
    if (p.bullets.length > 0) {
      const label = isZh ? "主要負責" : "Responsibilities";
      lines.push(`  ${label}: ${p.bullets.join(isZh ? "、" : " / ")}`);
    }
    if (p.dataModuleName) {
      const label = isZh ? "資料模組" : "Data Module";
      const details = p.dataModuleDetails.length
        ? ` (${p.dataModuleDetails.join(isZh ? "；" : " / ")})`
        : "";
      lines.push(`  ${label}: ${p.dataModuleName}${details}`);
    }
    lines.push("");
  }
  return lines.join("\n").trimEnd();
}
---

<BaseLayout title="About | Tianyi Kao" description="About Tianyi Kao">
  <Fragment slot="head">
    <link rel="stylesheet" href={aboutCssUrl} />
    <link rel="stylesheet" href={briefingCssUrl} />
  </Fragment>
  <div class="stack gap-20">
    <main class="wrapper about">

      <div class="hero-section">
        <Hero title="About" tagline="KTY's Journey" />
        <div class="exp-badges">
          <span class="exp-badge">
            <span class="exp-badge-label">
              {lang === "zh" ? "開發經驗" : "Software Development Experience"}
            </span>
            <strong>{swYears}{lang === "zh" ? " 年" : " yrs"}</strong>
          </span>
          <span class="exp-badge">
            <span class="exp-badge-label">
              {lang === "zh" ? "專案管理經驗" : "Project Management Experience"}
            </span>
            <strong>{pmYears}{lang === "zh" ? " 年" : " yrs"}</strong>
          </span>
          <span class="exp-badge">
            <span class="exp-badge-label">
              {lang === "zh" ? "總工作經驗" : "Total Professional Experience"}
            </span>
            <strong>{totalYears}{lang === "zh" ? " 年" : " yrs"}</strong>
          </span>
        </div>
        <div class="work-photo-wrapper" style="position:relative; width:100%;">
          <!-- Mask overlay with slogan -->
          <div class="work-photo-overlay" aria-hidden="true">
            <div class="mask-text">To Make a Difference.</div>
          </div>
          <img
            width="1553"
            height="873"
            src="/tymultiverse/assets/zen-landscape.svg"
            alt="Zen landscape with mountains, clouds, and tai chi symbol representing contemplation and balance"
            class="work-photo"
          />
          <div class="git-commit-ingest" data-admin-git-commit hidden>
            <div class="git-commit-toolbar">
              <div>
                <h2>Git Commit Ingest</h2>
                <p>Paste raw git log output and store searchable commit knowledge.</p>
              </div>
              <button type="button" class="git-copy-command" data-copy-git-command title="Copy command" aria-label="Copy command">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              </button>
            </div>
            <pre class="git-command" data-git-command>{gitCommitCommand}</pre>
            <textarea data-git-commit-text rows="10" placeholder="Paste agent output here"></textarea>
            <div class="git-commit-actions">
              <label>
                <input type="checkbox" data-git-embedding checked />
                Generate embeddings
              </label>
              <button type="button" class="git-submit" data-submit-git-commits>Ingest</button>
            </div>
            <div class="git-commit-result" data-git-commit-result aria-live="polite"></div>
          </div>
        </div>
      </div>

      <section>
        <h2 class="section-title">{lang === "zh" ? "背景" : "Background"}</h2>
        <div class="content background-content">
          <div class="name-section">
            <h1 class="majestic-name">
              {lang === "zh" ? "高天逸" : "KAO TIAN YI"}
            </h1>
            <p class="email">tianyikao@gmail.com</p>
          </div>
          <p set:html={aboutData.background[lang].replace(/\n/g, "<br>")} />
        </div>
      </section>
      <section>
        <h2 class="section-title">{lang === "zh" ? "專長" : "Expertise"}</h2>
        <div class="content expertise-content">
          <p>{aboutData.expertise[lang]}</p>
        </div>
      </section>
      <!-- Briefing Section -->
      <Briefing />

      <section>
        <h2 class="section-title">{lang === "zh" ? "專案經歷" : "Project Experience"}</h2>
        <div class="content">
          {
            experienceData.map(
              (job) =>
                job.projectExperience &&
                job.projectExperience[lang] &&
                job.projectExperience[lang].length > 0 && (
                  <details class="experience-item" data-copy={formatForResume(job, lang)}>
                    <summary class="job-header">
                      <div class="job-header-main">
                        <h3>{job.title}</h3>
                        <div class="job-meta">
                          <span class="company">{job.company}</span>
                          <span class="period">
                            <span class="date-highlight">{job.period}</span>
                          </span>
                        </div>
                      </div>
                      <button class="copy-resume-btn btn is-success" title={lang === "zh" ? "複製到履歷" : "Copy for resume"} aria-label="copy">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        <span class="copy-label">{lang === "zh" ? "複製" : "Copy"}</span>
                      </button>
                    </summary>
                    <div class="project-experience">
                      <ul>
                        {job.projectExperience[lang].map((project) => {
                          const parsed = parseProject(project, lang);
                          // highlight dates only in the head text
                          const dateHighlightedHead = highlightDates(
                            parsed.head,
                          );
                          return (
                            <li>
                              <span set:html={dateHighlightedHead} />
                              {(parsed.bullets.length > 0 ||
                                parsed.dataModuleName ||
                                parsed.dataModuleDetails.length > 0) && (
                                <ul class="sub-bullets">
                                  {parsed.bullets.map((b) => (
                                    <li>{b}</li>
                                  ))}
                                  {parsed.dataModuleName && (
                                    <li>
                                      {parsed.dataModuleName}
                                      {parsed.dataModuleDetails.length > 0 && (
                                        <ul class="sub-bullets">
                                          {parsed.dataModuleDetails.map((d) => (
                                            <li>{d}</li>
                                          ))}
                                        </ul>
                                      )}
                                    </li>
                                  )}
                                </ul>
                              )}
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  </details>
                ),
            )
          }
        </div>
      </section>

      <section>
        <h2 class="section-title">{lang === "zh" ? "教育" : "Education"}</h2>
        <div class="content education-container">
          {
            aboutData.education.map((item) => (
              <div
                class="education-item"
                id={item.institution === "iSpan" ? "iSpan" : ""}
              >
                <div class="education-header">
                  <h3>{item.institution}</h3>
                  <span class="education-period">
                    <span class="date-highlight">{item.period}</span>
                  </span>
                </div>
                <ul>
                  {item.programs.map((program) => (
                    <li>{program}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <section>
        <h2 class="section-title">{lang === "zh" ? "技術經驗" : "Tech Experience"}</h2>
        <div class="content">
          {
            experienceData
              .filter(
                (job) =>
                  ![
                    "Macro Associate",
                    "Fintech PM, MA Program",
                    "Auditor",
                  ].includes(job.title),
              )
              .map((job) => (
                <details class="experience-item">
                  <summary class="job-header">
                    <h3>{job.title}</h3>
                    <div class="job-meta">
                      <span class="company">{job.company}</span>
                      <span class="period">{job.period}</span>
                    </div>
                  </summary>

                  {job.responsibilities &&
                    (job.responsibilities as any)[lang] &&
                    (job.responsibilities as any)[lang].length > 0 && (
                      <div class="responsibilities">
                        <ul>
                          {(job.responsibilities as any)[lang].map(
                            (responsibility: string) => (
                              <li>{responsibility}</li>
                            ),
                          )}
                        </ul>
                      </div>
                    )}
                  {job.title === "Software Engineer" &&
                    job.company === "Tata Consultancy Services" && (
                      <div class="skills-section">
                        {/* Frontend skills used at TCS */}
                        {skillsData.categories
                          .filter(
                            (category) =>
                              category.name === "Frontend Development",
                          )
                          .map((category) => (
                            <div class="skill-category">
                              <h5>{category.name}</h5>
                              <div class="skill-tags">
                                {[
                                  "Angular.js",
                                  "TypeScript",
                                  "SCSS / CSS",
                                  "i18n / Localization",
                                  "Registry Pattern",
                                  "Singleton Pattern",
                                  "Single Source of Truth",
                                ].map((name) => {
                                  const skill = ((category as any).subcategories
                                    ? (category as any).subcategories.flatMap((sub: any) => sub.skills)
                                    : (category as any).skills || []
                                  ).find((s: any) => s.name === name);
                                  if (!skill) return null;
                                  const gradeMap: Record<string, string> = {
                                    shade1: "S",
                                    shade2: "A",
                                    shade3: "B",
                                    shade4: "C",
                                    shade5: "D",
                                  };
                                  return (
                                    <span
                                      class={`pill ${category.pillClass} ${skill.level}`}
                                      data-tooltip={`Level: ${gradeMap[skill.level] || skill.level}`}
                                    >
                                      {skill.name}
                                    </span>
                                  );
                                })}
                              </div>
                            </div>
                          ))}
                        <div class="mermaid-diagram margin-top">
                          <pre class="mermaid">
                            {`graph TD
    A["Astro Pages<br/>src/pages/*.astro<br/>File-based routing"] --> B["BaseLayout.astro<br/>Global app shell<br/>CSS manifest + head + transitions"]
    B --> C["Static Astro Components<br/>Nav.astro / Footer.astro / QAPlatform.astro"]
    B --> D["Page Content Slot<br/>Page-specific Astro sections"]

    C --> E["ThemeToggle.tsx<br/>React island in Nav"]
    D --> F["Client Islands<br/>client:load React components"]
    F --> G["SkillsBubbleChart.tsx<br/>React + D3"]
    F --> H["PeopleManagement.tsx<br/>Interactive React UI"]

    E --> I["Astro Hydration Runtime<br/>Astro.load + astro-island"]
    G --> I
    H --> I
    I --> J["React hydration success<br/>useEffect + event binding"]
    J --> K["D3 render into SVG<br/>bubble chart / treemap"]

    C --> L["astro:page-load re-init<br/>Nav / QABot / module scripts"]
    E --> M["Shared icon resources<br/>Icon.tsx + IconPaths.ts"]
    G --> M
    H --> M

    style A fill:#6366f1,stroke:#4338ca,stroke-width:3px,color:#ffffff
    style B fill:#8b5cf6,stroke:#7c3aed,stroke-width:3px,color:#ffffff
    style C fill:#7c3aed,stroke:#6d28d9,stroke-width:3px,color:#ffffff
    style D fill:#4f46e5,stroke:#3730a3,stroke-width:3px,color:#ffffff
    style E fill:#0ea5e9,stroke:#0284c7,stroke-width:2px,color:#ffffff
    style F fill:#06b6d4,stroke:#0891b2,stroke-width:3px,color:#ffffff
    style G fill:#06b6d4,stroke:#0891b2,stroke-width:2px,color:#ffffff
    style H fill:#06b6d4,stroke:#0891b2,stroke-width:2px,color:#ffffff
    style I fill:#f59e0b,stroke:#d97706,stroke-width:3px,color:#ffffff
    style J fill:#f97316,stroke:#ea580c,stroke-width:2px,color:#ffffff
    style K fill:#ef4444,stroke:#dc2626,stroke-width:2px,color:#ffffff
    style L fill:#14b8a6,stroke:#0f766e,stroke-width:2px,color:#ffffff
    style M fill:#10b981,stroke:#059669,stroke-width:2px,color:#ffffff`}
                          </pre>
                        </div>
                        {/* Backend/API skills used at TCS */}
                        {skillsData.categories
                          .filter(
                            (category) =>
                              category.name === "Backend Development",
                          )
                          .map((category) => (
                            <div class="skill-category">
                              <h5>{category.name}</h5>
                              {category.subcategories &&
                                category.subcategories
                                  .filter((sub) =>
                                    [
                                      "Java",
                                      "General",
                                    ].includes(sub.name),
                                  )
                                  .map((subcategory) => (
                                    <div class="skill-subcategory">
                                      <h6>{subcategory.name}</h6>
                                      <div class="skill-tags">
                                        {(() => {
                                          const allowedBySubcat = {
                                            Java: ["Java 8 11 17 21"],
                                            General: [
                                              "XML Configuration",
                                              "API Gateway",
                                              "RESTful API",
                                              "Chain of Responsibility",
                                              "Adapter Pattern",
                                              "Facade Pattern",
                                              "Externalized Configuration",
                                            ],
                                          };
                                          return subcategory.skills
                                            .filter((s) =>
                                              (
                                                allowedBySubcat[
                                                  subcategory.name
                                                ] || []
                                              ).includes(s.name),
                                            )
                                            .map((skill) => {
                                              const gradeMap = {
                                                shade1: "S",
                                                shade2: "A",
                                                shade3: "B",
                                                shade4: "C",
                                                shade5: "D",
                                              };
                                              return (
                                                <span
                                                  class={`pill ${category.pillClass} ${skill.level}`}
                                                  data-tooltip={`Level: ${gradeMap[skill.level] || skill.level}`}
                                                >
                                                  {skill.name}
                                                </span>
                                              );
                                            });
                                        })()}
                                      </div>
                                      {(subcategory as any).descriptions &&
                                        (subcategory as any).descriptions[
                                          job.company
                                        ] &&
                                        (subcategory as any).descriptions[
                                          job.company
                                        ][lang] &&
                                        (subcategory as any).descriptions[
                                          job.company
                                        ][lang].length > 0 && (
                                          <ul class="skill-subdescription">
                                            {(subcategory as any).descriptions[
                                              job.company
                                            ][lang].map((desc: string) => (
                                              <li
                                                set:html={desc.replace(
                                                  /(https?:\/\/[^\s]+)/g,
                                                  '<a href="$1" target="_blank">$1</a>',
                                                )}
                                              />
                                            ))}
                                          </ul>
                                        )}
                                    </div>
                                  ))}
                            </div>
                          ))}
                        {/* Architecture Diagram: Angular + Java Gateway System */}
                        <div class="mermaid-diagram margin-top">
                          <pre class="mermaid">
                            {`flowchart LR
    subgraph "Frontend (Angular.js)"
        A["Angular Components\\n(View / Logic / Style)"]
        AR["Angular Routing Module"]
        REG["Global Config Registry\\n(Registry + Singleton Pattern)"]
        A --> AR
        A --> REG
    end

    subgraph "Gateway Layer (Java)"
        GW["Java Gateway"]
        INS["Header Inserter Beans\\n(Java Interceptors)"]
        ADP["Adapter / Facade\\n(XML + JSON Schema Mapping)"]
        EXT["Externalized Config\\n(Multi-env Config Matrix)"]
        GW --> INS
        GW --> ADP
        GW --> EXT
    end

    subgraph "Backend Systems"
        BE["Legacy Backend Services"]
    end

    AR -->|"REST API Calls"| GW
    REG -->|"Centralized Route Lookups"| GW
    INS -->|"Injects Headers"| BE
    ADP -->|"Transforms Payloads"| BE

    classDef fe fill:#e8f4fd,stroke:#2196f3,color:#0b1a33
    classDef gw fill:#fff3e0,stroke:#ff9800,color:#0b1a33
    classDef be fill:#e8f5e9,stroke:#43a047,color:#0b1a33
    class A,AR,REG fe
    class GW,INS,ADP,EXT gw
    class BE be`}
                          </pre>
                        </div>
                      </div>
                    )}

                  {job.title === "Freelancer" && (
                    <div class="skills-section">
                      {skillsData.categories
                        .filter((category) =>
                          ["Backend Development", "AI", "Tools"].includes(
                            category.name,
                          ),
                        )
                        .map((category) => (
                          <div class="skill-category">
                            <h5>{category.name}</h5>
                            {category.subcategories ? (
                              category.subcategories
                                .filter((subcategory) => {
                                  // Only show relevant subcategories for Freelancer
                                  if (category.name === "Backend Development") {
                                    return [
                                      "PHP",
                                      "Python",
                                    ].includes(subcategory.name);
                                  }
                                  if (category.name === "AI") {
                                    return (
                                      subcategory.name === "Frameworks & APIs"
                                    );
                                  }
                                  if (category.name === "Tools") {
                                    return subcategory.name === "Others";
                                  }
                                  return false;
                                })
                                .map((subcategory) => (
                                  <div class="skill-subcategory">
                                    <h6>{subcategory.name}</h6>
                                    <div class="skill-tags">
                                      {
                                        // Only show PHP and Laravel for Backend Development
                                        (category.name ===
                                          "Backend Development" &&
                                        subcategory.name === "PHP"
                                          ? subcategory.skills.filter(
                                              (s) => ["PHP 12", "Laravel"].includes(s.name),
                                            )
                                          : category.name ===
                                                "Backend Development" &&
                                              subcategory.name === "Python"
                                            ? subcategory.skills.filter((s) =>
                                                s.name === "FastAPI",
                                              )
                                            : category.name === "AI" &&
                                                subcategory.name ===
                                                  "Frameworks & APIs"
                                              ? subcategory.skills.filter((s) =>
                                                  [
                                                    "LangChain",
                                                    "OpenAI API",
                                                    "ChatOpenAI",
                                                    "LLMChain",
                                                    "PromptTemplate",
                                                    "LangChain RAG",
                                                  ].includes(s.name),
                                                )
                                              : category.name === "Tools" &&
                                                  subcategory.name === "Others"
                                                ? subcategory.skills.filter(
                                                    (s) =>
                                                      s.name === "WordPress",
                                                  )
