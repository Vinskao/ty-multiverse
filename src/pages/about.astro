  <!-- Mermaid.js for on-page diagrams -->
  <script>
    import { getMermaidConfig } from '../scripts/mermaid-theme';

    let themeObserver: MutationObserver | null = null;

    async function loadMermaid() {
      if (!window["mermaid"]) {
        await new Promise<void>((resolve, reject) => {
          const s = document.createElement("script");
          s.src = "https://cdn.jsdelivr.net/npm/mermaid@10.6.1/dist/mermaid.min.js";
          s.onload = () => resolve();
          s.onerror = reject;
          document.head.appendChild(s);
        });
      }
      const mermaidLib = window["mermaid"] as any;
      if (mermaidLib) {
        // 根據當前主題設定 Mermaid 主題
        const isDarkMode =
          document.documentElement.classList.contains("theme-dark");
        const mermaidCfg = getMermaidConfig(isDarkMode);
        mermaidLib.initialize({ startOnLoad: true, ...mermaidCfg });

        // Force re-render all diagrams after theme change
        setTimeout(() => {
          mermaidLib.init();
        }, 100);

        // 監聽主題變化，重新初始化 Mermaid (guard against duplicates)
        if (!themeObserver) {
          themeObserver = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
              if (
                mutation.type === "attributes" &&
                mutation.attributeName === "class"
              ) {
                const isDark =
                  document.documentElement.classList.contains("theme-dark");
                mermaidLib.initialize({ startOnLoad: true, ...getMermaidConfig(isDark) });
                // 重新渲染所有圖表
                setTimeout(() => {
                  mermaidLib.init();
                }, 100);
              }
            });
          });

          themeObserver.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["class"],
          });
        }
      }
    }

    // Call immediately for initial page load
    loadMermaid();
    // Re-run on every Astro view transition
    document.addEventListener('astro:page-load', loadMermaid);
  </script>

  <!-- Styles for export button live in ResumePreview component -->
