        A->>C: Query Task Status
        C-->>A: Return Status

        alt Task Complete
            A-->>F: Return AI Response
            F-->>U: Display Result
        else Processing
            F-->>U: Show Processing
        end
    end`}
                                      </pre>
                                    </div>
                                  </>
                                )}
                              </div>
                            ))
                          ) : (
                            <div class="skill-tags">
                              {category.skills.map((skill) => {
                                const gradeMap = {
                                  shade1: "S",
                                  shade2: "A",
                                  shade3: "B",
                                  shade4: "C",
                                  shade5: "D",
                                };
                                return (
                                  <span
                                    class={`pill ${category.pillClass} ${skill.level} ${(skill as any).specialClass || ""}`}
                                    data-tooltip={`Level: ${gradeMap[skill.level] || skill.level}`}
                                  >
                                    {skill.name}
                                  </span>
                                );
                              })}
                            </div>
                          )}
                          {(category as any).description &&
                            (category as any).description[lang] &&
                            (category as any).description[lang].length > 0 && (
                              <ul class="skill-description">
                                {(category as any).description[lang].map(
                                  (desc: string, index: number) => (
                                    <li
                                      set:html={desc.replace(
                                        /(https?:\/\/[^\s]+)/g,
                                        '<a href="$1" target="_blank">$1</a>',
                                      )}
                                    />
                                  ),
                                )}
                              </ul>
                            )}

                          {category.name === "CI/CD" && (
                            <div class="mermaid-diagram">
                              <pre class="mermaid">
                                {`graph LR
                                  A[GitHub Repository] --> B[Clone and Setup]
                                  B --> C[Build with Node.js]
                                  C --> D[Build Docker Image with BuildKit]
                                  D --> E[Push to Docker Hub]
                                  E --> F[Deploy to Kubernetes]`}
                              </pre>
                            </div>
                          )}

                          {category.name === "Security & Authentication" && (
                            <div class="mermaid-diagram">
                              <pre class="mermaid">
                                {`sequenceDiagram
                                  participant User as User
                                  participant App as Application
                                  participant Auth as Authorization Server
                                  participant API as Resource Server
                                  
                                  User->>App: 1. Access Application
                                  App->>Auth: 2. Redirect to Authorization Page
                                  User->>Auth: 3. Login and Authorize
                                  Auth->>App: 4. Return Authorization Code
                                  App->>Auth: 5. Exchange Code for Token
                                  Auth->>App: 6. Return Access Token
                                  App->>API: 7. Access Resources with Token
                                  API->>App: 8. Return Protected Resources`}
                              </pre>
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  )}
                </details>
              ))
          }
        </div>
      </section>

      <section>
        <h2 class="section-title">{lang === "zh" ? "人格特質" : "Personality"}</h2>
        <div class="content personality-content">
          {aboutData.personality[lang].split("\n\n").map((para) => (
            <p set:html={para.replace(/\n/g, "<br>")} />
          ))}
        </div>
      </section>


    </main>
    <!-- Global language manager -->
    <script src="/tymultiverse/scripts/lang.js" is:inline></script>
    <script>
      import { navigate } from "astro:transitions/client";

      let cleanupAboutLangSync: (() => void) | null = null;

      function normalizeLang(code?: string | null) {
        return code && code.toLowerCase().startsWith("zh") ? "zh" : "en";
      }

      function syncAboutLanguage() {
        try {
          const appLang = (window as any).AppLang;
          if (!appLang) {
            setTimeout(syncAboutLanguage, 50);
            return;
          }

          const url = new URL(window.location.href);
          const urlLang = normalizeLang(url.searchParams.get("lang"));
          const appLangCode = normalizeLang(appLang.get());

          if (url.searchParams.has("lang")) {
            if (appLangCode !== urlLang) {
              appLang.set(urlLang);
            }
          } else {
            url.searchParams.set("lang", appLangCode);
            window.history.replaceState({}, "", url.toString());
          }

          if (cleanupAboutLangSync) {
            cleanupAboutLangSync();
            cleanupAboutLangSync = null;
          }

          cleanupAboutLangSync = appLang.onChange(({ code }: { code: string }) => {
            const nextLang = normalizeLang(code);
            const nextUrl = new URL(window.location.href);
            const currentLang = normalizeLang(nextUrl.searchParams.get("lang"));

            if (currentLang !== nextLang) {
              if (typeof (window as any).__saveLanguageSwitchScroll === "function") {
                (window as any).__saveLanguageSwitchScroll();
              }
              nextUrl.searchParams.set("lang", nextLang);
              navigate(nextUrl.toString());
            }
          });
        } catch (_) {}
      }

      syncAboutLanguage();
      document.addEventListener("astro:page-load", syncAboutLanguage);
    </script>

    <script>
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement | null;
        const btn = target?.closest(".copy-resume-btn") as HTMLButtonElement | null;
        if (!btn) return;
        e.stopPropagation();
        e.preventDefault();
        const text = (btn.closest("details") as HTMLElement)?.dataset.copy ?? "";
        navigator.clipboard.writeText(text).then(() => {
          const label = btn.querySelector<HTMLElement>(".copy-label");
          const svg = btn.querySelector("svg");
          const original = label?.textContent ?? "";
          if (label) label.textContent = "✓";
          if (svg) svg.style.display = "none";
          btn.classList.add("copied");
          setTimeout(() => {
            if (label) label.textContent = original;
            if (svg) svg.style.display = "";
            btn.classList.remove("copied");
          }, 1800);
        });
      });
    </script>

    <script>
      const gitCommand = `"REPO: $(git remote get-url origin)"; git log -n 50 --stat --date=iso-strict --pretty=format:"===COMMIT===%nHASH: %H%nDATE: %cI%nMSG: %s%n%b%n---FILES---"`;

      function initGitCommitIngest() {
        const panel = document.querySelector<HTMLElement>("[data-admin-git-commit]");
        const image = document.querySelector<HTMLElement>(".work-photo");
        const overlay = document.querySelector<HTMLElement>(".work-photo-overlay");
        const commandEl = document.querySelector<HTMLElement>("[data-git-command]");
        const copyBtn = document.querySelector<HTMLButtonElement>("[data-copy-git-command]");
        const submitBtn = document.querySelector<HTMLButtonElement>("[data-submit-git-commits]");
        const textarea = document.querySelector<HTMLTextAreaElement>("[data-git-commit-text]");
        const result = document.querySelector<HTMLElement>("[data-git-commit-result]");
        const embedding = document.querySelector<HTMLInputElement>("[data-git-embedding]");

        if (!panel || !image || !commandEl || !copyBtn || !submitBtn || !textarea || !result || !embedding) return;

        const isAdmin = localStorage.getItem("isAdmin") === "true";
        panel.hidden = !isAdmin;
        image.style.display = isAdmin ? "none" : "";
        if (overlay) overlay.style.display = isAdmin ? "none" : "";
        commandEl.textContent = gitCommand;

        copyBtn.onclick = async () => {
          await navigator.clipboard.writeText(gitCommand);
          copyBtn.classList.add("copied");
          setTimeout(() => copyBtn.classList.remove("copied"), 1200);
        };

        submitBtn.onclick = async () => {
          const token = localStorage.getItem("token");
          const text = textarea.value.trim();
          if (!token) {
            result.textContent = "Missing token. Please log in again.";
            return;
          }
          if (!text) {
            result.textContent = "Paste git output before ingesting.";
            return;
          }

          submitBtn.disabled = true;
          result.textContent = "Ingesting...";
          try {
            const response = await fetch("/maya-sawa/git-commits/ingest", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${token}`,
              },
              body: JSON.stringify({
                text,
                generate_embedding: embedding.checked,
              }),
            });
            const data = await response.json();
            if (!response.ok) {
              throw new Error(data.detail || "Ingest failed");
            }
            result.textContent = `Created ${data.created}, duplicate ${data.skipped_duplicate}, trivial ${data.skipped_trivial}, embedding failed ${data.embedding_failed}.`;
          } catch (error) {
            result.textContent = error instanceof Error ? error.message : "Ingest failed";
          } finally {
            submitBtn.disabled = false;
          }
        };
      }

      initGitCommitIngest();
      document.addEventListener("astro:page-load", initGitCommitIngest);
    </script>

