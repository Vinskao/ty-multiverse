---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import CKEditor from '../components/CKEditor.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const links = [
    "https://www.freecodecamp.org/certification/TianyiKao/javascript-algorithms-and-data-structures",
    "https://www.freecodecamp.org/certification/TianyiKao/data-visualization",
    "",
    "https://www.cloudskillsboost.google/public_profiles/28b434be-64c8-4b98-b2a6-7851772bda44/badges/3572551?utm_medium=social&utm_source=linkedin&utm_campaign=ql-social-share",
	"",
];
---
<body>

<BaseLayout
	title="My Work | Tianyi Kao"
	description="Learn about TY's most recent projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="TY's Blog"
				tagline="Although each article focuses on a single topic, it often contains a variety of key knowledge points. By identifying and connecting these same points across different articles, you can build a more comprehensive understanding."
				align="start"
			>
				<div slot="title" data-i18n="work.title">TY's Blog</div>
				<div slot="tagline" data-i18n="work.tagline">Although each article focuses on a single topic, it often contains a variety of key knowledge points. By identifying and connecting these same points across different articles, you can build a more comprehensive understanding.</div>
			</Hero>


			<CKEditor />
			<div class="article-count" style="text-align: center;">
				<p class="article-count-text" style="margin: 0 auto;" data-i18n="work.articleCount" data-i18n-count={projects.length}>📚 Total {projects.length} articles</p>
				<div class="sync-section" style="margin-top: 1rem; text-align: center;">
					<button id="sync-articles-btn" class="sync-btn" data-i18n="work.syncBtn" style="
						background: #007acc;
						color: white;
						border: none;
						padding: 0.75rem 1.5rem;
						border-radius: 6px;
						cursor: pointer;
						font-size: 0.9rem;
						font-weight: 500;
						transition: all 0.2s ease;
						box-shadow: 0 2px 4px rgba(0, 122, 204, 0.2);
					">
						🔄 Sync Articles to DB
					</button>
					<div id="sync-status" class="sync-status" style="
						margin-top: 0.5rem;
						font-size: 0.85rem;
						min-height: 1.2em;
						font-weight: 500;
					"></div>
				</div>
			</div>
			<Grid variant="offset">
				{
					projects.map((project, index) => (
						<li>
							<a href={links[index]}>
								<PortfolioPreview project={project} />
							</a>
						</li>
					))
				}
			</Grid>
			
		</main>
		<ContactCTA />
	</div>

	<script>
		import { syncService } from '../services/api/syncService';
		import i18nData from '../storages/i18n.json';

		document.addEventListener('DOMContentLoaded', () => {
			const syncBtn = document.getElementById('sync-articles-btn') as HTMLButtonElement;
			const syncStatus = document.getElementById('sync-status');

			const getI18n = (key: string) => {
				const lang = (window as any).AppLang ? (window as any).AppLang.get() : (localStorage.getItem('site_language') || 'en');
				const keys = key.split('.');
				let translation: any = i18nData;
				for (const k of keys) {
					translation = translation[k];
				}
				return translation[lang] || translation['en'] || key;
			};

			if (syncBtn && syncStatus) {
				syncBtn.addEventListener('click', async () => {
					try {
						const lang = (window as any).AppLang ? (window as any).AppLang.get() : 'en';
						
						// 禁用按鈕並顯示載入狀態
						syncBtn.disabled = true;
						syncBtn.style.background = '#666';
						syncBtn.textContent = lang === 'zh' ? '🔄 同步中...' : '🔄 Syncing...';
						syncStatus.textContent = getI18n('work.syncPreparing');
						syncStatus.style.color = '#666';

						// 執行同步
						const result = await syncService.syncArticlesToBackend();

						if (result.success) {
							const vectorInfo =
								typeof result.vectorizedCount === 'number'
									? (lang === 'zh' ? `, 向量化: ${result.vectorizedCount}` : `, embeddings: ${result.vectorizedCount}`)
									: '';
							const purgeInfo =
								typeof result.purgedCount === 'number'
									? (lang === 'zh' ? `, 清理: ${result.purgedCount}` : `, purged: ${result.purgedCount}`)
									: '';
							
							const msg = lang === 'zh' ? '同步成功' : result.message;
							const articleText = lang === 'zh' ? '篇文章' : 'articles';
							
							syncStatus.textContent = `✅ ${msg} (${result.articleCount} ${articleText}${vectorInfo}${purgeInfo})`;
							syncStatus.style.color = '#28a745';
							syncBtn.style.background = '#28a745';
							syncBtn.textContent = getI18n('work.synced');
						} else {
							throw new Error(result.message);
						}

					} catch (error) {
						console.error('Sync failed:', error);
						syncStatus.textContent = `❌ ${getI18n('work.retry')}: ${error.message}`;
						syncStatus.style.color = '#dc3545';
						syncBtn.style.background = '#dc3545';
						syncBtn.textContent = getI18n('work.retry');
					} finally {
						syncBtn.disabled = false;
						// 3秒後恢復原始狀態
						setTimeout(() => {
							syncBtn.style.background = '#007acc';
							syncBtn.textContent = getI18n('work.syncBtn');
							syncStatus.textContent = '';
						}, 3000);
					}
				});
			}
		});
	</script>
</BaseLayout>

</body>