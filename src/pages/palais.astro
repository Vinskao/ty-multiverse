---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Galwall from "../components/Galwall.astro";
import palaisCssUrl from "../styles/palais.css?url";
import galwallCssUrl from "../styles/galwall.css?url";

// 獲取 URL 參數
const url = new URL(Astro.request.url);
const username = url.searchParams.get("username");

// 檢查登入狀態
const isLoggedIn = !!username; // #4: 不再依賴 URL token（機密改由 localStorage + 後端強制）

// 如果未登入，重定向到登入頁面
if (!isLoggedIn) {
  return Astro.redirect(
    `/tymultiverse/login?redirect=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`,
  );
}
---

<BaseLayout title="Palais | Wavo Yuropha" description="Learn about TY's palais">
  <Fragment slot="head">
    <link rel="stylesheet" href={palaisCssUrl} />
    <link rel="stylesheet" href={galwallCssUrl} />
  </Fragment>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero title="Palais" tagline="Welcome to Lily Palais." align="start" />

      <div class="gang-video-container" data-palais-media-zoom>
        {
          [
            "https://peoplesystem.tatdvsonorth.com/images/people/gangHagisun.mp4",
            "https://peoplesystem.tatdvsonorth.com/images/people/gangHagishi.mp4",
            "https://peoplesystem.tatdvsonorth.com/images/people/gangPhoenix.mp4",
            "https://peoplesystem.tatdvsonorth.com/images/people/gangRegalos.mp4",
            "https://peoplesystem.tatdvsonorth.com/images/people/gangRapeum.mp4",
          ].map((src) => (
            <video
              src={src}
              autoplay
              muted
              loop
              playsinline
              class="gang-video"
              onerror="this.style.display='none'"
            />
          ))
        }
      </div>

      <div class="system-container module-buttons">
        <a
          href={`/tymultiverse/palais/fight?username=${username}`}
          class="module-button">Fight</a
        >
        <a
          href={`/tymultiverse/palais/group?username=${username}`}
          class="module-button">Group</a
        >
        <a
          href={`/tymultiverse/palais/dance?username=${username}`}
          class="module-button">Dance</a
        >
        <a
          href={`/tymultiverse/palais/party?username=${username}`}
          class="module-button">Party</a
        >
        <a
          href={`/tymultiverse/palais/live?username=${username}`}
          class="module-button">Live</a
        >
        <a
          href={`/tymultiverse/palais/levels?username=${username}`}
          class="module-button">Levels</a
        >
      </div>

      <div class="galwall-container">
        <Galwall />
      </div>
    </main>
  </div>
</BaseLayout>

<script
  async
  src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"
></script>
<script
  async
  defer
  src="https://cdnjs.cloudflare.com/ajax/libs/d3/4.2.2/d3.min.js"></script>
<script>
  import "../scripts/palaisMediaZoom";
</script>
